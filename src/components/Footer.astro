---
import contactData from '../content/settings/contact.json';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-inner">

    <!-- Brand -->
    <div class="footer-brand">
      <a href="/" class="footer-logo">TNC<em>.</em>18</a>
      <p class="footer-tagline">Retail & Interior Design</p>
      <p class="footer-location">Bangkok, Thailand</p>
    </div>

    <!-- Navigation -->
    <nav class="footer-nav" aria-label="Footer navigation">
      <p class="footer-nav-label">Pages</p>
      <a href="/">Home</a>
      <a href="/portfolio">Work</a>
      <a href="/about-services">Studio</a>
      <a href="/contact">Contact</a>
    </nav>

    <!-- Contact -->
    <div class="footer-contact">
      <p class="footer-nav-label">Connect</p>
      {contactData.instagram && (
        <a href={contactData.instagram} target="_blank" rel="noopener">Instagram</a>
      )}
      {contactData.tiktok && (
        <a href={contactData.tiktok} target="_blank" rel="noopener">TikTok</a>
      )}
      {contactData.facebook && (
        <a href={contactData.facebook} target="_blank" rel="noopener">Facebook</a>
      )}
      {contactData.line && (
        <a href={contactData.line} target="_blank" rel="noopener">Line OA</a>
      )}
      {contactData.email && (
        <a href={`mailto:${contactData.email}`}>{contactData.email}</a>
      )}
    </div>

  </div>

  <!-- Bottom bar -->
  <div class="footer-bottom">
    <p class="footer-copy">© {year} TNC.18. All rights reserved.</p>
    <p class="footer-copy">Senior partners only. No junior hand-offs.</p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--navy-deep, #0E2140);
    padding: 5rem var(--pad-x, 5vw) 0;
    border-top: 0.5px solid rgba(255,255,255,0.06);
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3.5rem;
    padding-bottom: 4rem;
    border-bottom: 0.5px solid rgba(255,255,255,0.07);
  }

  /* Brand */
  .footer-brand { display: flex; flex-direction: column; gap: 0.5rem; }

  .footer-logo {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 1.4rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    text-decoration: none;
    color: rgba(255,255,255,0.5);
    transition: color 0.2s;
  }
  .footer-logo:hover { color: #fff; }
  .footer-logo em { font-style: normal; color: #fff; }

  .footer-tagline {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 0.82rem;
    font-weight: 300;
    color: rgba(255,255,255,0.4);
    letter-spacing: 0.04em;
    margin-top: 0.25rem;
  }

  .footer-location {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 0.75rem;
    font-weight: 300;
    color: rgba(255,255,255,0.25);
    letter-spacing: 0.04em;
  }

  /* Nav + Contact columns */
  .footer-nav,
  .footer-contact {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .footer-nav-label {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 0.58rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.25);
    margin-bottom: 0.25rem;
  }

  .footer-nav a,
  .footer-contact a {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 0.88rem;
    font-weight: 400;
    color: rgba(255,255,255,0.55);
    text-decoration: none;
    letter-spacing: 0.04em;
    transition: color 0.2s;
  }
  .footer-nav a:hover,
  .footer-contact a:hover { color: #fff; }

  /* Bottom bar */
  .footer-bottom {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 1.75rem 0 2.5rem;
  }

  .footer-copy {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 0.72rem;
    font-weight: 300;
    color: rgba(255,255,255,0.2);
    letter-spacing: 0.04em;
    line-height: 1.5;
  }

  @media (min-width: 768px) {
    .footer-inner {
      grid-template-columns: 1.8fr 1fr 1fr;
      gap: 5rem;
    }
    .footer-bottom {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }
</style>
