---
import contactData from '../content/settings/contact.json';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-inner">

    <div class="footer-brand">
      <a href="/" class="footer-logo">TNC<em>.</em>18</a>
      <p class="footer-tagline">Retail & Interior Design · Bangkok</p>
    </div>

    <nav class="footer-nav" aria-label="Footer navigation">
      <p class="footer-col-label">Pages</p>
      <a href="/">Home</a>
      <a href="/portfolio">Work</a>
      <a href="/about-services">Studio</a>
      <a href="/contact">Contact</a>
    </nav>

    <div class="footer-connect">
      <p class="footer-col-label">Connect</p>
      {contactData.instagram && <a href={contactData.instagram} target="_blank" rel="noopener">Instagram</a>}
      {contactData.tiktok    && <a href={contactData.tiktok}    target="_blank" rel="noopener">TikTok</a>}
      {contactData.facebook  && <a href={contactData.facebook}  target="_blank" rel="noopener">Facebook</a>}
      {contactData.line      && <a href={contactData.line}      target="_blank" rel="noopener">Line OA</a>}
      {contactData.email     && <a href={`mailto:${contactData.email}`}>{contactData.email}</a>}
    </div>

  </div>

  <div class="footer-bottom">
    <p class="footer-copy">© {year} TNC.18. All rights reserved.</p>
    <p class="footer-copy">Senior partners only. No junior hand-offs.</p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--navy-deep, #0E2140);
    padding: 1.5rem var(--pad-x, 5vw) 0;
    border-top: 0.5px solid rgba(255,255,255,0.06);
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    padding-bottom: 1rem;
    border-bottom: 0.5px solid rgba(255,255,255,0.07);
  }

  .footer-logo {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    text-decoration: none;
    color: rgba(255,255,255,0.5);
    display: block;
    margin-bottom: 0.3rem;
    transition: color 0.2s;
  }
  .footer-logo:hover { color: #fff; }
  .footer-logo em { font-style: normal; color: #fff; }

  .footer-tagline {
    font-size: 0.72rem;
    font-weight: 300;
    color: rgba(255,255,255,0.25);
    letter-spacing: 0.04em;
  }

  /* Mobile: hide nav/connect cols */
  .footer-nav,
  .footer-connect { display: none; }

  .footer-col-label {
    font-size: 0.52rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.2);
    margin-bottom: 0.2rem;
  }

  .footer-nav a,
  .footer-connect a {
    font-size: 0.82rem;
    font-weight: 400;
    color: rgba(255,255,255,0.45);
    text-decoration: none;
    transition: color 0.2s;
  }
  .footer-nav a:hover,
  .footer-connect a:hover { color: #fff; }

  /* Mobile: brand hidden, only bottom bar shows */
  .footer-brand { display: none; }
  .footer-tagline { display: none; }

  .footer-bottom {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 0.3rem;
    padding: 1.25rem 0 1.5rem;
    text-align: center;
  }

  .footer-copy {
    font-size: 0.65rem;
    font-weight: 400;
    color: rgba(255,255,255,0.35);
    letter-spacing: 0.03em;
  }

  /* Desktop: restore full 3-col layout */
  @media (min-width: 768px) {
    .footer-inner {
      grid-template-columns: 1.6fr 1fr 1fr;
      gap: 4rem;
      align-items: start;
    }
    .footer-nav,
    .footer-connect { display: flex; flex-direction: column; gap: 0.55rem; }
    .footer-brand {
      flex-direction: column;
      align-items: flex-start;
      justify-content: flex-start;
    }
    .footer-tagline { display: block; }
    .footer-bottom {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
      padding: 1.25rem 0 1.75rem;
    }
  }
</style>
