---
import contactData from "../content/settings/contact.json";
const LINE_ICON = "https://res.cloudinary.com/dynjnftnu/image/upload/v1776531320/LINE_Brand_icon_2_ytuls0.png";

interface Props {
  ctaTitle?: string;
  ctaSub?: string;
  hideCta?: boolean;
}
const {
  ctaTitle = "Ready to Start?",
  ctaSub   = "Senior partners only. Fast turnaround. We reply within 2 hours.",
  hideCta  = false,
} = Astro.props;
---

<footer class="footer-root">
  {!hideCta && (
    <div class="footer-cta">
      <div class="footer-left">
        <p class="footer-eyebrow">Get In Touch</p>
        <h2 class="footer-title">{ctaTitle}</h2>
        <p class="footer-sub">{ctaSub}</p>
      </div>
      <div class="footer-right">
        {contactData.line && (
          <a href={contactData.line} target="_blank" rel="noopener" class="footer-line-btn">
            <img src={LINE_ICON} alt="LINE" class="footer-line-icon" />
            Message on Line
          </a>
        )}
      </div>
    </div>
  )}
</footer>

<style>
  .footer-root {
    background: var(--navy-deep, #0E2140);
    padding: 6rem var(--pad-x, 5vw) 6rem;
  }

  .footer-cta {
    display: flex;
    flex-direction: column;
    gap: 3rem;
    align-items: flex-start;
  }

  .footer-eyebrow {
    font-family: "Plus Jakarta Sans", system-ui, sans-serif;
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(244,243,239,0.35);
    margin-bottom: 1.5rem;
  }

  .footer-title {
    font-family: "Plus Jakarta Sans", system-ui, sans-serif;
    font-size: clamp(2.5rem, 6vw, 5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: #F4F3EF;
    line-height: 0.95;
    margin-bottom: 1.5rem;
  }

  .footer-sub {
    font-family: "Plus Jakarta Sans", system-ui, sans-serif;
    font-size: 0.9rem;
    font-weight: 400;
    color: rgba(244,243,239,0.4);
    line-height: 1.7;
    max-width: 380px;
  }

  .footer-right {
    display: flex;
    align-items: flex-start;
  }

  .footer-line-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-family: "Plus Jakarta Sans", system-ui, sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    color: #F4F3EF;
    background: transparent;
    padding: 1rem 2.5rem;
    border: 1px solid rgba(244,243,239,0.25);
    transition: background 0.22s, border-color 0.22s;
    white-space: nowrap;
  }
  .footer-line-btn:hover {
    background: rgba(244,243,239,0.08);
    border-color: rgba(244,243,239,0.6);
  }

  .footer-line-icon {
    width: 20px; height: 20px;
    object-fit: contain;
    border-radius: 3px;
    flex-shrink: 0;
  }

  @media (min-width: 768px) {
    .footer-root { padding: 7rem 8% 7rem; }
    .footer-cta {
      flex-direction: row;
      align-items: flex-end;
      justify-content: space-between;
      gap: 5rem;
    }
    .footer-left { flex: 1; max-width: 560px; }
    .footer-right { flex-shrink: 0; align-self: flex-end; }
  }

  @media (min-width: 1200px) {
    .footer-root { padding: 8rem 10% 8rem; }
  }
</style>
