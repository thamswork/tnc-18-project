---
const links = [
  { href: '/portfolio',      label: 'Work'    },
  { href: '/about-services', label: 'Studio'  },
  { href: '/contact',        label: 'Contact' },
];
const path = Astro.url.pathname;
---

<header id="site-header">
  <a href="/" class="logo" aria-label="TNC.18 Home">
    <span class="logo-type">TNC<em>.</em>18</span>
  </a>

  <nav class="nav-links" aria-label="Primary">
    {links.map(link => (
      <a
        href={link.href}
        class={`nav-link ${path === link.href || path.startsWith(link.href + '/') ? 'active' : ''}`}
      >{link.label}</a>
    ))}
  </nav>

  <div class="nav-right">
    <a href="/contact" class="nav-cta">Enquire</a>
    <button id="hamburger" class="hamburger" aria-label="Open menu" aria-expanded="false">
      <span></span>
      <span></span>
    </button>
  </div>
</header>

<div id="mobile-menu" class="mobile-menu" aria-hidden="true">
  <div class="mobile-menu-inner">
    {links.map(link => (
      <a href={link.href} class="mobile-link">{link.label}</a>
    ))}
    <a href="/contact" class="mobile-enquire">Enquire →</a>
  </div>
</div>

<style>
  #site-header {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 200;
    height: 60px;
    padding: 0 var(--pad-x, 1.25rem);
    display: flex;
    align-items: center;
    background: rgba(253,252,250,0.94);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 0.5px solid var(--cream-dark);
    transition: background 0.35s, border-color 0.35s;
  }

  #site-header.scrolled {
    background: rgba(253,252,250,0.99);
    border-bottom-color: var(--cream-mid);
    box-shadow: 0 1px 0 rgba(26,58,107,0.06);
  }

  /* Logo — deliberately compact */
  .logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    margin-right: auto;
  }

  .logo-type {
    font-family: var(--font-body);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--charcoal);
  }

  .logo-type em {
    font-style: normal;
    color: var(--navy);
  }

  /* Desktop nav */
  .nav-links {
    display: flex;
    gap: 2rem;
    margin-right: 2rem;
  }

  .nav-link {
    font-family: var(--font-body);
    font-size: 0.62rem;
    font-weight: 400;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    text-decoration: none;
    position: relative;
    padding-bottom: 2px;
    transition: color 0.2s;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 1.5px;
    background: var(--navy);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s cubic-bezier(0.4,0,0.2,1);
  }

  .nav-link:hover        { color: var(--navy); }
  .nav-link:hover::after { transform: scaleX(1); }
  .nav-link.active       { color: var(--navy); font-weight: 500; }
  .nav-link.active::after { transform: scaleX(1); }

  /* Right side */
  .nav-right {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .nav-cta {
    font-family: var(--font-body);
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--warm-white);
    background: var(--navy);
    text-decoration: none;
    padding: 0.48rem 1rem;
    transition: background 0.25s;
    white-space: nowrap;
  }

  .nav-cta:hover { background: var(--navy-mid); }

  /* Hamburger — nearly invisible until touched */
  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    opacity: 0.18;
    transition: opacity 0.2s;
  }

  .hamburger:hover,
  .hamburger:focus-visible { opacity: 1; outline: none; }

  .hamburger span {
    display: block;
    width: 18px;
    height: 1px;
    background: var(--navy);
    transition: transform 0.3s cubic-bezier(0.4,0,0.2,1), opacity 0.25s;
  }

  .hamburger[aria-expanded="true"] { opacity: 1; }
  .hamburger[aria-expanded="true"] span:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }
  .hamburger[aria-expanded="true"] span:nth-child(2) {
    transform: translateY(-6px) rotate(-45deg);
  }

  /* Mobile slide-down menu */
  .mobile-menu {
    position: fixed;
    top: 60px; left: 0; right: 0;
    z-index: 190;
    max-height: 0;
    overflow: hidden;
    background: var(--warm-white);
    border-bottom: 0.5px solid var(--cream-dark);
    transition: max-height 0.4s cubic-bezier(0.4,0,0.2,1);
  }

  .mobile-menu.open { max-height: 360px; }

  .mobile-menu-inner {
    padding: 1.25rem var(--pad-x, 1.25rem) 2rem;
    display: flex;
    flex-direction: column;
  }

  .mobile-link {
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 400;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--charcoal);
    text-decoration: none;
    padding: 0.65rem 0;
    border-bottom: 0.5px solid var(--cream-dark);
    transition: color 0.2s, padding-left 0.2s;
  }

  .mobile-link:hover { color: var(--navy); padding-left: 0.4rem; }

  .mobile-enquire {
    margin-top: 1.25rem;
    font-family: var(--font-body);
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--navy);
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .mobile-enquire:hover { opacity: 0.65; }

  @media (max-width: 768px) {
    .nav-links, .nav-cta { display: none; }
    .hamburger { display: flex; }
  }
</style>

<script>
  const header    = document.getElementById('site-header');
  const hamburger = document.getElementById('hamburger');
  const menu      = document.getElementById('mobile-menu');

  window.addEventListener('scroll', () => {
    header?.classList.toggle('scrolled', window.scrollY > 20);
  }, { passive: true });

  hamburger?.addEventListener('click', () => {
    const open = menu?.classList.toggle('open');
    hamburger.setAttribute('aria-expanded', String(open));
    menu?.setAttribute('aria-hidden', String(!open));
    hamburger.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
  });

  document.querySelectorAll('.mobile-link, .mobile-enquire').forEach(el => {
    el.addEventListener('click', () => {
      menu?.classList.remove('open');
      hamburger?.setAttribute('aria-expanded', 'false');
      menu?.setAttribute('aria-hidden', 'true');
      hamburger?.setAttribute('aria-label', 'Open menu');
    });
  });
</script>
