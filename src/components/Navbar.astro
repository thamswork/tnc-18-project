---
const links = [
  { href: '/portfolio',      label: 'Work'    },
  { href: '/about-services', label: 'Studio'  },
  { href: '/contact',        label: 'Contact' },
];
const path = Astro.url.pathname;
---

<header id="nav" role="banner">
  <a href="/" class="nav-logo" aria-label="TNC.18 home">
    TNC<em>.</em>18
  </a>

  <nav class="nav-links" aria-label="Primary navigation">
    {links.map(l => (
      <a
        href={l.href}
        class={`nav-link ${path === l.href || path.startsWith(l.href + '/') ? 'active' : ''}`}
      >{l.label}</a>
    ))}
  </nav>

  <div class="nav-right">
    <a href="/contact" class="nav-enquire">Enquire</a>
    <button id="nav-burger" class="nav-burger" aria-label="Open menu" aria-expanded="false">
      <span></span><span></span>
    </button>
  </div>
</header>

<div id="nav-drawer" class="nav-drawer" aria-hidden="true">
  {links.map(l => (
    <a href={l.href} class="drawer-link">{l.label}</a>
  ))}
  <a href="/contact" class="drawer-enquire">Enquire →</a>
</div>

<style>
  #nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 200;
    height: 64px;
    padding: 0 var(--pad-x, 5vw);
    display: flex;
    align-items: center;
    background: transparent;
    border-bottom: 0.5px solid rgba(26,26,26,0.08);
    transition: border-color 0.3s;
  }

  #nav.scrolled { background: rgba(248,247,244,0.97) !important; border-bottom-color: rgba(26,26,26,0.14); }

  .nav-logo { transition: color 0.4s; font-family: var(--font-body, 'Inter', sans-serif); font-size: 0.85rem; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ink, #1A1A1A); text-decoration: none; margin-right: auto; }
  .nav-logo em { font-style: normal; color: var(--navy, #1A3A6B); }

  .nav-links {
    display: flex;
    gap: 2.25rem;
    margin-right: 2rem;
  }

  .nav-link {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 0.65rem;
    font-weight: 400;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-light, #6B6B6B);
    text-decoration: none;
    position: relative;
    padding-bottom: 2px;
    transition: color 0.2s;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 1px;
    background: var(--navy, #1A3A6B);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s cubic-bezier(0.4,0,0.2,1);
  }

  .nav-link:hover,
  .nav-link.active { color: var(--ink, #1A1A1A); }

  .nav-link:hover::after,
  .nav-link.active::after { transform: scaleX(1); }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .nav-enquire {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #fff;
    background: var(--navy, #1A3A6B);
    text-decoration: none;
    padding: 0.5rem 1.1rem;
    transition: background 0.2s;
    white-space: nowrap;
  }
  .nav-enquire:hover { background: var(--navy-mid, #254E8F); }

  /* Hamburger — barely visible */
  .nav-burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    opacity: 0.2;
    transition: opacity 0.2s;
  }
  .nav-burger:hover,
  .nav-burger:focus-visible { opacity: 1; outline: none; }

  .nav-burger span {
    display: block;
    width: 18px; height: 1px;
    background: var(--ink, #1A1A1A);
    transition: transform 0.3s, opacity 0.2s;
  }

  .nav-burger[aria-expanded="true"] { opacity: 1; }
  .nav-burger[aria-expanded="true"] span:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }
  .nav-burger[aria-expanded="true"] span:nth-child(2) {
    transform: translateY(-6px) rotate(-45deg);
  }

  /* Drawer */
  .nav-drawer {
    position: fixed;
    top: 64px; left: 0; right: 0;
    z-index: 190;
    background: var(--bg, #F8F7F4);
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s cubic-bezier(0.4,0,0.2,1);
    border-bottom: 0.5px solid rgba(26,26,26,0.08);
  }
  .nav-drawer.open { max-height: 360px; }

  .drawer-link {
    display: block;
    font-family: var(--font-display, 'Tenor Sans', serif);
    font-size: 1.75rem;
    font-weight: 400;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--ink, #1A1A1A);
    text-decoration: none;
    padding: 0.7rem var(--pad-x, 5vw);
    border-bottom: 0.5px solid rgba(26,26,26,0.06);
    transition: color 0.2s, padding-left 0.2s;
  }
  .drawer-link:hover { color: var(--navy, #1A3A6B); padding-left: calc(var(--pad-x, 5vw) + 0.5rem); }

  .drawer-enquire {
    display: block;
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--navy, #1A3A6B);
    text-decoration: none;
    padding: 1.25rem var(--pad-x, 5vw) 1.75rem;
    transition: opacity 0.2s;
  }
  .drawer-enquire:hover { opacity: 0.6; }

  @media (max-width: 768px) {
    .nav-links, .nav-enquire { display: none; }
    .nav-burger { display: flex; }
  }
</style>

<script>
  const nav    = document.getElementById('nav');
  const burger = document.getElementById('nav-burger');
  const drawer = document.getElementById('nav-drawer');

  if (document.body.classList.contains('page-inner')) { nav?.classList.add('scrolled'); }
  window.addEventListener('scroll', () => {
    nav?.classList.toggle('scrolled', window.scrollY > 20);
  }, { passive: true });

  burger?.addEventListener('click', () => {
    const open = drawer?.classList.toggle('open');
    burger.setAttribute('aria-expanded', String(open));
    drawer?.setAttribute('aria-hidden', String(!open));
  });

  drawer?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      drawer.classList.remove('open');
      burger?.setAttribute('aria-expanded', 'false');
      drawer.setAttribute('aria-hidden', 'true');
    });
  });
</script>
<style>
  #nav:not(.scrolled) { border-bottom-color: transparent !important; box-shadow: none !important; background: transparent !important; backdrop-filter: none !important; -webkit-backdrop-filter: none !important; }
  #nav:not(.scrolled) .nav-logo,
  #nav:not(.scrolled) .nav-link,
  #nav:not(.scrolled) .nav-enquire { color: rgba(248,247,244,0.9) !important; }
  #nav:not(.scrolled) .nav-enquire { background: rgba(248,247,244,0.15) !important; border: 1px solid rgba(248,247,244,0.35) !important; }
  #nav:not(.scrolled) .nav-burger span { background: #F8F7F4 !important; }
<style is:global>
  body.page-inner #nav {
    background: rgba(248,247,244,0.97) !important;
    border-bottom: 0.5px solid rgba(26,26,26,0.1) !important;
  }
  body.page-inner .nav-logo,
  body.page-inner .nav-link { color: var(--ink, #1A1A1A) !important; }
  body.page-inner .nav-enquire { background: var(--navy, #1A3A6B) !important; color: #fff !important; }
  body.page-inner .nav-burger span { background: var(--ink, #1A1A1A) !important; }
</style>
