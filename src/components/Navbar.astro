---
const links = [
  { href: "/portfolio",      label: "Work"      },
  { href: "/about-services", label: "Who We Are"},
  { href: "/specbook",       label: "Specbook"  },
  { href: "/contact",        label: "Contact"   },
];
const path = Astro.url.pathname;
---

<header id="nav" role="banner">
  <a href="/" class="nav-logo" aria-label="TNC BUILD STUDIO home">
    TNC <em>BUILD</em> STUDIO
  </a>
  <nav class="nav-links" aria-label="Primary navigation">
    {links.map(l => (
      <a href={l.href} class={`nav-link ${path === l.href || path.startsWith(l.href + "/") ? "active" : ""}`}>{l.label}</a>
    ))}
  </nav>
  <div class="nav-right">
    <a href="/contact" class="nav-enquire">Enquire</a>
    <button id="nav-burger" class="nav-burger" aria-label="Open menu" aria-expanded="false">
      <span></span>
      <span></span>
    </button>
  </div>
</header>

<div id="nav-drawer" class="nav-drawer" aria-hidden="true">
  {links.map(l => (
    <a href={l.href} class="drawer-link">{l.label}</a>
  ))}
  <a href="/contact" class="drawer-enquire">Enquire &rarr;</a>
</div>

<style>
  /* ── NAV BASE ── */
  #nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 200;
    height: 64px;
    padding: 0 var(--pad-x, 5vw);
    display: flex;
    align-items: center;
    background: transparent;
    transition: background 0.35s, border-color 0.35s;
    border-bottom: 1px solid transparent;
  }
  #nav.scrolled {
    background: rgba(244,243,239,0.97);
    border-bottom-color: rgba(17,17,17,0.07);
    backdrop-filter: blur(10px);
  }
  #nav.home-nav:not(.scrolled) {
    background: transparent;
    border-bottom-color: transparent;
  }
  #nav.home-nav:not(.scrolled) .nav-logo,
  #nav.home-nav:not(.scrolled) .nav-link { color: rgba(244,243,239,0.92); }
  #nav.home-nav:not(.scrolled) .nav-enquire {
    color: rgba(244,243,239,0.9);
    border-color: rgba(244,243,239,0.3);
    background: transparent;
  }

  /* ── LOGO ── */
  .nav-logo {
    font-family: "Plus Jakarta Sans", system-ui, sans-serif;
    font-size: 0.75rem; font-weight: 700;
    letter-spacing: 0.15em; text-transform: uppercase;
    color: var(--ink, #111);
    text-decoration: none; margin-right: auto;
    white-space: nowrap; transition: color 0.25s;
  }
  .nav-logo em { font-style: normal; color: var(--navy, #1A3A6B); }

  /* ── DESKTOP LINKS ── */
  .nav-links { display: flex; gap: 2.5rem; margin-right: 2.5rem; }
  .nav-link {
    font-family: "Plus Jakarta Sans", system-ui, sans-serif;
    font-size: 0.7rem; font-weight: 500;
    letter-spacing: 0.06em; text-transform: uppercase;
    color: var(--ink-light, #777);
    text-decoration: none; position: relative;
    padding-bottom: 2px; transition: color 0.2s;
  }
  .nav-link::after {
    content: ""; position: absolute;
    bottom: -1px; left: 0; right: 0; height: 1px;
    background: var(--ink, #111);
    transform: scaleX(0); transform-origin: right;
    transition: transform 0.3s cubic-bezier(0.4,0,0.2,1);
  }
  .nav-link:hover { color: var(--ink, #111); }
  .nav-link:hover::after,
  .nav-link.active::after { transform: scaleX(1); transform-origin: left; }
  .nav-link.active { color: var(--ink, #111); }

  /* ── RIGHT ── */
  .nav-right { display: flex; align-items: center; gap: 1rem; }

  .nav-enquire {
    font-family: "Plus Jakarta Sans", system-ui, sans-serif;
    font-size: 0.65rem; font-weight: 600;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: #fff; background: var(--navy, #1A3A6B);
    text-decoration: none; padding: 0.6rem 1.35rem;
    transition: background 0.2s; white-space: nowrap;
  }
  .nav-enquire:hover { background: var(--navy-mid, #254E8F); }

  /* ── HAMBURGER — always rendered, shown/hidden via CSS only ── */
  .nav-burger {
    width: 44px; height: 44px;
    display: flex !important;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px;
    background: none; border: none;
    cursor: pointer; padding: 0;
    flex-shrink: 0;
  }
  .nav-burger span {
    display: block;
    width: 24px; height: 2px;
    background: var(--ink, #111);
    border-radius: 1px;
    transition: transform 0.3s cubic-bezier(0.4,0,0.2,1), opacity 0.2s;
    pointer-events: none;
  }
  /* White on transparent homepage */
  #nav.home-nav:not(.scrolled) .nav-burger span {
    background: #ffffff;
  }
  /* X state */
  .nav-burger[aria-expanded="true"] span:nth-child(1) {
    transform: translateY(8px) rotate(45deg);
  }
  .nav-burger[aria-expanded="true"] span:nth-child(2) {
    transform: translateY(-8px) rotate(-45deg);
  }

  /* Desktop: hide burger, show links */
  @media (min-width: 900px) {
    .nav-burger { display: none !important; }
    .nav-links { display: flex; }
    .nav-enquire { display: inline-flex; }
  }

  /* Mobile: hide links, show burger */
  @media (max-width: 899px) {
    .nav-links { display: none; }
    .nav-enquire { display: none; }
  }

  /* ── DRAWER ── */
  .nav-drawer {
    position: fixed;
    top: 64px; left: 0; right: 0;
    z-index: 190;
    background: var(--bg, #F4F3EF);
    max-height: 0; overflow: hidden;
    transition: max-height 0.4s cubic-bezier(0.4,0,0.2,1);
    border-bottom: 1px solid rgba(17,17,17,0.06);
  }
  .nav-drawer.open { max-height: 320px; }

  .drawer-link {
    display: block;
    font-family: "Plus Jakarta Sans", system-ui, sans-serif;
    font-size: 1.6rem; font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--ink, #111); text-decoration: none;
    padding: 0.75rem var(--pad-x, 5vw);
    border-bottom: 1px solid rgba(17,17,17,0.05);
    transition: color 0.2s, padding-left 0.25s;
  }
  .drawer-link:hover {
    color: var(--navy, #1A3A6B);
    padding-left: calc(var(--pad-x, 5vw) + 0.75rem);
  }

  .drawer-enquire {
    display: block;
    font-family: "Plus Jakarta Sans", system-ui, sans-serif;
    font-size: 0.65rem; font-weight: 600;
    letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--ink-light, #777); text-decoration: none;
    padding: 1.25rem var(--pad-x, 5vw) 2rem;
    transition: color 0.2s;
  }
  .drawer-enquire:hover { color: var(--ink, #111); }
</style>

<script>
  const nav    = document.getElementById("nav");
  const burger = document.getElementById("nav-burger");
  const drawer = document.getElementById("nav-drawer");

  if (document.body.classList.contains("page-home")) {
    nav?.classList.add("home-nav");
  } else {
    nav?.classList.add("scrolled");
  }

  window.addEventListener("scroll", () => {
    nav?.classList.toggle("scrolled", window.scrollY > 20);
  }, { passive: true });

  burger?.addEventListener("click", () => {
    const open = drawer?.classList.toggle("open");
    burger.setAttribute("aria-expanded", String(open));
    drawer?.setAttribute("aria-hidden", String(!open));
  });

  drawer?.querySelectorAll("a").forEach(a => {
    a.addEventListener("click", () => {
      drawer?.classList.remove("open");
      burger?.setAttribute("aria-expanded", "false");
      drawer?.setAttribute("aria-hidden", "true");
    });
  });
</script>
