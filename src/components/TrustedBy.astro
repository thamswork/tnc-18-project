---
let logos: any[] = [];
let sectionLabel = "Trusted By";
try {
  const { getCollection } = await import("astro:content");
  const raw = await getCollection("trusted_by" as any);
  logos = (raw || [])
    .map((e: any) => e.data)
    .filter((l: any) => l.logo && l.logo.trim() !== "")
    .sort((a: any, b: any) => (a.order || 99) - (b.order || 99));
} catch(e) { logos = []; }
try {
  const fs = await import("fs");
  const path = await import("path");
  const settingsPath = path.join(process.cwd(), "src/content/trusted-by/settings.json");
  if (fs.existsSync(settingsPath)) {
    const settings = JSON.parse(fs.readFileSync(settingsPath, "utf-8"));
    if (settings.section_label) sectionLabel = settings.section_label;
  }
} catch(e) {}
---

<section class="trusted-by">
  <p class="tb-label">{sectionLabel}</p>
  <div class="tb-track">
    {logos.map((l: any) => (
      l.url
        ? <a href={l.url} target="_blank" rel="noopener noreferrer" class="tb-item">
            <img src={l.logo} alt={l.name} class="tb-logo" loading="lazy" />
          </a>
        : <div class="tb-item">
            <img src={l.logo} alt={l.name} class="tb-logo" loading="lazy" />
          </div>
    ))}
  </div>
</section>

<style>
  .trusted-by {
    background: var(--bg-dark, #ECEAE3);
    padding: 2rem var(--pad-x, 5vw);
    border-bottom: 0.5px solid rgba(17,17,17,0.06);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    overflow: hidden;
  }
  .tb-label {
    font-size: 0.52rem;
    font-weight: 600;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: rgba(17,17,17,0.3);
  }
  .tb-track {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 1.75rem 3rem;
    width: 100%;
    max-width: 1300px;
  }
  @media (min-width: 1024px) {
    .tb-track {
      flex-wrap: nowrap;
      justify-content: space-between;
      gap: 1.5rem;
    }
  }
  .tb-item {
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    flex-shrink: 0;
  }
  .tb-logo {
    height: 36px;
    width: auto;
    max-width: 130px;
    display: block;
    object-fit: contain;
    opacity: 1;
    filter: none;
  }
  @media (max-width: 768px) {
    .tb-track {
      gap: 1.25rem 2rem;
    }
    .tb-logo {
      height: 28px;
      max-width: 100px;
    }
  }
</style>
