---
interface Image {
  src: string;
  alt?: string;
  layout_style?: 'portrait' | 'landscape' | 'square';
}
interface Props {
  images: Image[];
  caption?: string;
}
const { images, caption } = Astro.props;
const count = images.length;
---
<figure class={`sb-grid sb-grid--${count}`} data-reveal>
  {images.map(img => (
    <div class={`sb-grid-item sb-grid-item--${img.layout_style || 'landscape'}`}>
      <img src={img.src} alt={img.alt || ''} loading="lazy" class="sb-grid-img" />
    </div>
  ))}
  {caption && <figcaption class="sb-grid-cap">{caption}</figcaption>}
</figure>

<style>
  .sb-grid {
    display: grid;
    gap: 3px;
    padding: 0 var(--pad-x, 5vw);
    margin: 0;
    width: 100%;
  }

  .sb-grid--1 { grid-template-columns: 1fr; }
  .sb-grid--2 { grid-template-columns: 1fr 1fr; }
  .sb-grid--3 { grid-template-columns: 1fr 1fr 1fr; }

  .sb-grid-item { overflow: hidden; }

  .sb-grid-item--landscape .sb-grid-img { aspect-ratio: 16/9; }
  .sb-grid-item--portrait  .sb-grid-img { aspect-ratio: 3/4; }
  .sb-grid-item--square    .sb-grid-img { aspect-ratio: 1/1; }

  .sb-grid-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 1.2s cubic-bezier(0.4,0,0.2,1);
  }
  .sb-grid-item:hover .sb-grid-img { transform: scale(1.03); }

  .sb-grid-cap {
    grid-column: 1 / -1;
    font-family: 'Courier New', monospace;
    font-size: 0.52rem;
    letter-spacing: 0.16em;
    color: var(--ink-light, #6B6B6B);
    padding-top: 0.65rem;
    text-transform: uppercase;
  }

  @media (max-width: 640px) {
    .sb-grid--3 { grid-template-columns: 1fr 1fr; }
  }

  @media (min-width: 768px) {
    .sb-grid { padding: 0 8%; }
  }
</style>
