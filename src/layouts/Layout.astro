---
export interface Props {
  title: string;
  description?: string;
  bodyClass?: string;
}
const { title, description = 'TNC.18 — Retail & Interior Design, Bangkok Thailand', bodyClass } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta property="og:title" content={`${title} — TNC.18`} />
    <meta property="og:description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Tenor+Sans&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <title>{title} — TNC.18</title>
      <link rel="stylesheet" href="/src/styles/premium-preview.css" />
  </head>
  <body class={`${Astro.url.pathname === "/" ? "page-home" : "page-inner"}${bodyClass ? " " + bodyClass : ""}`}>
    <slot />
    <script>
      const saved = localStorage.getItem('tnc-lang') || 'en';
      document.documentElement.setAttribute('data-lang', saved);
    </script>
    <script src="/premium-preview.js" is:inline></script>
  </body>
</html>

<style is:global>
  :root {
    /* ── Core palette ── */
    --bg:           #F8F7F4;
    --bg-dark:      #EFEDE8;
    --ink:          #1A1A1A;
    --ink-mid:      #3D3D3D;
    --ink-light:    #6B6B6B;
    --navy:         #1A3A6B;
    --navy-mid:     #254E8F;
    --navy-deep:    #0E2140;
    --line-green:   #06C755;

    /* ── Legacy aliases (keeps old pages from breaking) ── */
    --cream:        #F8F7F4;
    --cream-mid:    #EFEDE8;
    --cream-dark:   #D8D5CE;
    --warm-white:   #FFFFFF;
    --charcoal:     #1A1A1A;
    --charcoal-mid: #3D3D3D;
    --muted:        #6B6B6B;
    --gold:         #1A3A6B;
    --gold-light:   #254E8F;
    --blue:         #1A3A6B;
    --blue-mid:     #254E8F;
    --blue-pale:    #EDF2FA;
    --stone:        #F8F7F4;
    --stone-mid:    #EFEDE8;
    --stone-dark:   #D8D5CE;

    /* ── Typography ── */
    --font-display: 'Tenor Sans', Georgia, serif;
    --font-body:    'Inter', system-ui, sans-serif;
    --font-mono:    'Courier New', Courier, monospace;
    --font-sans:    'Inter', system-ui, sans-serif;
    --font-serif:   'Tenor Sans', Georgia, serif;

    /* ── Spacing ── */
    --pad-x:   5vw;
    --section: 10rem;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html {
    background: var(--bg);
    color: var(--ink);
    scroll-behavior: smooth;
    -webkit-text-size-adjust: 100%;
  }

  body {
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 400;
    line-height: 1.7;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    overflow-x: hidden;
    background: var(--bg);
    color: var(--ink);
  }

  h1, h2, h3, h4 {
    font-family: var(--font-display);
    font-weight: 400;
    line-height: 1.05;
    color: var(--ink);
  }

  p { line-height: 1.8; color: var(--ink-mid); }
  a { color: inherit; }
  img, video { display: block; width: 100%; }

  ::selection        { background: var(--navy); color: #fff; }
  ::-webkit-scrollbar       { width: 2px; }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: var(--navy); }

  /* ── Global reveal ── */
  [data-reveal] {
    opacity: 0;
    transform: translateY(32px);
    transition:
      opacity  0.9s cubic-bezier(0.16,1,0.3,1),
      transform 0.9s cubic-bezier(0.16,1,0.3,1);
  }
  [data-reveal].revealed { opacity: 1; transform: none; }
  [data-reveal][data-delay="1"] { transition-delay: 0.12s; }
  [data-reveal][data-delay="2"] { transition-delay: 0.24s; }
  [data-reveal][data-delay="3"] { transition-delay: 0.36s; }

  /* ── Shared section label ── */
  .s-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 400;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--ink-light);
    display: block;
  }

  /* ── Shared footer ── */
  .site-footer {
    background: var(--navy-deep);
    padding: 4rem var(--pad-x) 3rem;
    border-top: 0.5px solid rgba(255,255,255,0.06);
  }
  .site-footer-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }
  /* Brand col */
  .site-footer-brand {}
  .site-footer-logo {
    font-family: var(--font-body);
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    color: rgba(255,255,255,0.55);
    display: block;
    margin-bottom: 0.5rem;
    text-transform: uppercase;
  }
  .site-footer-logo em { font-style: normal; color: #fff; }
  .site-footer-sub {
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 300;
    letter-spacing: 0.04em;
    color: rgba(255,255,255,0.35);
    line-height: 1.6;
  }
  /* Nav col */
  .site-footer-nav {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }
  .site-footer-nav a {
    font-family: var(--font-body);
    font-size: 0.82rem;
    font-weight: 400;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.45);
    text-decoration: none;
    transition: color 0.2s;
    white-space: nowrap;
  }
  .site-footer-nav a:hover { color: #fff; }
  /* Legal col */
  .site-footer-legal {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .site-footer-copy {
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 300;
    color: rgba(255,255,255,0.25);
    letter-spacing: 0.04em;
    line-height: 1.6;
  }
  @media (min-width: 768px) {
    .site-footer-inner {
      grid-template-columns: 1.5fr 1fr 1fr;
      align-items: start;
      gap: 4rem;
    }
    .site-footer-nav {
      flex-direction: column;
    }
  }

  /* ── Shared Line button ── */
  .btn-line {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--ink);
    background: var(--line-green);
    padding: 0.9rem 1.8rem;
    transition: background 0.25s, transform 0.15s;
    white-space: nowrap;
  }
  .btn-line:hover { background: var(--navy, #1A3A6B); color: #F8F7F4; }
  .btn-line:active { transform: scale(0.98); }

  .line-dot {
    display: block;
    width: 7px; height: 7px;
    border-radius: 50%;
    background: #fff;
    flex-shrink: 0;
  }

  /* ── Shared navy ghost button ── */
  .btn-ghost {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-body);
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--navy);
    background: transparent;
    padding: 0.85rem 1.75rem;
    border: 1px solid var(--navy);
    transition: background 0.25s, color 0.25s;
    white-space: nowrap;
  }
  .btn-ghost:hover { background: var(--navy); color: #fff; }

  @media (min-width: 768px) {
    :root { --pad-x: 8%; --section: 12rem; }
  }
  @media (min-width: 1200px) {
    :root { --pad-x: 10%; }
  }
</style>
