---
export interface Props {
  title: string;
  description?: string;
  bodyClass?: string;
}
const { title, description = 'TNC BUILD STUDIO — Retail & Interior Design, Bangkok Thailand', bodyClass } = Astro.props;
---
<!doctype html>
<html lang="th">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- ── PRIMARY SEO ── -->
    <title>{title} — TNC Build Studio</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <link rel="canonical" href={`https://tncbuildstudio.com${Astro.url.pathname}`} />

    <!-- ── HREFLANG TH/EN ── -->
    <link rel="alternate" hreflang="th" href={`https://tncbuildstudio.com${Astro.url.pathname}`} />
    <link rel="alternate" hreflang="en" href={`https://tncbuildstudio.com${Astro.url.pathname}`} />
    <link rel="alternate" hreflang="x-default" href={`https://tncbuildstudio.com${Astro.url.pathname}`} />

    <!-- ── KEYWORDS TH + EN + misspellings ── -->
    <meta name="keywords" content="ทำบูธขายของในห้าง, ทำบูท, บูธขายของ, บูทขายของ, ออกแบบบูธ, รับทำบูธ, Pop-up Store, ป็อปอัพสโตร์, ป๊อปอัพสโตร์, popupstore, ทำร้านค้าในห้าง, ตกแต่งร้านค้า, ตกแต่งภายใน, ออกแบบตกแต่งภายใน, รับเหมาตกแต่งภายใน, คีออสก์, kiosk, ทำบูธสยามพารากอน, ทำบูธเซ็นทรัล, ทำบูธไอคอนสยาม, ทำบูธเอ็มควอเทียร์, ทำบูธเกษรวิลเลจ, ทำบูธเมกาบางนา, retail design bangkok, interior design bangkok, shop design thailand, booth design bangkok, TNC Build Studio, TNC18, บริษัทออกแบบตกแต่งภายใน, บริษัทรับเหมาตกแต่งร้าน, ผู้รับเหมาตกแต่งร้านค้า, ออกแบบพื้นที่เชิงพาณิชย์, commercial interior design bangkok, retail fit-out bangkok, shop fitting bangkok, mall booth contractor bangkok, pop up store contractor thailand, exhibition booth bangkok, งานนิทรรศการ, บูธงานแฟร์, ออกแบบบูธนิทรรศการ, stand design bangkok, display booth bangkok, brand activation bangkok, brand activation thailand, experiential retail bangkok, ทำบูธแบรนด์, ออกแบบ brand activation, ร้านค้าชั่วคราว, ร้านค้าสำเร็จรูป, modular booth thailand, portable booth bangkok, custom booth design thailand" />

    <!-- ── OPEN GRAPH ── -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`https://tncbuildstudio.com${Astro.url.pathname}`} />
    <meta property="og:title" content={`${title} — TNC Build Studio`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://tncbuildstudio.com/images/og-image.jpg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="TNC Build Studio" />
    <meta property="og:locale" content="th_TH" />
    <meta property="og:locale:alternate" content="en_US" />

    <!-- ── TWITTER CARD ── -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} — TNC Build Studio`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://tncbuildstudio.com/images/og-image.jpg" />

    <!-- ── GEO TARGETING ── -->
    <meta name="geo.region" content="TH-10" />
    <meta name="geo.placename" content="Bangkok, Thailand" />
    <meta name="geo.position" content="13.7563;100.5018" />
    <meta name="ICBM" content="13.7563, 100.5018" />

    <!-- ── LOCAL BUSINESS STRUCTURED DATA ── -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "LocalBusiness",
          "@id": "https://tncbuildstudio.com/#business",
          "name": "TNC Build Studio",
          "alternateName": ["TNC.18", "TNC18", "TNC Build Studio Bangkok"],
          "description": "รับออกแบบและสร้างบูธขายของในห้าง Pop-up Store ร้านค้า ตกแต่งภายใน กรุงเทพมหานคร | Retail & Interior Design firm in Bangkok Thailand",
          "url": "https://tncbuildstudio.com",
          "logo": "https://tncbuildstudio.com/favicon.svg",
          "telephone": "+6620000000",
          "email": "hello@tnc18.com",
          "address": {
            "@type": "PostalAddress",
            "addressLocality": "Bangkok",
            "addressRegion": "Bangkok",
            "addressCountry": "TH"
          },
          "geo": {
            "@type": "GeoCoordinates",
            "latitude": 13.7563,
            "longitude": 100.5018
          },
          "areaServed": ["Bangkok", "Thailand", "กรุงเทพมหานคร", "ประเทศไทย"],
          "serviceType": [
            "Retail Design", "Interior Design", "Pop-up Store", "Booth Design", "Kiosk Design",
            "ออกแบบบูธ", "ทำบูธขายของในห้าง", "ตกแต่งภายใน", "ออกแบบร้านค้า", "คีออสก์"
          ],
          "sameAs": [
            "https://www.facebook.com/profile.php?id=61579055983582",
            "https://www.instagram.com/tncbuildstudio"
          ],
          "priceRange": "฿฿฿",
          "openingHours": "Mo-Su 09:00-18:00"
        },
        {
          "@type": "WebSite",
          "@id": "https://tncbuildstudio.com/#website",
          "url": "https://tncbuildstudio.com",
          "name": "TNC Build Studio",
          "description": "รับทำบูธขายของในห้าง Pop-up Store ออกแบบตกแต่งภายใน กรุงเทพ",
          "inLanguage": ["th", "en"]
        },
        {
          "@type": "FAQPage",
          "mainEntity": [
            {
              "@type": "Question",
              "name": "รับทำบูธขายของในห้างราคาเท่าไหร่?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "ราคาขึ้นอยู่กับขนาดและความซับซ้อนของงาน TNC Build Studio รับออกแบบและสร้างบูธขายของในห้างทุกประเภท ติดต่อเราเพื่อรับใบเสนอราคา"
              }
            },
            {
              "@type": "Question",
              "name": "ทำบูธขายของในห้างใช้เวลานานแค่ไหน?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "TNC Build Studio เชี่ยวชาญด้าน Fast Delivery สามารถส่งมอบงานได้ภายในระยะเวลาที่กำหนด ตั้งแต่ออกแบบจนถึงติดตั้งแล้วเสร็จ"
              }
            },
            {
              "@type": "Question",
              "name": "รับทำ Pop-up Store ในห้างสรรพสินค้าไหนบ้าง?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "TNC Build Studio รับทำบูธและ Pop-up Store ในห้างสรรพสินค้าชั้นนำทั่วกรุงเทพ ได้แก่ สยามพารากอน เซ็นทรัลเวิลด์ ไอคอนสยาม เอ็มควอเทียร์ เกษรวิลเลจ และเมกาบางนา"
              }
            },
            {
              "@type": "Question",
              "name": "TNC Build Studio รับงานตกแต่งภายในร้านค้าด้วยไหม?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "ใช่ TNC Build Studio รับออกแบบและตกแต่งภายในร้านค้า บูธ Pop-up Store และพื้นที่เชิงพาณิชย์ทุกประเภท โดยทีมงานซีเนียร์โดยตรง"
              }
            },
            {
              "@type": "Question",
              "name": "What is TNC Build Studio?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "TNC Build Studio is a Bangkok-based senior-led retail design and construction firm specializing in booth design, Pop-up Stores, kiosks, and interior design for malls and retail spaces across Thailand."
              }
            }
          ]
        },
        {
          "@type": "BreadcrumbList",
          "itemListElement": [
            {
              "@type": "ListItem",
              "position": 1,
              "name": "Home",
              "item": "https://tncbuildstudio.com"
            },
            {
              "@type": "ListItem",
              "position": 2,
              "name": "Portfolio",
              "item": "https://tncbuildstudio.com/portfolio"
            },
            {
              "@type": "ListItem",
              "position": 3,
              "name": "Services",
              "item": "https://tncbuildstudio.com/about-services"
            },
            {
              "@type": "ListItem",
              "position": 4,
              "name": "Contact",
              "item": "https://tncbuildstudio.com/contact"
            }
          ]
        }
      ]
    })}></script>

    <!-- ── FAVICON ── -->
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />

    <!-- ── FONTS ── -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,300;1,400&family=Noto+Sans+Thai:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />

    <!-- ── GOOGLE ANALYTICS (add GA_ID in CMS siteinfo) ── -->
    <!-- Replace G-XXXXXXXXXX with your actual GA4 ID -->
    <!-- <script async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX"></script> -->
    <!-- <script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments)}gtag("js",new Date());gtag("config","G-XXXXXXXXXX");</script> -->

    <!-- ── GOOGLE SEARCH CONSOLE VERIFICATION ── -->
    <!-- Add your verification meta tag here once you get it from Search Console -->
    <!-- <meta name="google-site-verification" content="YOUR_CODE_HERE" /> -->

    <slot name="head" />
    <link rel="stylesheet" href="/src/styles/premium-preview.css" />
  </head>
  <body class={`${Astro.url.pathname === "/" ? "page-home" : "page-inner"}${bodyClass ? " " + bodyClass : ""}`}>
    <slot />
    <script>
      const saved = localStorage.getItem('tnc-lang') || 'en';
      document.documentElement.setAttribute('data-lang', saved);
    </script>
    <script src="/premium-preview.js" is:inline></script>
  </body>
</html>

<style is:global>
  :root {
    --bg:           #F5F4F0;
    --bg-dark:      #ECEAE4;
    --bg-ink:       #0D0D0D;
    --ink:          #0D0D0D;
    --ink-mid:      #2A2A2A;
    --ink-light:    #767676;
    --ink-ghost:    #ABABAB;
    --navy:         #1A3A6B;
    --navy-mid:     #254E8F;
    --navy-deep:    #0E2140;
    --line-green:   #06C755;

    --cream:        #F5F4F0;
    --cream-mid:    #ECEAE4;
    --cream-dark:   #D6D3CB;
    --warm-white:   #FFFFFF;
    --charcoal:     #0D0D0D;
    --charcoal-mid: #2A2A2A;
    --muted:        #767676;
    --gold:         #1A3A6B;
    --gold-light:   #254E8F;
    --blue:         #1A3A6B;
    --blue-mid:     #254E8F;
    --blue-pale:    #EDF2FA;
    --stone:        #F5F4F0;
    --stone-mid:    #ECEAE4;
    --stone-dark:   #D6D3CB;

    --font-display: "Plus Jakarta Sans", system-ui, sans-serif;
    --font-body:    "Plus Jakarta Sans", system-ui, sans-serif;
    --font-mono:    "Plus Jakarta Sans", system-ui, sans-serif;
    --font-sans:    "Plus Jakarta Sans", system-ui, sans-serif;
    --font-serif:   "Plus Jakarta Sans", system-ui, sans-serif;

    --pad-x:   5vw;
    --section: 9rem;
    --ease-out: cubic-bezier(0.16, 1, 0.3, 1);
    --ease-in-out: cubic-bezier(0.4, 0, 0.2, 1);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html {
    background: var(--bg);
    color: var(--ink);
    scroll-behavior: smooth;
    -webkit-text-size-adjust: 100%;
    font-size: 16px;
  }

  body {
    font-family: "Plus Jakarta Sans", system-ui, sans-serif;
    font-size: 0.9375rem;
    font-weight: 300;
    line-height: 1.65;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    overflow-x: hidden;
    background: var(--bg);
    color: var(--ink);
    letter-spacing: -0.01em;
  }

  h1 {
    font-family: "Plus Jakarta Sans", system-ui, sans-serif;
    font-weight: 400;
    line-height: 1.0;
    color: var(--ink);
    letter-spacing: -0.02em;
  }
  h2 {
    font-family: "Plus Jakarta Sans", system-ui, sans-serif;
    font-weight: 400;
    line-height: 1.05;
    color: var(--ink);
    letter-spacing: -0.015em;
  }
  h3, h4 {
    font-family: "Plus Jakarta Sans", system-ui, sans-serif;
    font-weight: 500;
    line-height: 1.2;
    color: var(--ink);
    letter-spacing: -0.01em;
  }

  p { line-height: 1.75; color: var(--ink-mid); font-weight: 300; }
  a { color: inherit; text-decoration: none; }
  img, video { display: block; width: 100%; }

  ::selection { background: var(--ink); color: var(--bg); }
  ::-webkit-scrollbar       { width: 1px; }

  /* Force solid navbar on project/slug pages */
  body.page-solid-nav #nav {
    background: rgba(244,243,239,0.98) !important;
    border-bottom: 1px solid rgba(17,17,17,0.08) !important;
    backdrop-filter: blur(12px) !important;
  }
  body.page-solid-nav #nav .nav-logo,
  body.page-solid-nav #nav .nav-link {
    color: var(--ink, #111) !important;
  }
  body.page-solid-nav #nav .nav-burger span {
    background: var(--ink, #111) !important;
  }
  body.page-solid-nav #nav .nav-enquire {
    color: #fff !important;
    background: var(--navy, #1A3A6B) !important;
    border-color: var(--navy, #1A3A6B) !important;
  }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: var(--ink); }

  [data-reveal] {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.85s cubic-bezier(0.16,1,0.3,1), transform 0.85s cubic-bezier(0.16,1,0.3,1);
  }
  [data-reveal].revealed { opacity: 1; transform: none; }
  [data-reveal][data-delay="1"] { transition-delay: 0.1s; }
  [data-reveal][data-delay="2"] { transition-delay: 0.2s; }
  [data-reveal][data-delay="3"] { transition-delay: 0.3s; }

  .s-label {
    font-family: "Plus Jakarta Sans", system-ui, sans-serif;
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-light);
    display: block;
  }

  /* ── SHARED PAGE HEADER — used across all pages ── */
  .page-hero-std {
    padding: 5rem var(--pad-x) 2.5rem;
    border-bottom: 1px solid rgba(17,17,17,0.07);
    background: var(--bg, #F4F3EF);
  }
  .page-eyebrow-std {
    font-size: 0.55rem !important;
    font-weight: 600 !important;
    letter-spacing: 0.26em !important;
    text-transform: uppercase !important;
    color: var(--navy, #1A3A6B) !important;
    display: block !important;
    margin-bottom: 0.75rem !important;
  }
  .page-title-std {
    font-size: clamp(2rem, 6vw, 4rem) !important;
    font-weight: 800 !important;
    letter-spacing: -0.04em !important;
    line-height: 0.92 !important;
    color: var(--ink, #111) !important;
    text-transform: uppercase !important;
  }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: "Plus Jakarta Sans", system-ui, sans-serif;
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--ink);
    background: transparent;
    padding: 0.85rem 1.75rem;
    border: 0.5px solid var(--ink);
    transition: background 0.25s, color 0.25s;
    white-space: nowrap;
  }
  .btn-ghost:hover { background: var(--ink); color: var(--bg); }

  .btn-line {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: "Plus Jakarta Sans", system-ui, sans-serif;
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--ink);
    background: var(--line-green);
    padding: 0.9rem 1.8rem;
    transition: background 0.25s, transform 0.15s;
    white-space: nowrap;
  }
  .btn-line:hover { background: var(--ink); color: var(--bg); }
  .btn-line:active { transform: scale(0.98); }

  .line-dot {
    display: block;
    width: 6px; height: 6px;
    border-radius: 50%;
    background: #fff;
    flex-shrink: 0;
  }

  .site-footer {
    background: #0D0D0D;
    padding: 4rem var(--pad-x) 3rem;
  }

  @media (min-width: 768px) {
    :root { --pad-x: 8%; --section: 11rem; }
  }
  @media (min-width: 1200px) {
    :root { --pad-x: 10%; }
  }
  @media (min-width: 1600px) {
    :root { --pad-x: 12%; }
  }
</style>
