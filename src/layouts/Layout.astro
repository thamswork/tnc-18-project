---
export interface Props {
  title: string;
  description?: string;
  bodyClass?: string;
}
const { title, description = 'TNC BUILD STUDIO — Retail & Interior Design, Bangkok Thailand', bodyClass } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta property="og:title" content={`${title} — TNC BUILD STUDIO`} />
    <meta property="og:description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,300;1,400&display=swap" rel="stylesheet" />
    <title>{title} — TNC BUILD STUDIO</title>
    <slot name="head" />
    <link rel="stylesheet" href="/src/styles/premium-preview.css" />
  </head>
  <body class={`${Astro.url.pathname === "/" ? "page-home" : "page-inner"}${bodyClass ? " " + bodyClass : ""}`}>
    <slot />
    <script>
      const saved = localStorage.getItem('tnc-lang') || 'en';
      document.documentElement.setAttribute('data-lang', saved);
    </script>
    <script src="/premium-preview.js" is:inline></script>
  </body>
</html>

<style is:global>
  :root {
    --bg:           #F5F4F0;
    --bg-dark:      #ECEAE4;
    --bg-ink:       #0D0D0D;
    --ink:          #0D0D0D;
    --ink-mid:      #2A2A2A;
    --ink-light:    #767676;
    --ink-ghost:    #ABABAB;
    --navy:         #1A3A6B;
    --navy-mid:     #254E8F;
    --navy-deep:    #0E2140;
    --line-green:   #06C755;

    --cream:        #F5F4F0;
    --cream-mid:    #ECEAE4;
    --cream-dark:   #D6D3CB;
    --warm-white:   #FFFFFF;
    --charcoal:     #0D0D0D;
    --charcoal-mid: #2A2A2A;
    --muted:        #767676;
    --gold:         #1A3A6B;
    --gold-light:   #254E8F;
    --blue:         #1A3A6B;
    --blue-mid:     #254E8F;
    --blue-pale:    #EDF2FA;
    --stone:        #F5F4F0;
    --stone-mid:    #ECEAE4;
    --stone-dark:   #D6D3CB;

    --font-display: "Plus Jakarta Sans", system-ui, sans-serif;
    --font-body:    "Plus Jakarta Sans", system-ui, sans-serif;
    --font-mono:    "Plus Jakarta Sans", system-ui, sans-serif;
    --font-sans:    "Plus Jakarta Sans", system-ui, sans-serif;
    --font-serif:   "Plus Jakarta Sans", system-ui, sans-serif;

    --pad-x:   5vw;
    --section: 9rem;
    --ease-out: cubic-bezier(0.16, 1, 0.3, 1);
    --ease-in-out: cubic-bezier(0.4, 0, 0.2, 1);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html {
    background: var(--bg);
    color: var(--ink);
    scroll-behavior: smooth;
    -webkit-text-size-adjust: 100%;
    font-size: 16px;
  }

  body {
    font-family: "Plus Jakarta Sans", system-ui, sans-serif;
    font-size: 0.9375rem;
    font-weight: 300;
    line-height: 1.65;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    overflow-x: hidden;
    background: var(--bg);
    color: var(--ink);
    letter-spacing: -0.01em;
  }

  h1 {
    font-family: "Plus Jakarta Sans", system-ui, sans-serif;
    font-weight: 400;
    line-height: 1.0;
    color: var(--ink);
    letter-spacing: -0.02em;
  }
  h2 {
    font-family: "Plus Jakarta Sans", system-ui, sans-serif;
    font-weight: 400;
    line-height: 1.05;
    color: var(--ink);
    letter-spacing: -0.015em;
  }
  h3, h4 {
    font-family: "Plus Jakarta Sans", system-ui, sans-serif;
    font-weight: 500;
    line-height: 1.2;
    color: var(--ink);
    letter-spacing: -0.01em;
  }

  p { line-height: 1.75; color: var(--ink-mid); font-weight: 300; }
  a { color: inherit; text-decoration: none; }
  img, video { display: block; width: 100%; }

  ::selection { background: var(--ink); color: var(--bg); }
  ::-webkit-scrollbar       { width: 1px; }

  /* Force solid navbar on project/slug pages */
  body.page-solid-nav #nav {
    background: rgba(244,243,239,0.98) !important;
    border-bottom: 1px solid rgba(17,17,17,0.08) !important;
    backdrop-filter: blur(12px) !important;
  }
  body.page-solid-nav #nav .nav-logo,
  body.page-solid-nav #nav .nav-link {
    color: var(--ink, #111) !important;
  }
  body.page-solid-nav #nav .nav-burger span {
    background: var(--ink, #111) !important;
  }
  body.page-solid-nav #nav .nav-enquire {
    color: #fff !important;
    background: var(--navy, #1A3A6B) !important;
    border-color: var(--navy, #1A3A6B) !important;
  }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: var(--ink); }

  [data-reveal] {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.85s cubic-bezier(0.16,1,0.3,1), transform 0.85s cubic-bezier(0.16,1,0.3,1);
  }
  [data-reveal].revealed { opacity: 1; transform: none; }
  [data-reveal][data-delay="1"] { transition-delay: 0.1s; }
  [data-reveal][data-delay="2"] { transition-delay: 0.2s; }
  [data-reveal][data-delay="3"] { transition-delay: 0.3s; }

  .s-label {
    font-family: "Plus Jakarta Sans", system-ui, sans-serif;
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-light);
    display: block;
  }

  /* ── SHARED PAGE HEADER — used across all pages ── */
  .page-hero-std {
    padding: 5rem var(--pad-x) 2.5rem;
    border-bottom: 1px solid rgba(17,17,17,0.07);
    background: var(--bg, #F4F3EF);
  }
  .page-eyebrow-std {
    font-size: 0.55rem !important;
    font-weight: 600 !important;
    letter-spacing: 0.26em !important;
    text-transform: uppercase !important;
    color: var(--navy, #1A3A6B) !important;
    display: block !important;
    margin-bottom: 0.75rem !important;
  }
  .page-title-std {
    font-size: clamp(2rem, 6vw, 4rem) !important;
    font-weight: 800 !important;
    letter-spacing: -0.04em !important;
    line-height: 0.92 !important;
    color: var(--ink, #111) !important;
    text-transform: uppercase !important;
  }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: "Plus Jakarta Sans", system-ui, sans-serif;
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--ink);
    background: transparent;
    padding: 0.85rem 1.75rem;
    border: 0.5px solid var(--ink);
    transition: background 0.25s, color 0.25s;
    white-space: nowrap;
  }
  .btn-ghost:hover { background: var(--ink); color: var(--bg); }

  .btn-line {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: "Plus Jakarta Sans", system-ui, sans-serif;
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--ink);
    background: var(--line-green);
    padding: 0.9rem 1.8rem;
    transition: background 0.25s, transform 0.15s;
    white-space: nowrap;
  }
  .btn-line:hover { background: var(--ink); color: var(--bg); }
  .btn-line:active { transform: scale(0.98); }

  .line-dot {
    display: block;
    width: 6px; height: 6px;
    border-radius: 50%;
    background: #fff;
    flex-shrink: 0;
  }

  .site-footer {
    background: #0D0D0D;
    padding: 4rem var(--pad-x) 3rem;
  }

  @media (min-width: 768px) {
    :root { --pad-x: 8%; --section: 11rem; }
  }
  @media (min-width: 1200px) {
    :root { --pad-x: 10%; }
  }
  @media (min-width: 1600px) {
    :root { --pad-x: 12%; }
  }
</style>
