---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import { getCollection } from 'astro:content';
import contactData from '../content/settings/contact.json';
import pageData from '../content/pages/about-services.json';

const allServices = await getCollection('services');
const services = allServices.sort((a, b) => a.data.order - b.data.order);
---

<Layout title="Studio — TNC.18">
  <Navbar />

  <main class="main">

    <!-- Hero -->
    <section class="hero">
      {pageData.hero_image
        ? <img src={pageData.hero_image} alt="" class="hero-img" />
        : <div class="hero-ph"></div>
      }
      <div class="hero-veil"></div>
      <div class="hero-content">
        <h1 class="hero-title">{pageData.headline.toUpperCase()}</h1>
      </div>
    </section>

    <!-- Mission -->
    <section class="mission" data-reveal>
      <p class="mission-text">{pageData.mission}</p>
    </section>

    <!-- Bio -->
    <section class="bio">
      <div class="bio-inner">
        <div class="bio-text" data-reveal>
          <p class="bio-p">{pageData.bio_1}</p>
          {pageData.bio_2 && <p class="bio-p">{pageData.bio_2}</p>}
        </div>
        <aside class="bio-side">
          {pageData.owner_photo && (
            <div class="owner" data-reveal>
              <img src={pageData.owner_photo} alt={pageData.owner_name || ''} class="owner-img" />
              {pageData.owner_name  && <p class="owner-name">{pageData.owner_name}</p>}
              {pageData.owner_title && <p class="owner-role">{pageData.owner_title}</p>}
            </div>
          )}
          {(pageData.years || pageData.projects) && (
            <div class="stats" data-reveal>
              {pageData.years    && <div class="stat"><span class="stat-n">{pageData.years}</span><span class="stat-l">Years</span></div>}
              {pageData.projects && <div class="stat"><span class="stat-n">{pageData.projects}</span><span class="stat-l">Projects</span></div>}
            </div>
          )}
        </aside>
      </div>
    </section>

    <!-- Services -->
    <section class="services">
      <div class="svc-head" data-reveal>
        <span class="s-label">What We Do</span>
      </div>
      <div class="svc-list">
        {services.map((s, i) => (
          <div class="svc-row" data-reveal data-delay={String(i % 3)}>
            <span class="svc-n">0{s.data.order}</span>
            <div class="svc-body">
              <h3 class="svc-title">{s.data.title.toUpperCase()}</h3>
              {s.data.description && <p class="svc-desc">{s.data.description}</p>}
            </div>
          </div>
        ))}
        {services.length === 0 && (
          <p class="svc-empty">Add services in the <a href="/admin">CMS</a>.</p>
        )}
      </div>
    </section>

    <!-- CTA -->
    <section class="cta" data-reveal>
      <div class="cta-inner">
        <div>
          <h2 class="cta-title">Work with us<br/>directly.</h2>
          <p class="cta-sub">Senior partners. Fast turnaround. 24/7 support.</p>
        </div>
        {contactData.line && (
          <a href={contactData.line} target="_blank" rel="noopener" class="cta-line-btn">
            <span class="line-dot"></span>
            Message on Line
          </a>
        )}
      </div>
    </section>

  </main>

  <footer class="site-footer">
    <div class="site-footer-inner">
      <div>
        <span class="site-footer-logo">TNC<em>.</em>18</span>
        <p class="site-footer-sub">Retail & Interior Design · Bangkok</p>
      </div>
      <nav class="site-footer-nav">
        <a href="/">Home</a>
        <a href="/portfolio">Work</a>
        <a href="/contact">Contact</a>
        {contactData.line && <a href={contactData.line} target="_blank" rel="noopener">Line OA</a>}
      </nav>
      <p class="site-footer-copy">© {new Date().getFullYear()} TNC.18.</p>
    </div>
  </footer>
</Layout>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  .main { padding-top: 64px; background: var(--bg); min-height: 100vh; }

  /* Hero */
  .hero {
    position: relative; width: 100%;
    height: 50vw; min-height: 260px; max-height: 520px;
    overflow: hidden; background: #0a0c10;
  }
  .hero-img { width: 100%; height: 100%; object-fit: cover; opacity: 0.42; display: block; }
  .hero-ph  { position: absolute; inset: 0; background: linear-gradient(155deg,#1a2a3e,#060810); }
  .hero-veil { position: absolute; inset: 0; background: linear-gradient(to top,rgba(4,6,10,0.75) 0%,transparent 60%); }
  .hero-content { position: absolute; inset: 0; display: flex; align-items: flex-end; padding: 2.5rem var(--pad-x); }
  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 6vw, 3.5rem);
    font-weight: 400; letter-spacing: 0.08em;
    color: #F8F7F4; line-height: 1.05;
  }

  /* Mission */
  .mission { padding: var(--section) var(--pad-x) 0; }
  .mission-text {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 3vw, 1.75rem);
    font-weight: 400; letter-spacing: 0.04em;
    color: var(--ink); line-height: 1.65; max-width: 720px;
  }

  /* Bio */
  .bio { padding: var(--section) var(--pad-x) 0; }
  .bio-inner { display: flex; flex-direction: column; gap: 3rem; }
  .bio-p {
    font-size: 1rem; line-height: 1.9;
    color: var(--ink-mid); font-weight: 300;
    margin-bottom: 1.25rem; max-width: 560px;
  }
  .bio-p:last-child { margin-bottom: 0; }

  .owner { display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 2rem; }
  .owner-img { width: 60px; height: 60px; border-radius: 50%; object-fit: cover; }
  .owner-name {
    font-family: var(--font-display); font-size: 0.9rem;
    letter-spacing: 0.06em; color: var(--ink); margin-top: 0.25rem;
  }
  .owner-role {
    font-family: var(--font-mono); font-size: 0.52rem;
    letter-spacing: 0.18em; text-transform: uppercase; color: var(--ink-light);
  }

  .stats { display: flex; gap: 3rem; }
  .stat { display: flex; flex-direction: column; gap: 0.15rem; }
  .stat-n {
    font-family: var(--font-display); font-size: 2.25rem;
    font-weight: 400; color: var(--ink); line-height: 1;
  }
  .stat-l {
    font-family: var(--font-mono); font-size: 0.5rem;
    letter-spacing: 0.22em; text-transform: uppercase; color: var(--ink-light);
  }

  /* Services */
  .services { padding: var(--section) var(--pad-x) 0; }
  .svc-head { padding-bottom: 1.5rem; border-bottom: 0.5px solid rgba(26,26,26,0.1); margin-bottom: 0; }
  .svc-list { border-top: none; }
  .svc-row {
    display: flex; gap: 1.5rem; padding: 1.75rem 0;
    border-bottom: 0.5px solid rgba(26,26,26,0.07);
    align-items: flex-start;
  }
  .svc-n {
    font-family: var(--font-mono); font-size: 0.52rem;
    color: var(--navy); letter-spacing: 0.14em; flex-shrink: 0; padding-top: 0.2rem;
  }
  .svc-title {
    font-family: var(--font-display);
    font-size: clamp(0.95rem, 2.5vw, 1.25rem);
    font-weight: 400; letter-spacing: 0.08em;
    color: var(--ink); margin-bottom: 0.45rem;
  }
  .svc-desc {
    font-size: 0.88rem; line-height: 1.85;
    color: var(--ink-light); font-weight: 300; max-width: 480px;
  }
  .svc-empty { font-size: 0.875rem; color: var(--ink-light); padding: 2rem 0; }
  .svc-empty a { color: var(--navy); text-decoration: none; }

  /* CTA */
  .cta {
    background: var(--navy-deep);
    padding: var(--section) var(--pad-x);
    margin-top: var(--section);
  }
  .cta-inner {
    display: flex; flex-direction: column; gap: 2.5rem;
    align-items: flex-start; max-width: 800px;
  }
  .cta-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 400; letter-spacing: 0.06em;
    text-transform: uppercase; color: #F8F7F4; line-height: 1.05;
    margin-bottom: 0.85rem;
  }
  .cta-sub {
    font-size: 0.9rem; color: rgba(248,247,244,0.4);
    line-height: 1.85; font-weight: 300;
  }
  .cta-line-btn {
    display: inline-flex; align-items: center; gap: 0.65rem;
    font-family: var(--font-body); font-size: 0.65rem;
    font-weight: 500; letter-spacing: 0.16em;
    text-transform: uppercase; text-decoration: none;
    color: #F8F7F4; background: transparent;
    padding: 0.9rem 1.8rem;
    border: 1px solid rgba(248,247,244,0.35);
    transition: background 0.25s, border-color 0.25s;
    white-space: nowrap; flex-shrink: 0;
  }
  .cta-line-btn:hover { background: rgba(248,247,244,0.1); border-color: rgba(248,247,244,0.65); }

  @media (min-width: 768px) {
    .bio-inner { flex-direction: row; gap: 6rem; align-items: flex-start; }
    .bio-text  { flex: 1; }
    .bio-side  { width: 220px; flex-shrink: 0; }
    .cta-inner { flex-direction: row; align-items: center; justify-content: space-between; gap: 5rem; }
  }
</style>

<script>
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (!e.isIntersecting) return;
      e.target.classList.add('revealed');
      io.unobserve(e.target);
    });
  }, { threshold: 0.06 });
  document.querySelectorAll('[data-reveal]').forEach(el => io.observe(el));
</script>
