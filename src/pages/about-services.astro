---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';
import contactData from '../content/settings/contact.json';
import pageData from '../content/pages/about-services.json';

const allServices = await getCollection('services');
const services = allServices.sort((a, b) => a.data.order - b.data.order);
---

<Layout title="Studio — TNC.18">
  <Navbar />

  <main class="main">

    <!-- Hero -->
    <section class="hero">
      {pageData.hero_image
        ? <img src={pageData.hero_image} alt="" class="hero-img" />
        : <div class="hero-ph"></div>
      }
      <div class="hero-veil"></div>
      <div class="hero-content">
        <p class="hero-eyebrow">Studio</p>
        <h1 class="hero-title">{pageData.headline.toUpperCase()}</h1>
      </div>
    </section>

    <!-- Mission -->
    <section class="mission" data-reveal>
      <p class="mission-text">{pageData.mission}</p>
    </section>

    <!-- Stats -->
    {(pageData.years || pageData.projects) && (
      <section class="stats-band" data-reveal>
        {pageData.years && (
          <div class="stat-item">
            <span class="stat-n">{pageData.years}</span>
            <span class="stat-l">Years of<br/>Precision Craft</span>
          </div>
        )}
        <div class="stat-divider"></div>
        {pageData.projects && (
          <div class="stat-item">
            <span class="stat-n">{pageData.projects}</span>
            <span class="stat-l">Projects<br/>Completed</span>
          </div>
        )}
        <div class="stat-divider"></div>
        <div class="stat-item">
          <span class="stat-n">0</span>
          <span class="stat-l">Junior<br/>Hand-offs</span>
        </div>
      </section>
    )}

    <!-- Bio -->
    <section class="bio">
      <div class="bio-inner">
        <div class="bio-text" data-reveal>
          <p class="bio-p">{pageData.bio_1}</p>
          {pageData.bio_2 && <p class="bio-p">{pageData.bio_2}</p>}
          <a href="/portfolio" class="bio-link">View Our Work →</a>
        </div>
        {pageData.owner_photo && (
          <aside class="bio-side" data-reveal>
            <img src={pageData.owner_photo} alt={pageData.owner_name || ''} class="owner-img" />
            {pageData.owner_name  && <p class="owner-name">{pageData.owner_name}</p>}
            {pageData.owner_title && <p class="owner-role">{pageData.owner_title}</p>}
          </aside>
        )}
      </div>
    </section>

    <!-- Services -->
    <section class="services">
      <div class="svc-head" data-reveal>
        <span class="s-label">What We Do</span>
      </div>
      <div class="svc-list">
        {services.map((s, i) => (
          <div class="svc-row" data-reveal data-delay={String(i % 3)}>
            <span class="svc-n">{String(s.data.order).padStart(2,'0')}</span>
            <div class="svc-body">
              <h3 class="svc-title">{s.data.title.toUpperCase()}</h3>
              {s.data.description && <p class="svc-desc">{s.data.description}</p>}
            </div>
          </div>
        ))}
        {services.length === 0 && (
          <p class="svc-empty">Add services in the <a href="/admin">CMS</a>.</p>
        )}
      </div>
    </section>


    <!-- CTA -->
    <section class="cta" data-reveal>
      <div class="cta-inner">
        <div class="cta-left">
          <h2 class="cta-title">Work with us<br/>directly.</h2>
          <p class="cta-sub">Senior partners only. Fast turnaround. 24/7 support.</p>
        </div>
        {contactData.line && (
          <a href={contactData.line} target="_blank" rel="noopener" class="cta-line-btn">
            <span class="line-dot"></span>
            Message on Line
          </a>
        )}
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  .main { padding-top: 64px; background: var(--bg, #F8F7F4); min-height: 100vh; }

  /* HERO */
  .hero {
    position: relative; width: 100%;
    height: 60vw; min-height: 300px; max-height: 580px;
    overflow: hidden; background: #0a0c10;
  }
  .hero-img { width: 100%; height: 100%; object-fit: cover; opacity: 0.45; display: block; }
  .hero-ph  { position: absolute; inset: 0; background: linear-gradient(155deg,#1a2a3e,#060810); }
  .hero-veil { position: absolute; inset: 0; background: linear-gradient(to top,rgba(4,6,10,0.82) 0%,rgba(4,6,10,0.2) 55%,transparent 75%); }
  .hero-content { position: absolute; inset: 0; display: flex; flex-direction: column; justify-content: flex-end; padding: 2.5rem var(--pad-x,5vw); }
  .hero-eyebrow { font-family: var(--font-mono,'Courier New',monospace); font-size: 0.54rem; letter-spacing: 0.3em; text-transform: uppercase; color: rgba(248,247,244,0.4); margin-bottom: 0.75rem; }
  .hero-title { font-family: var(--font-display,'Tenor Sans',serif); font-size: clamp(1.75rem,5.5vw,3.5rem); font-weight: 400; letter-spacing: 0.08em; color: #F8F7F4; line-height: 1.1; }

  /* MISSION */
  .mission { padding: 4rem var(--pad-x,5vw) 0; }
  .mission-text { font-family: var(--font-display,'Tenor Sans',serif); font-size: clamp(1.15rem,3vw,1.85rem); font-weight: 400; letter-spacing: 0.04em; color: var(--ink,#1A1A1A); line-height: 1.7; max-width: 720px; }

  /* STATS */
  .stats-band { display: flex; align-items: center; padding: 3rem var(--pad-x,5vw) 0; flex-wrap: nowrap; gap: 0; overflow-x: auto; }
  .stat-item { display: flex; flex-direction: column; gap: 0.5rem; flex: 1; min-width: 100px; }
  .stat-n { font-family: var(--font-display,'Tenor Sans',serif); font-size: clamp(1.75rem,6vw,4rem); font-weight: 400; color: var(--ink,#1A1A1A); line-height: 1; }
  .stat-l { font-family: var(--font-mono,'Courier New',monospace); font-size: 0.52rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--ink-light,#6B6B6B); line-height: 1.6; }
  .stat-divider { width: 0.5px; height: 50px; background: rgba(26,26,26,0.15); flex-shrink: 0; align-self: center; }

  /* BIO */
  .bio { padding: 4rem var(--pad-x,5vw) 0; }
  .bio-inner { display: flex; flex-direction: column; gap: 3rem; }
  .bio-p { font-size: 1rem; line-height: 1.95; color: var(--ink-mid,#3D3D3D); font-weight: 300; margin-bottom: 1.25rem; max-width: 580px; font-size: 0.95rem; }
  .bio-p:last-of-type { margin-bottom: 1.75rem; }
  .bio-link { font-family: var(--font-mono,'Courier New',monospace); font-size: 0.58rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--navy,#1A3A6B); text-decoration: none; transition: opacity 0.2s; }
  .bio-link:hover { opacity: 0.6; }
  .owner-img { width: 72px; height: 72px; border-radius: 50%; object-fit: cover; margin-bottom: 0.75rem; }
  .owner-name { font-family: var(--font-display,'Tenor Sans',serif); font-size: 0.95rem; letter-spacing: 0.06em; color: var(--ink,#1A1A1A); }
  .owner-role { font-family: var(--font-mono,'Courier New',monospace); font-size: 0.5rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ink-light,#6B6B6B); margin-top: 0.25rem; }

  /* SERVICES */
  .services { padding: 4rem var(--pad-x,5vw) 0; }
  .svc-head { padding-bottom: 1.25rem; border-bottom: 0.5px solid rgba(26,26,26,0.12); }
  .s-label { font-family: var(--font-mono,'Courier New',monospace); font-size: 0.58rem; letter-spacing: 0.28em; text-transform: uppercase; color: var(--ink-light,#6B6B6B); }
  .svc-row { display: grid; grid-template-columns: 2.5rem 1fr; gap: 1.5rem; padding: 2rem 0; border-bottom: 0.5px solid rgba(26,26,26,0.07); align-items: flex-start; }
  .svc-n { font-family: var(--font-mono,'Courier New',monospace); font-size: 0.58rem; color: var(--navy,#1A3A6B); letter-spacing: 0.14em; font-weight: 600; padding-top: 0.25rem; }
  .svc-title { font-family: var(--font-display,'Tenor Sans',serif); font-size: clamp(1rem,2.5vw,1.35rem); font-weight: 400; letter-spacing: 0.08em; color: var(--ink,#1A1A1A); margin-bottom: 0.5rem; line-height: 1.2; }
  .svc-desc { font-size: 0.9rem; line-height: 1.9; color: var(--ink-light,#6B6B6B); font-weight: 300; max-width: 520px; }
  .svc-empty { font-size: 0.875rem; color: var(--ink-light,#6B6B6B); padding: 2rem 0; }
  .svc-empty a { color: var(--navy,#1A3A6B); text-decoration: none; }

  /* WORK BAND */
  .work-band { padding: 4rem var(--pad-x,5vw); background: #EFEDE8; }
  .work-band-inner { display: flex; flex-direction: column; gap: 1.5rem; max-width: 600px; }
  .work-band-label { font-family: var(--font-mono,'Courier New',monospace); font-size: 0.54rem; letter-spacing: 0.28em; text-transform: uppercase; color: var(--navy,#1A3A6B); }
  .work-band-title { font-family: var(--font-display,'Tenor Sans',serif); font-size: clamp(1.5rem,4vw,2.5rem); font-weight: 400; letter-spacing: 0.06em; text-transform: uppercase; color: var(--ink,#1A1A1A); line-height: 1.1; }
  .btn-ghost { display: inline-flex; align-items: center; font-family: var(--font-body,'Inter',sans-serif); font-size: 0.62rem; font-weight: 500; letter-spacing: 0.18em; text-transform: uppercase; text-decoration: none; color: var(--navy,#1A3A6B); background: transparent; padding: 0.85rem 1.75rem; border: 1px solid var(--navy,#1A3A6B); transition: background 0.25s, color 0.25s; align-self: flex-start; }
  .btn-ghost:hover { background: var(--navy,#1A3A6B); color: #F8F7F4; }

  /* CTA */
  .cta { background: var(--navy-deep,#0E2140); padding: 4rem var(--pad-x,5vw); }
  .cta-inner { display: flex; flex-direction: column; gap: 2.5rem; align-items: flex-start; max-width: 1000px; margin: 0 auto; }
  .cta-title { font-family: var(--font-display,'Tenor Sans',serif); font-size: clamp(2rem,6vw,4rem); font-weight: 400; letter-spacing: 0.06em; text-transform: uppercase; color: #F8F7F4; line-height: 1.05; margin-bottom: 0.85rem; }
  .cta-sub { font-size: 0.9rem; color: rgba(248,247,244,0.4); line-height: 1.85; font-weight: 300; }
  .cta-line-btn { display: inline-flex; align-items: center; gap: 0.65rem; font-family: var(--font-body,'Inter',sans-serif); font-size: 0.68rem; font-weight: 500; letter-spacing: 0.16em; text-transform: uppercase; text-decoration: none; color: #F8F7F4; background: transparent; padding: 0.9rem 1.8rem; border: 1px solid rgba(248,247,244,0.4); transition: background 0.25s, border-color 0.25s; white-space: nowrap; flex-shrink: 0; }
  .cta-line-btn:hover { background: rgba(248,247,244,0.1); border-color: rgba(248,247,244,0.7); }
  .line-dot { display: block; width: 7px; height: 7px; border-radius: 50%; background: #06C755; flex-shrink: 0; }

  /* FOOTER */
  .site-footer { background: var(--navy-deep,#0E2140); padding: 3.5rem var(--pad-x,5vw); }
  .site-footer-inner { display: flex; flex-direction: column; gap: 2rem; width: 100%; }
  .footer-brand { display: flex; flex-direction: column; gap: 0.3rem; }
  .site-footer-logo { font-family: var(--font-body,'Inter',sans-serif); font-size: 0.85rem; font-weight: 600; letter-spacing: 0.2em; color: rgba(255,255,255,0.3); display: block; }
  .site-footer-logo em { font-style: normal; color: rgba(255,255,255,0.65); }
  .site-footer-sub { font-family: var(--font-mono,'Courier New',monospace); font-size: 0.5rem; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(255,255,255,0.15); }
  .site-footer-nav { display: flex; flex-wrap: wrap; gap: 0.75rem 2rem; }
  .site-footer-nav a { font-family: var(--font-mono,'Courier New',monospace); font-size: 0.54rem; letter-spacing: 0.16em; text-transform: uppercase; color: rgba(255,255,255,0.35); text-decoration: none; transition: color 0.2s; white-space: nowrap; }
  .site-footer-nav a:hover { color: rgba(255,255,255,0.8); }
  .site-footer-copy { font-family: var(--font-mono,'Courier New',monospace); font-size: 0.46rem; color: rgba(255,255,255,0.12); letter-spacing: 0.12em; }

  @media (min-width: 768px) {
    .bio-inner { flex-direction: row; gap: 6rem; align-items: flex-start; }
    .bio-text { flex: 1; }
    .bio-side { width: 200px; flex-shrink: 0; }
    .cta-inner { flex-direction: row; align-items: center; justify-content: space-between; gap: 5rem; }
    .site-footer-inner { flex-direction: row; align-items: flex-start; justify-content: space-between; flex-wrap: nowrap; gap: 0; overflow-x: auto; }
    .stats-band { flex-wrap: nowrap; gap: 0; }
    .stat-item { padding-right: 3rem; }
    .stat-divider { margin-right: 3rem; }
  }
</style>

<script>
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (!e.isIntersecting) return;
      e.target.classList.add('revealed');
      io.unobserve(e.target);
    });
  }, { threshold: 0.06 });
  document.querySelectorAll('[data-reveal]').forEach(el => io.observe(el));
</script>
