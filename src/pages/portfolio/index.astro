---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';
import contactData from '../../content/settings/contact.json';

const allProjects = await getCollection('projects');
const projects = allProjects.sort((a, b) => b.data.year - a.data.year);

function slug(t: string) {
  return t.toLowerCase().replace(/['’]/g, '').replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
}

const categories = ['All', ...new Set(projects.map(p => p.data.category).filter(Boolean))];
---

<Layout
  title="Work — TNC.18"
  description="Retail interior design portfolio — TNC.18 Bangkok."
>
  <Navbar />

  <main class="main">

    <header class="page-head">
      <h1 class="page-title">Works</h1>
      <div class="page-filters" id="filters" role="tablist">
        {categories.map((cat, i) => (
          <button
            class={`filter-btn ${i === 0 ? 'active' : ''}`}
            data-cat={cat}
            role="tab"
            aria-selected={i === 0 ? 'true' : 'false'}
          >{cat}</button>
        ))}
      </div>
    </header>

    <div class="grid" id="proj-grid">
      {projects.map((p, i) => (
        <article
          class="grid-item"
          data-reveal
          data-category={p.data.category}
        >
          <a href={`/portfolio/${slug(p.data.title)}`} class="grid-link">
            <div class="grid-img-wrap">
              {p.data.cover && !p.data.cover.includes('placeholder')
                ? <img
                    src={p.data.cover}
                    alt={p.data.title}
                    loading={i < 3 ? 'eager' : 'lazy'}
                    class="grid-img"
                  />
                : <div class="grid-ph"></div>
              }
              <div class="grid-overlay">
                <span class="grid-read">Read More →</span>
              </div>
              <div class="grid-num">{String(i + 1).padStart(2, '0')}</div>
            </div>
            <div class="grid-info">
              <div class="grid-meta">
                <span class="grid-cat">{p.data.category?.toUpperCase()}</span>
                {p.data.location && <><span class="grid-sep">—</span><span class="grid-loc">{p.data.location.toUpperCase()}</span></>}
                <span class="grid-yr">{p.data.year}</span>
              </div>
              <h2 class="grid-name">{p.data.title}</h2>
            </div>
          </a>
        </article>
      ))}

      {projects.length === 0 && (
        <div class="grid-empty">
          <p>No projects yet. <a href="/admin">Add in CMS →</a></p>
        </div>
      )}
    </div>

    {contactData.line && (
      <div class="page-cta" data-reveal>
        <h2 class="cta-q">Have a project in mind?</h2>
        <a href={contactData.line} target="_blank" rel="noopener" class="btn-ghost">
          <span class="line-dot"></span>
          Message on Line
        </a>
      </div>
    )}

  </main>

  <Footer />
</Layout>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  .main { padding-top: 64px; background: var(--bg); min-height: 100vh; }

  /* Page header */
  .page-head {
    padding: 4rem var(--pad-x) 2rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .page-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 6vw, 3.5rem);
    font-weight: 400; letter-spacing: 0.06em;
    text-transform: uppercase; color: var(--ink);
  }

  /* Category filters */
  .page-filters {
    display: flex;
    gap: 0;
    flex-wrap: wrap;
    border-bottom: 0.5px solid rgba(26,26,26,0.1);
  }

  .filter-btn {
    font-family: var(--font-mono);
    font-size: 0.58rem; letter-spacing: 0.2em;
    text-transform: uppercase; color: var(--ink-light);
    background: none; border: none;
    padding: 0.6rem 1.25rem 0.6rem 0;
    cursor: pointer;
    position: relative;
    transition: color 0.2s;
    white-space: nowrap;
  }

  .filter-btn::after {
    content: '';
    position: absolute;
    bottom: -0.5px; left: 0; right: 0;
    height: 1.5px;
    background: var(--navy);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s;
  }

  .filter-btn:hover { color: var(--ink); }
  .filter-btn.active { color: var(--ink); font-weight: 500; }
  .filter-btn.active::after { transform: scaleX(1); }

  /* Grid — 1 col mobile, 2 col tablet, 3 col desktop */
  .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1px;
    background: rgba(26,26,26,0.06);
  }

  .grid-item {
    background: var(--bg);
    opacity: 0; transform: translateY(28px);
    transition: opacity 0.85s cubic-bezier(0.16,1,0.3,1),
                transform 0.85s cubic-bezier(0.16,1,0.3,1);
  }
  .grid-item.revealed { opacity: 1; transform: none; }
  .grid-item.hidden { display: none; }

  .grid-link { display: block; text-decoration: none; color: inherit; }

  .grid-img-wrap {
    position: relative; width: 100%; overflow: hidden;
    background: var(--bg-dark); aspect-ratio: 4/3;
  }

  .grid-img {
    width: 100%; height: 100%; object-fit: cover; display: block;
    transition: transform 1.2s cubic-bezier(0.4,0,0.2,1);
  }
  .grid-ph { width: 100%; height: 100%; background: var(--bg-dark); }
  .grid-link:hover .grid-img { transform: scale(1.04); }

  /* Overlay */
  .grid-overlay {
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
    background: rgba(26,58,107,0);
    transition: background 0.4s;
  }
  .grid-link:hover .grid-overlay { background: rgba(26,58,107,0.55); }

  .grid-read {
    font-family: var(--font-mono);
    font-size: 0.6rem; letter-spacing: 0.28em;
    text-transform: uppercase; color: #fff;
    opacity: 0; transform: translateY(6px);
    transition: opacity 0.35s, transform 0.35s;
  }
  .grid-link:hover .grid-read { opacity: 1; transform: none; }

  /* Project number */
  .grid-num {
    position: absolute; top: 1rem; left: 1rem;
    font-family: var(--font-mono); font-size: 0.52rem;
    letter-spacing: 0.14em; color: rgba(248,247,244,0.5);
  }

  /* Info */
  .grid-info { padding: 0.85rem 1.25rem 1.5rem; }

  .grid-meta {
    display: flex; align-items: center; gap: 0.5rem;
    margin-bottom: 0.45rem; flex-wrap: wrap;
  }
  .grid-cat {
    font-family: var(--font-mono); font-size: 0.46rem;
    letter-spacing: 0.24em; color: var(--navy);
  }
  .grid-sep { font-size: 0.46rem; color: var(--bg-dark); }
  .grid-loc {
    font-family: var(--font-mono); font-size: 0.46rem;
    letter-spacing: 0.16em; color: var(--ink-light);
  }
  .grid-yr {
    font-family: var(--font-mono); font-size: 0.46rem;
    color: rgba(26,26,26,0.3); margin-left: auto;
  }
  .grid-name {
    font-family: var(--font-display);
    font-size: clamp(0.9rem, 2vw, 1.15rem);
    font-weight: 400; letter-spacing: 0.06em;
    text-transform: uppercase; color: var(--ink); line-height: 1.25;
  }

  /* Empty */
  .grid-empty {
    padding: 5rem var(--pad-x);
    font-size: 0.875rem; color: var(--ink-light);
    background: var(--bg);
  }
  .grid-empty a { color: var(--navy); text-decoration: none; }

  /* Bottom CTA */
  .page-cta {
    padding: 6rem var(--pad-x);
    display: flex; flex-direction: column; gap: 1.5rem;
    align-items: flex-start;
  }
  .cta-q {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 4vw, 2rem);
    font-weight: 400; letter-spacing: 0.06em;
    text-transform: uppercase; color: var(--ink);
  }

  /* Desktop */
  @media (min-width: 640px) {
    .grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .grid { grid-template-columns: repeat(3, 1fr); }
    .page-head { flex-direction: row; align-items: flex-end; gap: 3rem; }
    .page-filters { border-bottom: none; align-items: flex-end; padding-bottom: 0.5rem; }
  }
</style>

<script>
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (!e.isIntersecting) return;
      e.target.classList.add('revealed');
      io.unobserve(e.target);
    });
  }, { threshold: 0.04 });
  document.querySelectorAll('[data-reveal]').forEach(el => io.observe(el));

  document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.filter-btn').forEach(b => {
        b.classList.remove('active');
        b.setAttribute('aria-selected', 'false');
      });
      btn.classList.add('active');
      btn.setAttribute('aria-selected', 'true');

      const cat = btn.getAttribute('data-cat');
      document.querySelectorAll('.grid-item').forEach(item => {
        const el = item as HTMLElement;
        if (cat === 'All' || el.dataset.category === cat) {
          el.classList.remove('hidden');
        } else {
          el.classList.add('hidden');
        }
      });
    });
  });
</script>
