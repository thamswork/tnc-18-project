---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import { getCollection } from "astro:content";

const allProjects = await getCollection("projects");
const projects = allProjects.sort((a, b) => b.data.year - a.data.year);

function slug(t: string) {
  return t.toLowerCase().replace(/[\u2018\u2019'']/g, "").replace(/[^a-z0-9]+/g, "-").replace(/^-|-$/g, "");
}

const categories = ["All", ...new Set(projects.map(p => p.data.category).filter(Boolean))];
---

<Layout title="Work — TNC BUILD STUDIO" description="Portfolio of retail interior design projects by TNC BUILD STUDIO, Bangkok.">
  <Navbar />

  <main class="main">

    <header class="page-header">
      <div class="page-header-left">
        <p class="page-eyebrow">Selected Projects</p>
        <h1 class="page-title">Work</h1>
      </div>
      <div class="page-filters" id="filters" role="tablist">
        {categories.map((cat, i) => (
          <button
            class={`filter-btn ${i === 0 ? "active" : ""}`}
            data-cat={cat} role="tab"
            aria-selected={i === 0 ? "true" : "false"}
          >{cat}</button>
        ))}
      </div>
    </header>

    <div class="proj-grid" id="proj-grid">
      {projects.map((p, i) => (
        <article class="proj-card" data-category={p.data.category} data-index={i}>
          <a href={`/portfolio/${slug(p.data.title)}`} class="proj-link">
            <div class="proj-img-wrap">
              {p.data.cover && !p.data.cover.includes("placeholder")
                ? <img src={p.data.cover} alt={p.data.title}
                    loading={i < 4 ? "eager" : "lazy"} class="proj-img" />
                : <div class="proj-ph"></div>
              }
              <div class="proj-overlay">
                <div class="proj-overlay-inner">
                  <span class="proj-cat">{p.data.category}</span>
                  <h2 class="proj-title">{p.data.title}</h2>
                  <span class="proj-arrow">→</span>
                </div>
              </div>
            </div>
          </a>
        </article>
      ))}

      {projects.length === 0 && (
        <div class="proj-empty">
          <p>No projects yet. <a href="/admin">Add in CMS →</a></p>
        </div>
      )}
    </div>

  </main>

  <Footer ctaTitle="Have a Project in Mind?" ctaSub="Every project handled by founding partners. No junior hand-offs." />
</Layout>

<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

.main {
  padding-top: 64px;
  background: var(--bg, #F4F3EF);
  min-height: 100vh;
}

/* ── HEADER ── */
.page-header {
  display: flex;
  flex-direction: column;
  gap: 2rem;
  padding: 2.5rem var(--pad-x) 2rem;
}

@media (min-width: 768px) {
  .page-header {
    flex-direction: row;
    align-items: flex-end;
    justify-content: space-between;
    gap: 3rem;
  }
}

.page-eyebrow {
  font-size: 0.575rem; font-weight: 600;
  letter-spacing: 0.26em; text-transform: uppercase;
  color: var(--navy, #1A3A6B);
  margin-bottom: 0.75rem; display: block;
}

.page-title {
  font-size: clamp(2rem, 6vw, 4rem);
  font-weight: 800; letter-spacing: -0.04em;
  line-height: 0.88; color: var(--ink, #111);
  text-transform: uppercase;
}

/* ── FILTERS ── */
.page-filters {
  display: flex; gap: 0;
  flex-wrap: wrap; overflow-x: auto;
  scrollbar-width: none;
  padding-bottom: 2px;
}
.page-filters::-webkit-scrollbar { display: none; }

.filter-btn {
  font-size: 0.6rem; font-weight: 500;
  letter-spacing: 0.14em; text-transform: uppercase;
  color: var(--ink-light, #777);
  background: none; border: none; cursor: pointer;
  padding: 0.4rem 1.5rem 0.4rem 0;
  position: relative; white-space: nowrap;
  transition: color 0.2s; flex-shrink: 0;
}
.filter-btn::after {
  content: ""; position: absolute;
  bottom: 0; left: 0; right: 0; height: 1px;
  background: var(--ink, #111);
  transform: scaleX(0); transform-origin: left;
  transition: transform 0.3s cubic-bezier(0.4,0,0.2,1);
}
.filter-btn.active { color: var(--ink, #111); font-weight: 600; }
.filter-btn.active::after { transform: scaleX(1); }
.filter-btn:hover { color: var(--ink, #111); }

/* ── GRID ── */
.proj-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1.5rem;
  padding: 0 var(--pad-x) 5rem;
}

@media (min-width: 600px) {
  .proj-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }
}

@media (min-width: 1024px) {
  .proj-grid {
    grid-template-columns: repeat(3, 1fr);
    gap: 1.75rem;
  }
}

/* ── CARD ── */
.proj-card {
  opacity: 0; transform: translateY(24px);
  transition: opacity 0.7s cubic-bezier(0.16,1,0.3,1),
              transform 0.7s cubic-bezier(0.16,1,0.3,1);
}
.proj-card.in-view { opacity: 1; transform: none; }
.proj-card.hidden { display: none; }

.proj-link {
  display: block;
  text-decoration: none; color: inherit;
}

/* ── IMAGE ── */
.proj-img-wrap {
  position: relative; width: 100%;
  overflow: hidden;
  background: var(--bg-dark, #ECEAE3);
  aspect-ratio: 1/1;
}

.proj-img {
  width: 100%; height: 100%;
  object-fit: cover; display: block;
  transition: transform 1.2s cubic-bezier(0.4,0,0.2,1);
}
.proj-ph { width: 100%; height: 100%; background: var(--bg-dark); }
.proj-link:hover .proj-img { transform: scale(1.05); }

/* ── OVERLAY ── */
.proj-overlay {
  position: absolute; inset: 0;
  background: rgba(10,18,36,0);
  transition: background 0.45s cubic-bezier(0.4,0,0.2,1);
  display: flex; align-items: flex-end;
}
.proj-link:hover .proj-overlay {
  background: rgba(10,18,36,0.72);
}

.proj-overlay-inner {
  padding: 2rem 1.75rem;
  display: flex; flex-direction: column;
  gap: 0.5rem; width: 100%;
  transform: translateY(12px); opacity: 0;
  transition:
    opacity 0.4s 0.05s cubic-bezier(0.16,1,0.3,1),
    transform 0.4s 0.05s cubic-bezier(0.16,1,0.3,1);
}
.proj-link:hover .proj-overlay-inner {
  opacity: 1; transform: none;
}

.proj-cat {
  font-size: 0.55rem; font-weight: 600;
  letter-spacing: 0.2em; text-transform: uppercase;
  color: rgba(244,243,239,0.55);
}

.proj-title {
  font-size: clamp(1rem, 2.5vw, 1.5rem);
  font-weight: 700; letter-spacing: -0.02em;
  color: #F4F3EF; line-height: 1.15;
}

.proj-arrow {
  font-size: 1rem; color: rgba(244,243,239,0.6);
  margin-top: 0.25rem;
  transition: transform 0.25s;
}
.proj-link:hover .proj-arrow { transform: translateX(4px); }

.proj-empty {
  grid-column: 1 / -1;
  padding: 5rem 0;
  font-size: 0.875rem; color: var(--ink-light);
}
.proj-empty a { color: var(--navy); }
</style>

<script>
(function() {
  const cards = document.querySelectorAll<HTMLElement>(".proj-card");
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (!e.isIntersecting) return;
      const el = e.target as HTMLElement;
      const idx = parseInt(el.dataset.index || "0");
      setTimeout(() => el.classList.add("in-view"), (idx % 3) * 90);
      io.unobserve(el);
    });
  }, { threshold: 0.06 });
  cards.forEach(c => io.observe(c));
})();

(function() {
  document.querySelectorAll(".filter-btn").forEach(btn => {
    btn.addEventListener("click", () => {
      document.querySelectorAll(".filter-btn").forEach(b => {
        b.classList.remove("active");
        b.setAttribute("aria-selected", "false");
      });
      btn.classList.add("active");
      btn.setAttribute("aria-selected", "true");
      const cat = btn.getAttribute("data-cat");
      document.querySelectorAll<HTMLElement>(".proj-card").forEach(card => {
        card.classList.toggle("hidden", cat !== "All" && card.dataset.category !== cat);
      });
    });
  });
})();
</script>
