---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map(p => ({
    params: {
      slug: p.data.title
        .toLowerCase()
        .replace(/[\u2018\u2019'']/g, "")
        .replace(/[^a-z0-9]+/g, "-")
        .replace(/^-|-$/g, "")
    },
    props: { project: p }
  }));
}

const { project } = Astro.props;
const d = project.data;
const { Content } = await render(project);

const allProjects = await getCollection("projects");
const sorted = allProjects.sort((a, b) => b.data.year - a.data.year);
const idx = sorted.findIndex(p => p.id === project.id);
const next = sorted[(idx + 1) % sorted.length];
const nextSlug = next?.data.title.toLowerCase().replace(/[\u2018\u2019'']/g,"").replace(/[^a-z0-9]+/g,"-").replace(/^-|-$/g,"");

const areaVal = d.area ? `${d.area} SQ.M` : (d.size ? String(d.size) : null);
const metaRows = [
  { k: "Client",   v: d.client || null },
  { k: "Location", v: d.location || null },
  { k: "Area",     v: areaVal },
  { k: "Year",     v: d.year ? String(d.year) : null },
  { k: "Type",     v: d.category || null },
].filter(r => r.v);
---

<Layout
  bodyClass="page-slug page-solid-nav"
  title={`${d.title} — TNC BUILD STUDIO`}
  description={d.description || `${d.title} — Retail & Interior Design by TNC BUILD STUDIO Bangkok`}
>
  <Navbar />
  <main class="proj-main">

    <!-- HERO -->
    <div class="proj-hero">
      {d.video_url
        ? <video autoplay muted loop playsinline class="proj-hero-asset">
            <source src={d.video_url} type="video/mp4" />
          </video>
        : d.cover
          ? <img src={d.cover} alt={d.title} class="proj-hero-asset" loading="eager" />
          : <div class="proj-hero-ph"></div>
      }
      <div class="proj-hero-veil"></div>
      <a href="/portfolio" class="proj-back">← All Work</a>
      <div class="proj-hero-caption">
        <span class="proj-hero-cat">{d.category}</span>
        <h1 class="proj-hero-title">{d.title}</h1>
      </div>
    </div>

    <!-- META STRIP — scrollable horizontal on mobile -->
    <div class="proj-meta-strip">
      {metaRows.map(row => (
        <div class="proj-meta-cell">
          <span class="proj-meta-k">{row.k}</span>
          <span class="proj-meta-v">{row.v}</span>
        </div>
      ))}
    </div>

    <!-- DESCRIPTION -->
    {d.description && (
      <section class="proj-desc-section" data-reveal>
        <p class="proj-desc">{d.description}</p>
      </section>
    )}

    <!-- GALLERY -->
    {d.gallery && d.gallery.length > 0 && (
      <section class="proj-gallery">
        {d.gallery.map((img: string, i: number) => (
          <figure
            class={`proj-gframe ${i % 5 === 0 || i % 5 === 3 ? "gframe-full" : "gframe-half"}`}
            data-reveal
          >
            <img src={img} alt={`${d.title} — ${i + 1}`} loading="lazy" class="proj-gimg" />
          </figure>
        ))}
      </section>
    )}

    <!-- BODY COPY -->
    {project.body && project.body.trim() && (
      <div class="proj-body" data-reveal>
        <div class="proj-body-inner prose">
          <Content />
        </div>
      </div>
    )}

    <!-- NEXT PROJECT -->
    {next && next.id !== project.id && (
      <a href={`/portfolio/${nextSlug}`} class="proj-next">
        <div class="proj-next-bg">
          {next.data.cover && <img src={next.data.cover} alt={next.data.title} class="proj-next-img" loading="lazy" />}
          <div class="proj-next-veil"></div>
        </div>
        <div class="proj-next-content">
          <span class="proj-next-label">Next Project</span>
          <h2 class="proj-next-title">{next.data.title}</h2>
          <span class="proj-next-arrow">→</span>
        </div>
      </a>
    )}

    <Footer ctaTitle="Like What You See?" ctaSub="Message us directly. Senior partners respond within 2 hours." />
  </main>
</Layout>

<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

.proj-main {
  background: var(--bg, #F4F3EF);
  min-height: 100vh;
  overflow-x: hidden;
}

/* ══ HERO ══ */
.proj-hero {
  position: relative;
  width: 100%;
  height: 100svh;
  overflow: hidden;
  background: #060608;
}

.proj-hero-asset {
  width: 100%; height: 100%;
  object-fit: cover; display: block;
}
.proj-hero-ph {
  width: 100%; height: 100%;
  background: linear-gradient(155deg, #0e1a2e, #060608);
}
.proj-hero-veil {
  position: absolute; inset: 0;
  background:
    linear-gradient(to top, rgba(4,6,10,0.92) 0%, rgba(4,6,10,0.25) 55%, transparent 80%),
    linear-gradient(to bottom, rgba(4,6,10,0.55) 0%, transparent 18%);
}

/* Back */
.proj-back {
  position: absolute;
  top: 76px; left: var(--pad-x, 5vw);
  z-index: 10;
  display: inline-flex; align-items: center; gap: 0.5rem;
  font-size: 0.58rem; font-weight: 600;
  letter-spacing: 0.14em; text-transform: uppercase;
  color: rgba(244,243,239,0.7); text-decoration: none;
  transition: color 0.2s, gap 0.2s;
  background: rgba(10,18,36,0.35);
  backdrop-filter: blur(8px);
  padding: 0.5rem 1rem;
  border: 1px solid rgba(244,243,239,0.15);
}
.proj-back:hover {
  color: #F4F3EF;
  gap: 0.75rem;
  border-color: rgba(244,243,239,0.35);
}

/* Caption */
.proj-hero-caption {
  position: absolute;
  bottom: 0; left: 0; right: 0; z-index: 5;
  padding: 0 var(--pad-x, 5vw) clamp(2rem, 6vh, 4rem);
  display: flex; flex-direction: column; gap: 0.6rem;
}

.proj-hero-cat {
  font-size: 0.55rem; font-weight: 600;
  letter-spacing: 0.22em; text-transform: uppercase;
  color: rgba(244,243,239,0.45);
}

.proj-hero-title {
  font-size: clamp(1.75rem, 7vw, 5rem);
  font-weight: 800; letter-spacing: -0.03em;
  line-height: 0.95; color: #F4F3EF;
  text-transform: uppercase;
  max-width: 90vw;
}

/* ══ META STRIP ══ */
.proj-meta-strip {
  display: flex;
  flex-wrap: wrap;
  border-top: 2px solid var(--navy, #1A3A6B);
  border-bottom: 1px solid rgba(17,17,17,0.08);
  background: #fff;
}

.proj-meta-cell {
  display: flex; flex-direction: column;
  gap: 0.4rem;
  padding: 1rem 1.25rem;
  border-right: 1px solid rgba(17,17,17,0.07);
  border-bottom: 1px solid rgba(17,17,17,0.07);
  /* Each cell takes at least 1/3 of row, max 1/5 */
  flex: 1 1 30%;
  min-width: 100px;
}
.proj-meta-cell:last-child {
  border-right: none;
}

@media (min-width: 540px) {
  .proj-meta-cell {
    flex: 1 1 18%;
    border-bottom: none;
  }
  .proj-meta-cell:last-child { border-right: none; }
}

.proj-meta-k {
  font-size: 0.46rem; font-weight: 600;
  letter-spacing: 0.2em; text-transform: uppercase;
  color: var(--ink-light, #777);
  white-space: nowrap;
  display: block;
}

.proj-meta-v {
  font-size: 0.8rem; font-weight: 700;
  letter-spacing: -0.01em; color: var(--ink, #111);
  white-space: normal;
  word-break: break-word;
}

/* ══ DESCRIPTION ══ */
.proj-desc-section {
  padding: 2.5rem var(--pad-x, 5vw);
  background: #fff;
  border-bottom: 1px solid rgba(17,17,17,0.06);
  opacity: 0; transform: translateY(16px);
  transition: opacity 0.8s cubic-bezier(0.16,1,0.3,1), transform 0.8s cubic-bezier(0.16,1,0.3,1);
}
.proj-desc-section.revealed { opacity: 1; transform: none; }

.proj-desc {
  font-size: clamp(0.9rem, 2.5vw, 1.05rem);
  line-height: 1.85; color: var(--ink-mid, #333);
  font-weight: 400; max-width: 640px;
}

/* ══ GALLERY ══ */
.proj-gallery {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 2px;
  background: rgba(17,17,17,0.06);
  padding: 2px;
}

.proj-gframe {
  overflow: hidden;
  background: var(--bg-dark, #ECEAE3);
  opacity: 0; transform: translateY(12px);
  transition: opacity 0.7s cubic-bezier(0.16,1,0.3,1), transform 0.7s cubic-bezier(0.16,1,0.3,1);
}
.proj-gframe.revealed { opacity: 1; transform: none; }

.gframe-full {
  grid-column: span 2;
  aspect-ratio: 16/9;
}
.gframe-half { aspect-ratio: 1/1; }

@media (max-width: 480px) {
  .gframe-full { aspect-ratio: 4/3; }
  .gframe-half { aspect-ratio: 4/5; }
}

.proj-gimg {
  width: 100%; height: 100%;
  object-fit: cover; display: block;
  transition: transform 1.2s cubic-bezier(0.4,0,0.2,1);
}
.proj-gframe:hover .proj-gimg { transform: scale(1.03); }

/* ══ BODY COPY ══ */
.proj-body {
  padding: 3rem var(--pad-x, 5vw);
  background: var(--bg, #F4F3EF);
  border-top: 1px solid rgba(17,17,17,0.07);
  opacity: 0; transform: translateY(16px);
  transition: opacity 0.8s cubic-bezier(0.16,1,0.3,1), transform 0.8s cubic-bezier(0.16,1,0.3,1);
}
.proj-body.revealed { opacity: 1; transform: none; }
.proj-body-inner { max-width: 640px; }

.prose :global(p) {
  font-size: clamp(0.875rem, 2.5vw, 0.95rem);
  line-height: 1.9; color: var(--ink-mid, #333);
  margin-bottom: 1.4rem;
}
.prose :global(h2), .prose :global(h3) {
  font-size: 1rem; font-weight: 700;
  letter-spacing: -0.02em; color: var(--ink, #111);
  margin: 2rem 0 0.75rem;
}

/* ══ NEXT PROJECT ══ */
.proj-next {
  display: block; position: relative;
  width: 100%;
  height: clamp(200px, 45vw, 400px);
  overflow: hidden; text-decoration: none;
}
.proj-next-bg { position: absolute; inset: 0; }
.proj-next-img {
  width: 100%; height: 100%;
  object-fit: cover; display: block;
  transition: transform 1.2s cubic-bezier(0.4,0,0.2,1);
}
.proj-next:hover .proj-next-img { transform: scale(1.04); }
.proj-next-veil {
  position: absolute; inset: 0;
  background: rgba(10,18,36,0.62);
}
.proj-next-content {
  position: absolute; inset: 0;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  gap: 0.6rem; z-index: 2; text-align: center;
  padding: 0 var(--pad-x, 5vw);
}
.proj-next-label {
  font-size: 0.52rem; font-weight: 600;
  letter-spacing: 0.24em; text-transform: uppercase;
  color: rgba(244,243,239,0.45);
}
.proj-next-title {
  font-size: clamp(1rem, 5vw, 2.25rem);
  font-weight: 800; letter-spacing: -0.03em;
  color: #F4F3EF; text-transform: uppercase;
  line-height: 1.0;
}
.proj-next-arrow {
  font-size: 1.25rem;
  color: rgba(244,243,239,0.55);
  transition: transform 0.3s;
}
.proj-next:hover .proj-next-arrow { transform: translateX(5px); }

/* ══ DESKTOP ENHANCEMENTS ══ */
@media (min-width: 768px) {
  .proj-hero-title { font-size: clamp(2.5rem, 5vw, 5rem); }
  .proj-meta-cell { padding: 1.25rem 2rem; flex: 1 1 auto; border-bottom: none; }
  .proj-desc-section { padding: 4rem 10%; }
  .proj-body { padding: 5rem 10%; }
  .proj-gallery { gap: 3px; padding: 3px; }
  .gframe-half { aspect-ratio: 4/5; }
}

@media (min-width: 1200px) {
  .proj-desc-section { padding: 5rem 15%; }
  .proj-body { padding: 6rem 15%; }
}
</style>

<script>
const io = new IntersectionObserver((entries) => {
  entries.forEach(e => {
    if (!e.isIntersecting) return;
    e.target.classList.add("revealed");
    io.unobserve(e.target);
  });
}, { threshold: 0.04, rootMargin: "0px 0px -30px 0px" });
document.querySelectorAll("[data-reveal]").forEach(el => io.observe(el));
</script>
