---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import { getCollection } from 'astro:content';
import homepageData from '../content/pages/homepage.json';

const allProjects = await getCollection('projects');
const featured = allProjects
  .filter(p => p.data.featured)
  .sort((a, b) => b.data.year - a.data.year);
const projects = featured.length >= 1 ? featured : allProjects
  .sort((a, b) => b.data.year - a.data.year);
---

<Layout title="Retail Design Experiences">
  <Navbar />

  <!-- ═══════════════════════════════════════
       HERO — 4:5 aspect ratio media container
  ═══════════════════════════════════════ -->
  <section class="hero">
    <div class="hero-media">
      {homepageData.hero_video
        ? <video autoplay muted loop playsinline class="hero-video"><source src={homepageData.hero_video} type="video/mp4" /></video>
        : <video autoplay muted loop playsinline class="hero-video"><source src="/hero.mp4" type="video/mp4" /></video>
      }
      {homepageData.hero_image
        ? <img src={homepageData.hero_image} alt="TNC.18 Retail Experiences" class="hero-img-fallback" />
        : <div class="hero-fallback"></div>
      }
      <div class="hero-overlay"></div>
    </div>

    <div class="hero-content">
      <p class="hero-location">Bangkok · Thailand</p>
      <h1 class="hero-title">RETAIL<br/>EXPERIENCES</h1>
      <div class="hero-rule"></div>
      <p class="hero-sub">Architecture · Retail Design · Interior</p>
    </div>

    <div class="hero-scroll-hint">
      <span class="scroll-line"></span>
      <span class="scroll-label">Scroll</span>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       PROJECTS — Stacked vertically, mobile-first
  ═══════════════════════════════════════ -->
  <section class="projects" id="work">
    <header class="section-header">
      <span class="section-label">Selected Work</span>
      <a href="/projects" class="link-all">All Projects →</a>
    </header>

    <div class="project-stack">
      {projects.map((p, i) => (
        <article class="project-card" data-reveal>
          <a href={`/projects/${p.id}`} class="project-link">

            <!-- Featured label -->
            <div class="card-label">
              <span class="label-dot"></span>
              Featured Project
            </div>

            <!-- Full-width image/video -->
            <div class="card-media">
              {p.data.cover && !p.data.cover.includes('placeholder')
                ? <img src={p.data.cover} alt={p.data.title} loading="lazy" class="card-img" />
                : <div class="card-ph"></div>
              }
              <div class="card-media-overlay">
                <span class="card-view">View Project →</span>
              </div>
            </div>

            <!-- Meta row -->
            <div class="card-meta">
              <span class="meta-item">
                <span class="meta-key">Category</span>
                <span class="meta-val">{p.data.category?.toUpperCase()}</span>
              </span>
              {p.data.location && (
                <span class="meta-sep">|</span>
                <span class="meta-item">
                  <span class="meta-key">Mall</span>
                  <span class="meta-val">{p.data.location?.toUpperCase()}</span>
                </span>
              )}
              {p.data.size && (
                <span class="meta-sep">|</span>
                <span class="meta-item">
                  <span class="meta-key">Size</span>
                  <span class="meta-val">{p.data.size?.toUpperCase()}</span>
                </span>
              )}
              <span class="meta-sep">|</span>
              <span class="meta-item">
                <span class="meta-key">Year</span>
                <span class="meta-val">{p.data.year}</span>
              </span>
            </div>

            <!-- Title row -->
            <div class="card-footer">
              <h2 class="card-title">{p.data.title?.toUpperCase()}</h2>
              <span class="card-arrow">→</span>
            </div>

          </a>
        </article>
      ))}

      <!-- Placeholder cards if fewer than 2 real projects -->
      {projects.length < 1 && (
        <article class="project-card" data-reveal>
          <a href="/admin" class="project-link">
            <div class="card-label"><span class="label-dot"></span>Featured Project</div>
            <div class="card-media"><div class="card-ph"></div></div>
            <div class="card-meta">
              <span class="meta-item"><span class="meta-key">Mall</span><span class="meta-val">SIAM PARAGON</span></span>
              <span class="meta-sep">|</span>
              <span class="meta-item"><span class="meta-key">Size</span><span class="meta-val">120 SQ.M</span></span>
            </div>
            <div class="card-footer">
              <h2 class="card-title">ADD YOUR FIRST PROJECT</h2>
              <span class="card-arrow">→</span>
            </div>
          </a>
        </article>
      )}
      {projects.length === 1 && (
        <article class="project-card" data-reveal>
          <a href="/admin" class="project-link">
            <div class="card-label"><span class="label-dot"></span>Featured Project</div>
            <div class="card-media"><div class="card-ph card-ph--2"></div></div>
            <div class="card-meta">
              <span class="meta-item"><span class="meta-key">Mall</span><span class="meta-val">CENTRAL EMBASSY</span></span>
              <span class="meta-sep">|</span>
              <span class="meta-item"><span class="meta-key">Size</span><span class="meta-val">85 SQ.M</span></span>
            </div>
            <div class="card-footer">
              <h2 class="card-title">ADD SECOND PROJECT</h2>
              <span class="card-arrow">→</span>
            </div>
          </a>
        </article>
      )}
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       ABOUT — Minimal strip
  ═══════════════════════════════════════ -->
  <section class="about" data-reveal>
    <div class="about-inner">
      <span class="about-label">About the Studio</span>
      <div class="about-body">
        <h2 class="about-title">WE DESIGN RETAIL<br/>SPACES THAT SELL.</h2>
        <p class="about-text">
          TNC.18 is a Bangkok-based boutique retail design agency. From pop-ups to flagship stores,
          we craft environments that convert foot traffic into loyal customers — through material,
          light, and spatial precision.
        </p>
        <a href="/about" class="about-link">Our Story →</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       SERVICES — Numbered list
  ═══════════════════════════════════════ -->
  <section class="services">
    <div class="services-inner">
      <span class="section-label">What We Do</span>
      <div class="svc-list">
        {(['Retail Interior Design', 'Pop-up & Exhibition Spaces', 'Brand Environment Strategy', 'Construction & Fitout', 'Visual Merchandising']).map((name, i) => (
          <a href="/services" class="svc-row" data-reveal>
            <span class="svc-n">0{i + 1}</span>
            <span class="svc-name">{name.toUpperCase()}</span>
            <span class="svc-arr">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       CTA
  ═══════════════════════════════════════ -->
  <section class="cta" data-reveal>
    <p class="cta-eyebrow">Start a Project</p>
    <h2 class="cta-title">HAVE A SPACE<br/>IN MIND?</h2>
    <a href="/contact" class="cta-btn">Get in Touch</a>
  </section>

  <!-- ═══════════════════════════════════════
       FOOTER — Dark charcoal
  ═══════════════════════════════════════ -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-brand">
        <span class="footer-logo">TNC<em>.</em>18</span>
        <p class="footer-sub">Retail Design Agency · Bangkok</p>
      </div>
      <nav class="footer-nav">
        <a href="tel:+66000000000">+66 00 000 0000</a>
        <a href="mailto:hello@tnc18.com">hello@tnc18.com</a>
        <a href="https://instagram.com" target="_blank" rel="noopener">Instagram</a>
        <a href="https://line.me" target="_blank" rel="noopener">Line OA</a>
      </nav>
      <p class="footer-copy">© 2025 TNC.18. All rights reserved.</p>
    </div>
  </footer>

</Layout>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  /* ─────────────────────────────────
     HERO
  ───────────────────────────────── */
  .hero {
    position: relative;
    width: 100%;
    /* 4:5 on mobile, unconstrained on desktop */
    aspect-ratio: 4 / 5;
    max-height: 100vh;
    min-height: 480px;
    overflow: hidden;
    background: var(--charcoal);
    margin-top: 68px; /* clear fixed navbar */
  }

  .hero-media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.55;
  }

  .hero-fallback {
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, #3a3530 0%, #1e1c18 100%);
  }

  .hero-img-fallback {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.55;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to top,  rgba(20,18,15,0.80) 0%, transparent 55%),
      linear-gradient(to bottom, rgba(20,18,15,0.35) 0%, transparent 40%);
  }

  .hero-content {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 2.5rem 1.75rem 3.5rem;
  }

  .hero-location {
    font-family: var(--font-body);
    font-size: 0.6rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: rgba(244, 240, 230, 0.45);
    margin-bottom: 1rem;
    animation: fadeUp 0.9s 0.2s both;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(2.75rem, 10vw, 6rem);
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--warm-white);
    line-height: 1.0;
    animation: slideUp 1.1s cubic-bezier(0.16, 1, 0.3, 1) 0.1s both;
  }

  .hero-rule {
    width: 36px;
    height: 1px;
    background: var(--gold);
    margin: 1.5rem 0 0.85rem;
    animation: lineIn 0.7s cubic-bezier(0.4, 0, 0.2, 1) 0.8s both;
    transform: scaleX(0);
    transform-origin: left;
  }

  .hero-sub {
    font-size: 0.6rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(244, 240, 230, 0.35);
    animation: fadeUp 0.8s 1s both;
  }

  .hero-scroll-hint {
    position: absolute;
    bottom: 2rem;
    right: 1.75rem;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    animation: fadeUp 0.8s 1.4s both;
  }

  .scroll-line {
    display: block;
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, rgba(181,154,125,0.8), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.4; }
    50%       { opacity: 1; }
  }

  .scroll-label {
    font-size: 0.5rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: rgba(181, 154, 125, 0.6);
    writing-mode: vertical-rl;
    transform: rotate(180deg);
  }

  @keyframes slideUp  { from { transform: translateY(60px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
  @keyframes fadeUp   { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes lineIn   { to   { transform: scaleX(1); } }

  /* ─────────────────────────────────
     PROJECTS
  ───────────────────────────────── */
  .projects {
    background: var(--cream);
    padding: 3.5rem 1.75rem;
    border-top: 1px solid var(--cream-dark);
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    border-bottom: 1px solid var(--cream-dark);
    padding-bottom: 0.85rem;
    margin-bottom: 2.5rem;
  }

  .section-label {
    font-family: var(--font-body);
    font-size: 0.58rem;
    font-weight: 500;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .link-all {
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    color: var(--charcoal);
    text-decoration: none;
    transition: color 0.3s;
  }

  .link-all:hover { color: var(--gold); }

  .project-stack {
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  /* Card */
  .project-card {
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.9s cubic-bezier(0.16,1,0.3,1), transform 0.9s cubic-bezier(0.16,1,0.3,1);
  }

  .project-card.revealed {
    opacity: 1;
    transform: translateY(0);
  }

  .project-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  /* Featured label */
  .card-label {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-body);
    font-size: 0.58rem;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.85rem;
  }

  .label-dot {
    display: block;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--gold);
    flex-shrink: 0;
  }

  /* Media */
  .card-media {
    position: relative;
    width: 100%;
    overflow: hidden;
    background: var(--cream-dark);
  }

  /* Keep natural image ratio; tall images stay tall */
  .card-img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 1.1s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .card-ph {
    width: 100%;
    aspect-ratio: 4 / 3;
    background: linear-gradient(135deg, #c8bfae 0%, #9e9085 100%);
    transition: transform 1.1s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .card-ph--2 {
    background: linear-gradient(135deg, #b5a99a 0%, #7a6e65 100%);
  }

  .project-link:hover .card-img,
  .project-link:hover .card-ph {
    transform: scale(1.04);
  }

  .card-media-overlay {
    position: absolute;
    inset: 0;
    background: rgba(20, 18, 15, 0.18);
    display: flex;
    align-items: flex-end;
    justify-content: flex-end;
    padding: 1.25rem;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .project-link:hover .card-media-overlay { opacity: 1; }

  .card-view {
    font-size: 0.6rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--warm-white);
    background: rgba(42, 40, 37, 0.7);
    padding: 0.4rem 0.85rem;
    backdrop-filter: blur(4px);
  }

  /* Meta row */
  .card-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 0.75rem;
    padding: 0.85rem 0;
    border-bottom: 1px solid var(--cream-dark);
    margin-top: 0;
  }

  .meta-item {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }

  .meta-key {
    font-size: 0.52rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 500;
  }

  .meta-val {
    font-size: 0.52rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--charcoal);
    font-weight: 500;
  }

  .meta-sep {
    color: var(--cream-dark);
    font-size: 0.7rem;
  }

  /* Card footer */
  .card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 0.85rem;
  }

  .card-title {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 4vw, 1.6rem);
    font-weight: 400;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--charcoal);
    line-height: 1.15;
  }

  .card-arrow {
    font-size: 1.1rem;
    color: var(--gold);
    transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1);
    flex-shrink: 0;
  }

  .project-link:hover .card-arrow { transform: translateX(6px); }

  /* ─────────────────────────────────
     ABOUT
  ───────────────────────────────── */
  .about {
    background: var(--cream-mid);
    border-top: 1px solid var(--cream-dark);
    border-bottom: 1px solid var(--cream-dark);
    padding: 4rem 1.75rem;
  }

  .about-inner {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    max-width: 640px;
  }

  .about-label {
    font-family: var(--font-body);
    font-size: 0.58rem;
    font-weight: 500;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    color: var(--gold);
  }

  .about-title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 6vw, 2.5rem);
    font-weight: 400;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--charcoal);
    line-height: 1.1;
  }

  .about-text {
    font-size: 0.875rem;
    line-height: 1.9;
    color: var(--ink);
    font-weight: 300;
    max-width: 480px;
  }

  .about-link {
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--charcoal);
    text-decoration: none;
    border-bottom: 1px solid var(--cream-dark);
    padding-bottom: 2px;
    display: inline-block;
    transition: color 0.3s, border-color 0.3s;
  }

  .about-link:hover { color: var(--gold); border-color: var(--gold); }

  /* ─────────────────────────────────
     SERVICES
  ───────────────────────────────── */
  .services {
    background: var(--cream);
    padding: 3.5rem 1.75rem;
  }

  .services-inner { max-width: 960px; margin: 0 auto; }
  .services .section-label { display: block; margin-bottom: 1.5rem; }

  .svc-list { border-top: 1px solid var(--cream-dark); }

  .svc-row {
    display: flex;
    align-items: center;
    padding: 1rem 0;
    border-bottom: 1px solid var(--cream-mid);
    text-decoration: none;
    color: inherit;
    position: relative;
    transition: padding-left 0.35s cubic-bezier(0.4,0,0.2,1);
    opacity: 0;
    transform: translateY(20px);
    transition:
      opacity 0.7s cubic-bezier(0.16,1,0.3,1),
      transform 0.7s cubic-bezier(0.16,1,0.3,1),
      padding-left 0.3s ease;
  }

  .svc-row.revealed {
    opacity: 1;
    transform: translateY(0);
  }

  .svc-row:hover { padding-left: 0.75rem; }

  .svc-n {
    font-size: 0.52rem;
    color: var(--gold);
    width: 2.5rem;
    flex-shrink: 0;
    letter-spacing: 0.12em;
    font-weight: 500;
  }

  .svc-name {
    font-family: var(--font-display);
    font-size: clamp(0.9rem, 3.5vw, 1.2rem);
    font-weight: 400;
    letter-spacing: 0.08em;
    color: var(--charcoal);
    flex: 1;
    transition: color 0.3s;
  }

  .svc-row:hover .svc-name { color: var(--gold); }

  .svc-arr {
    font-size: 0.8rem;
    color: var(--cream-dark);
    transition: transform 0.3s, color 0.3s;
  }

  .svc-row:hover .svc-arr { transform: translateX(4px); color: var(--gold); }

  /* ─────────────────────────────────
     CTA
  ───────────────────────────────── */
  .cta {
    background: var(--charcoal);
    padding: 5rem 1.75rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.9s cubic-bezier(0.16,1,0.3,1), transform 0.9s cubic-bezier(0.16,1,0.3,1);
  }

  .cta.revealed { opacity: 1; transform: translateY(0); }

  .cta-eyebrow {
    font-family: var(--font-body);
    font-size: 0.58rem;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 500;
  }

  .cta-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 8vw, 3.5rem);
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--warm-white);
    line-height: 1.05;
  }

  .cta-btn {
    display: inline-block;
    margin-top: 0.5rem;
    font-family: var(--font-body);
    font-size: 0.64rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--charcoal);
    background: var(--gold);
    text-decoration: none;
    padding: 0.9rem 2.5rem;
    transition: background 0.35s, color 0.35s;
  }

  .cta-btn:hover { background: var(--gold-light); }

  /* ─────────────────────────────────
     FOOTER — Dark charcoal
  ───────────────────────────────── */
  .footer {
    background: #1e1c19;
    border-top: 1px solid rgba(244, 240, 230, 0.05);
    padding: 2.5rem 1.75rem;
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .footer-logo {
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    color: rgba(244, 240, 230, 0.4);
    display: block;
    margin-bottom: 0.3rem;
  }

  .footer-logo em { font-style: normal; color: var(--gold); }

  .footer-sub {
    font-size: 0.55rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(244, 240, 230, 0.18);
    line-height: 1;
  }

  .footer-nav {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .footer-nav a {
    font-family: var(--font-body);
    font-size: 0.62rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(244, 240, 230, 0.28);
    text-decoration: none;
    transition: color 0.3s;
    display: inline-block;
  }

  .footer-nav a:hover { color: var(--gold); }

  .footer-copy {
    font-size: 0.52rem;
    color: rgba(244, 240, 230, 0.12);
    letter-spacing: 0.1em;
    line-height: 1;
  }

  /* ─────────────────────────────────
     DESKTOP ADJUSTMENTS
  ───────────────────────────────── */
  @media (min-width: 768px) {
    .hero {
      aspect-ratio: unset;
      height: 100vh;
      margin-top: 68px;
    }

    .hero-content { padding: 0 5rem 4.5rem; }
    .hero-scroll-hint { right: 3rem; }

    .projects { padding: 5rem; }
    .about    { padding: 5rem; }
    .services { padding: 5rem; }
    .cta      { padding: 7rem 5rem; }
    .footer   { padding: 3rem 5rem; }

    .footer-inner {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 1rem;
    }

    .footer-nav { flex-direction: row; gap: 2rem; }

    .project-stack { gap: 5.5rem; }

    .about-inner { flex-direction: row; gap: 4rem; align-items: flex-start; }
    .about-label { writing-mode: vertical-rl; transform: rotate(180deg); flex-shrink: 0; padding-top: 0.25rem; }
  }

  @media (min-width: 1100px) {
    .card-title { font-size: 1.75rem; }
  }
</style>

<script>
  /* ── Reveal on scroll ── */
  const io = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      entry.target.classList.add('revealed');
      io.unobserve(entry.target);
    });
  }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });

  document.querySelectorAll('[data-reveal]').forEach(el => io.observe(el));

  /* ── Language toggle (preserve existing behaviour) ── */
  function applyLang(lang: string) {
    localStorage.setItem('tnc-lang', lang);
    document.documentElement.setAttribute('data-lang', lang);
    document.getElementById('lang-en')?.classList.toggle('active', lang === 'en');
    document.getElementById('lang-th')?.classList.toggle('active', lang === 'th');
  }
  applyLang(localStorage.getItem('tnc-lang') || 'en');
  document.getElementById('lang-toggle')?.addEventListener('click', () => {
    applyLang(
      (document.documentElement.getAttribute('data-lang') || 'en') === 'en' ? 'th' : 'en'
    );
  });
</script>
