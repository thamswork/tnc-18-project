---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import contactData from '../content/settings/contact.json';
import pageData    from '../content/pages/contact.json';
---

<Layout title="Contact — TNC.18">
  <Navbar />

  <main class="main">

    <!-- Headline -->
    <section class="head" data-reveal>
      <h1 class="head-title">{pageData.headline.toUpperCase()}</h1>
      {pageData.subtext && <p class="head-sub">{pageData.subtext}</p>}
      {pageData.promise && (
        <p class="head-promise">
          <span class="promise-dot"></span>
          {pageData.promise}
        </p>
      )}
    </section>

    <!-- Line OA — primary -->
    {contactData.line && (
      <section class="primary" data-reveal>
        <span class="s-label">Primary Contact</span>
        <a href={contactData.line} target="_blank" rel="noopener" class="line-cta">
          <span class="line-dot"></span>
          {pageData.line_label || 'Message us on Line'}
        </a>
        <p class="line-note">{pageData.promise || 'Fastest response guaranteed.'}</p>
      </section>
    )}

    <!-- Social links -->
    <section class="socials" data-reveal>
      <span class="s-label">Also Find Us</span>
      <div class="social-list">
        {contactData.instagram && (
          <a href={contactData.instagram} target="_blank" rel="noopener" class="social-row">
            <span class="social-platform">Instagram</span>
            <span class="social-handle">
              {contactData.instagram.replace('https://instagram.com/','@').replace('https://www.instagram.com/','@')}
            </span>
            <span class="social-arr">→</span>
          </a>
        )}
        {contactData.tiktok && (
          <a href={contactData.tiktok} target="_blank" rel="noopener" class="social-row">
            <span class="social-platform">TikTok</span>
            <span class="social-handle">
              {contactData.tiktok.replace('https://tiktok.com/','').replace('https://www.tiktok.com/','')}
            </span>
            <span class="social-arr">→</span>
          </a>
        )}
        {contactData.email && (
          <a href={`mailto:${contactData.email}`} class="social-row">
            <span class="social-platform">Email</span>
            <span class="social-handle">{contactData.email}</span>
            <span class="social-arr">→</span>
          </a>
        )}
        {contactData.phone && (
          <a href={`tel:${contactData.phone.replace(/\s/g,'')}`} class="social-row">
            <span class="social-platform">Phone</span>
            <span class="social-handle">{contactData.phone}</span>
            <span class="social-arr">→</span>
          </a>
        )}
      </div>
    </section>

  </main>

  <footer class="site-footer">
    <div class="site-footer-inner">
      <div>
        <span class="site-footer-logo">TNC<em>.</em>18</span>
        <p class="site-footer-sub">Retail & Interior Design · Bangkok</p>
      </div>
      <p class="site-footer-copy">© {new Date().getFullYear()} TNC.18.</p>
    </div>
  </footer>
</Layout>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  .main {
    padding-top: 64px; background: var(--bg);
    min-height: 100vh; display: flex; flex-direction: column;
  }

  /* Headline */
  .head { padding: var(--section) var(--pad-x) 0; }
  .head-title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 12vw, 7rem);
    font-weight: 400; letter-spacing: 0.04em;
    color: var(--ink); line-height: 0.95;
    margin-bottom: 1.5rem;
  }
  .head-sub {
    font-size: 1rem; line-height: 1.85;
    color: var(--ink-mid); font-weight: 300;
    max-width: 480px; margin-bottom: 1rem;
  }
  .head-promise {
    display: flex; align-items: center; gap: 0.55rem;
    font-family: var(--font-mono); font-size: 0.58rem;
    letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--navy); font-weight: 400;
  }
  .promise-dot {
    display: block; width: 6px; height: 6px;
    border-radius: 50%; background: var(--line-green); flex-shrink: 0;
  }

  /* Primary Line CTA */
  .primary {
    padding: var(--section) var(--pad-x) 0;
    display: flex; flex-direction: column; gap: 1.25rem;
    align-items: flex-start;
  }
  .line-cta {
    display: inline-flex; align-items: center; gap: 0.65rem;
    font-family: var(--font-body); font-size: 0.72rem;
    font-weight: 500; letter-spacing: 0.14em;
    text-transform: uppercase; text-decoration: none;
    color: var(--navy, #1A3A6B); background: transparent;
    padding: 1.1rem 2.25rem;
    border: 1.5px solid var(--navy, #1A3A6B);
    transition: background 0.25s, color 0.25s, transform 0.15s;
    white-space: nowrap;
  }
  .line-cta:hover { background: var(--navy, #1A3A6B); color: #F8F7F4; }
  .line-cta:active { transform: scale(0.98); }
  .line-note {
    font-family: var(--font-mono); font-size: 0.52rem;
    letter-spacing: 0.14em; color: var(--ink-light);
  }

  /* Social list */
  .socials {
    padding: var(--section) var(--pad-x) 0;
    display: flex; flex-direction: column; gap: 1.5rem;
    margin-bottom: var(--section);
  }
  .social-list { display: flex; flex-direction: column; }
  .social-row {
    display: flex; align-items: center; gap: 1rem;
    padding: 1.1rem 0;
    border-bottom: 0.5px solid rgba(26,26,26,0.07);
    text-decoration: none; color: inherit;
    transition: padding-left 0.2s;
  }
  .social-row:hover { padding-left: 0.5rem; }
  .social-platform {
    font-family: var(--font-mono); font-size: 0.52rem;
    letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--ink-light); width: 90px; flex-shrink: 0;
  }
  .social-handle {
    font-family: var(--font-display); font-size: 1rem;
    color: var(--ink); flex: 1;
    transition: color 0.2s;
  }
  .social-row:hover .social-handle { color: var(--navy); }
  .social-arr {
    font-size: 0.9rem; color: var(--navy); flex-shrink: 0;
    transition: transform 0.2s;
  }
  .social-row:hover .social-arr { transform: translateX(4px); }

  @media (min-width: 768px) {
    .social-list { display: grid; grid-template-columns: repeat(2,1fr); }
  }
</style>

<script>
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (!e.isIntersecting) return;
      e.target.classList.add('revealed');
      io.unobserve(e.target);
    });
  }, { threshold: 0.06 });
  document.querySelectorAll('[data-reveal]').forEach(el => io.observe(el));
</script>
