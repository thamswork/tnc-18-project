---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import contactData from '../content/settings/contact.json';
import pageData    from '../content/pages/contact.json';

const igHandle = (contactData.instagram || '')
  .replace('https://www.instagram.com/','@')
  .replace('https://instagram.com/','@');

const ttHandle = (contactData.tiktok || '')
  .replace('https://www.tiktok.com/','')
  .replace('https://tiktok.com/','');
---

<Layout title="Contact — TNC.18">
  <Navbar />

  <main class="contact-main">

    <div class="contact-grid">

      <!-- LEFT: headline + Line CTA -->
      <div class="contact-left">
        <div class="contact-left-inner" data-reveal>
          <p class="contact-eyebrow">Get In Touch</p>
          <h1 class="contact-title">{pageData.headline.toUpperCase()}</h1>
          {pageData.subtext && (
            <p class="contact-sub">{pageData.subtext}</p>
          )}

          {contactData.line && (
            <a href={contactData.line} target="_blank" rel="noopener" class="btn-line">
              <span class="line-dot"></span>
              {pageData.line_label || 'Message us on Line'}
            </a>
          )}

          {pageData.promise && (
            <p class="contact-promise">
              <span class="promise-dot"></span>
              {pageData.promise}
            </p>
          )}
        </div>
      </div>

      <!-- RIGHT: dark navy contact channels -->
      <div class="contact-right">
        <div class="contact-right-inner" data-reveal-fade>

          <p class="right-label">Also Find Us</p>

          <div class="channel-list">

            {contactData.instagram && (
              <a href={contactData.instagram} target="_blank" rel="noopener" class="channel-row">
                <div class="channel-meta">
                  <span class="channel-platform">Instagram</span>
                  <span class="channel-handle">{igHandle}</span>
                </div>
                <span class="channel-arr">→</span>
              </a>
            )}

            {contactData.tiktok && (
              <a href={contactData.tiktok} target="_blank" rel="noopener" class="channel-row">
                <div class="channel-meta">
                  <span class="channel-platform">TikTok</span>
                  <span class="channel-handle">{ttHandle}</span>
                </div>
                <span class="channel-arr">→</span>
              </a>
            )}

            {contactData.facebook && (
              <a href={contactData.facebook} target="_blank" rel="noopener" class="channel-row">
                <div class="channel-meta">
                  <span class="channel-platform">Facebook</span>
                  <span class="channel-handle">TNC.18</span>
                </div>
                <span class="channel-arr">→</span>
              </a>
            )}

            {contactData.email && (
              <a href={`mailto:${contactData.email}`} class="channel-row">
                <div class="channel-meta">
                  <span class="channel-platform">Email</span>
                  <span class="channel-handle">{contactData.email}</span>
                </div>
                <span class="channel-arr">→</span>
              </a>
            )}

            {contactData.phone && (
              <a href={`tel:${contactData.phone.replace(/\s/g,'')}`} class="channel-row">
                <div class="channel-meta">
                  <span class="channel-platform">Phone</span>
                  <span class="channel-handle">{contactData.phone}</span>
                </div>
                <span class="channel-arr">→</span>
              </a>
            )}

          </div>

          <!-- Studio address block -->
          <div class="studio-block">
            <p class="studio-label">Studio</p>
            <p class="studio-address">Bangkok, Thailand</p>
            <p class="studio-hours">Mon – Sat · 09:00 – 18:00</p>
          </div>

        </div>
      </div>

    </div>

  </main>

  <Footer />
</Layout>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  .contact-main {
    padding-top: 64px;
    min-height: calc(100vh - 64px);
    background: var(--bg, #F8F7F4);
  }

  /* ── SPLIT GRID ── */
  .contact-grid {
    display: flex;
    flex-direction: column;
    min-height: calc(100vh - 64px);
  }

  /* ── LEFT ── */
  .contact-left {
    background: var(--bg, #F8F7F4);
    display: flex;
    align-items: center;
    padding: 5rem var(--pad-x, 5vw);
  }

  .contact-left-inner {
    max-width: 520px;
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .contact-eyebrow {
    font-family: 'Courier New', monospace;
    font-size: 0.55rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--navy, #1A3A6B);
  }

  .contact-title {
    font-family: var(--font-display, 'Tenor Sans', serif);
    font-size: clamp(3rem, 8vw, 5.5rem);
    font-weight: 400;
    letter-spacing: 0.03em;
    color: var(--ink, #1A1A1A);
    line-height: 0.95;
  }

  .contact-sub {
    font-size: 0.95rem;
    line-height: 1.9;
    color: var(--ink-mid, #4A4A4A);
    font-weight: 300;
    max-width: 400px;
  }

  .btn-line {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--navy, #1A3A6B);
    background: transparent;
    padding: 1rem 2rem;
    border: 1.5px solid var(--navy, #1A3A6B);
    transition: background 0.25s, color 0.25s;
    align-self: flex-start;
  }
  .btn-line:hover { background: var(--navy, #1A3A6B); color: #F8F7F4; }

  .line-dot {
    display: block;
    width: 7px; height: 7px;
    border-radius: 50%;
    background: #06C755;
    flex-shrink: 0;
  }

  .contact-promise {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Courier New', monospace;
    font-size: 0.52rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-light, #6B6B6B);
  }

  .promise-dot {
    display: block;
    width: 5px; height: 5px;
    border-radius: 50%;
    background: #06C755;
    flex-shrink: 0;
  }

  /* ── RIGHT ── */
  .contact-right {
    background: var(--navy-deep, #0E2140);
    display: flex;
    align-items: flex-start;
    padding: 5rem var(--pad-x, 5vw);
  }

  .contact-right-inner {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .right-label {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 0.68rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(248,247,244,0.45);
    font-weight: 500;
  }

  /* Channel rows */
  .channel-list {
    display: flex;
    flex-direction: column;
  }

  .channel-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 0;
    border-bottom: 0.5px solid rgba(248,247,244,0.08);
    text-decoration: none;
    color: inherit;
    transition: padding-left 0.2s;
  }
  .channel-row:first-child { border-top: 0.5px solid rgba(248,247,244,0.08); }
  .channel-row:hover { padding-left: 0.5rem; }

  .channel-meta {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .channel-platform {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 0.65rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(248,247,244,0.5);
    font-weight: 500;
  }

  .channel-handle {
    font-family: var(--font-display, 'Tenor Sans', serif);
    font-size: clamp(1.25rem, 2.5vw, 1.65rem);
    color: #F8F7F4;
    font-weight: 400;
    letter-spacing: 0.02em;
    transition: color 0.2s;
  }
  .channel-row:hover .channel-handle { color: #F8F7F4; }

  .channel-arr {
    font-size: 1rem;
    color: rgba(248,247,244,0.25);
    transition: transform 0.2s, color 0.2s;
    flex-shrink: 0;
  }
  .channel-row:hover .channel-arr { transform: translateX(5px); color: rgba(248,247,244,0.7); }

  /* Studio block */
  .studio-block {
    padding-top: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .studio-label {
    font-family: 'Courier New', monospace;
    font-size: 0.48rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(248,247,244,0.3);
    margin-bottom: 0.25rem;
  }

  .studio-address {
    font-family: var(--font-display, 'Tenor Sans', serif);
    font-size: 1.1rem;
    color: rgba(248,247,244,0.85);
  }

  .studio-hours {
    font-family: 'Courier New', monospace;
    font-size: 0.52rem;
    letter-spacing: 0.14em;
    color: rgba(248,247,244,0.25);
  }



  /* ── DESKTOP: true split ── */
  @media (min-width: 768px) {
    .contact-grid {
      flex-direction: row;
      min-height: calc(100vh - 64px);
    }
    .contact-left {
      flex: 1;
      padding: 8rem 6vw 8rem 8vw;
      align-items: center;
    }
    .contact-right {
      width: 42%;
      flex-shrink: 0;
      padding: 8rem 6vw 8rem 5vw;
      align-items: flex-start;
      min-height: 100%;
    }
  }

  /* ── ANIMATIONS ── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(28px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  [data-reveal] { opacity: 0; transform: translateY(28px); }
  [data-reveal].revealed {
    animation: fadeUp 0.75s cubic-bezier(0.4,0,0.2,1) forwards;
  }
  [data-reveal-fade] { opacity: 0; }
  [data-reveal-fade].revealed {
    animation: fadeIn 0.9s ease forwards;
  }

  .channel-row {
    opacity: 0;
    transform: translateX(16px);
    transition: opacity 0.5s ease, transform 0.5s ease, padding-left 0.2s;
  }
  .channel-row.visible {
    opacity: 1;
    transform: translateX(0);
  }

</style>

<script>
  // Reveal blocks
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (!e.isIntersecting) return;
      e.target.classList.add('revealed');
      io.unobserve(e.target);
    });
  }, { threshold: 0.06 });
  document.querySelectorAll('[data-reveal], [data-reveal-fade]').forEach(el => io.observe(el));

  // Stagger channel rows
  const rows = document.querySelectorAll('.channel-row');
  const rowObs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (!e.isIntersecting) return;
      const i = Array.from(rows).indexOf(e.target);
      setTimeout(() => e.target.classList.add('visible'), i * 90);
      rowObs.unobserve(e.target);
    });
  }, { threshold: 0.1 });
  rows.forEach(r => rowObs.observe(r));
</script>
