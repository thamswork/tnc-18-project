---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';
import contactData from '../content/settings/contact.json';
import pageData    from '../content/pages/contact.json';

const allProjects = await getCollection('projects');
const projects = allProjects.sort((a, b) => b.data.year - a.data.year);
const featured = projects[0] || null;

const igHandle = (contactData.instagram || '').replace('https://www.instagram.com/','@').replace('https://instagram.com/','@');
const ttHandle = (contactData.tiktok || '').replace('https://www.tiktok.com/','').replace('https://tiktok.com/','');
const LINE_ICON = 'https://res.cloudinary.com/dynjnftnu/image/upload/v1776531320/LINE_Brand_icon_2_ytuls0.png';

// Hero priority: video > hero_images list > hero_image single > portfolio pick > latest project
const pd = pageData as any;
const heroVideo = pd.hero_video || null;

const heroImages = pd.hero_images || [];
const firstPhoto = heroImages.length > 0
  ? (typeof heroImages[0] === 'string' ? heroImages[0] : heroImages[0]?.image || null)
  : null;

const singlePhoto = pd.hero_image || null;

const pickedProject = pd.hero_project
  ? allProjects.find(p => p.data.title === pd.hero_project) || null
  : null;

let heroSrc: string | null = null;
if (!heroVideo) {
  if (firstPhoto)                      heroSrc = firstPhoto;
  else if (singlePhoto)                heroSrc = singlePhoto;
  else if (pickedProject?.data?.cover) heroSrc = pickedProject.data.cover;
  else if (featured?.data?.cover)      heroSrc = featured.data.cover;
}
---

<Layout title="Contact — TNC.18">
  <Navbar />

  <main class="contact-page">

    {heroVideo
      ? <video autoplay muted loop playsinline class="bg-img"><source src={heroVideo} type="video/mp4" /></video>
      : heroSrc
        ? <img src={heroSrc} alt="" class="bg-img" loading="eager" />
        : null
    }
    <div class="bg-veil"></div>

    <div class="page-content">

      <div class="top-bar">
        <span class="brand-tag">Retail & Interior Design · Bangkok</span>
      </div>

      <div class="bottom-content">
        <div class="contact-left">
          <h1 class="contact-title">{pageData.headline.toUpperCase()}</h1>
          <p class="contact-sub">{pageData.subtext}</p>
          {contactData.line && (
            <a href={contactData.line} target="_blank" rel="noopener" class="line-btn">
              <img src={LINE_ICON} alt="LINE" class="line-ico" />
              {pageData.line_label || 'Message us on Line'}
            </a>
          )}
          {pageData.promise && (
            <p class="promise"><span class="dot"></span>{pageData.promise}</p>
          )}
        </div>

        <div class="contact-right">
          {contactData.instagram && (
            <a href={contactData.instagram} target="_blank" rel="noopener" class="ch">
              <span class="ch-plat">Instagram</span>
              <span class="ch-handle">{igHandle}</span>
            </a>
          )}
          {contactData.tiktok && (
            <a href={contactData.tiktok} target="_blank" rel="noopener" class="ch">
              <span class="ch-plat">TikTok</span>
              <span class="ch-handle">{ttHandle}</span>
            </a>
          )}
          {contactData.facebook && (
            <a href={contactData.facebook} target="_blank" rel="noopener" class="ch">
              <span class="ch-plat">Facebook</span>
              <span class="ch-handle">TNC.18</span>
            </a>
          )}
          {contactData.email && (
            <a href={`mailto:${contactData.email}`} class="ch">
              <span class="ch-plat">Email</span>
              <span class="ch-handle">{contactData.email}</span>
            </a>
          )}
          {contactData.phone && (
            <a href={`tel:${contactData.phone.replace(/\s/g,'')}`} class="ch">
              <span class="ch-plat">Phone</span>
              <span class="ch-handle">{contactData.phone}</span>
            </a>
          )}
          <div class="studio">
            <span class="ch-plat">Studio</span>
            <span class="ch-handle">Bangkok, Thailand</span>
            <span class="studio-hrs">Mon – Sat · 09:00 – 18:00</span>
          </div>
        </div>
      </div>

    </div>
  </main>

  <Footer hideCta={true} />
</Layout>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  .contact-page {
    position: relative;
    width: 100%;
    min-height: 100vh;
    overflow: hidden;
    background: #0a0e18;
  }

  .bg-img {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    z-index: 0;
  }

  .bg-veil {
    position: fixed;
    inset: 0;
    z-index: 1;
    background: rgba(6,8,14,0.6);
  }

  .page-content {
    position: relative;
    z-index: 2;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 5.5rem var(--pad-x, 5vw) 4rem;
  }

  .top-bar {
    display: flex;
    justify-content: flex-end;
  }

  .brand-tag {
    font-family: 'Courier New', monospace;
    font-size: 0.55rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.45);
  }

  .bottom-content {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .contact-title {
    font-family: var(--font-display, 'Tenor Sans', serif);
    font-size: clamp(2.5rem, 7vw, 5.5rem);
    font-weight: 400;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #fff;
    line-height: 0.95;
    margin-bottom: 1.25rem;
    text-shadow: 0 2px 24px rgba(0,0,0,0.5);
  }

  .contact-sub {
    font-size: 0.9rem;
    line-height: 1.85;
    color: rgba(255,255,255,0.82);
    font-weight: 300;
    max-width: 420px;
    margin-bottom: 2rem;
  }

  .line-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    text-decoration: none;
    color: #fff;
    padding: 1rem 2rem;
    border: 1.5px solid rgba(255,255,255,0.55);
    transition: background 0.25s, border-color 0.25s;
    margin-bottom: 1rem;
  }
  .line-btn:hover { background: rgba(255,255,255,0.12); border-color: #fff; }
  .line-ico { width: 22px; height: 22px; object-fit: contain; border-radius: 4px; }

  .promise {
    display: flex; align-items: center; gap: 0.5rem;
    font-family: 'Courier New', monospace;
    font-size: 0.52rem; letter-spacing: 0.18em;
    text-transform: uppercase; color: rgba(255,255,255,0.6);
  }
  .dot { display: block; width: 5px; height: 5px; border-radius: 50%; background: #06C755; flex-shrink: 0; }

  .contact-right { display: flex; flex-direction: column; gap: 0; }

  .ch {
    display: flex; flex-direction: column; gap: 0.15rem;
    padding: 0.85rem 0;
    border-bottom: 0.5px solid rgba(255,255,255,0.12);
    text-decoration: none; color: inherit;
    transition: padding-left 0.2s;
  }
  .ch:first-child { border-top: 0.5px solid rgba(255,255,255,0.12); }
  .ch:hover { padding-left: 0.4rem; }

  .ch-plat {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 0.55rem; letter-spacing: 0.18em;
    text-transform: uppercase; color: rgba(255,255,255,0.55); font-weight: 500;
  }

  .ch-handle {
    font-family: var(--font-display, 'Tenor Sans', serif);
    font-size: clamp(0.95rem, 1.8vw, 1.25rem);
    color: rgba(255,255,255,0.95);
    transition: color 0.2s;
  }
  .ch:hover .ch-handle { color: #fff; }

  .studio { display: flex; flex-direction: column; gap: 0.15rem; padding-top: 1rem; }
  .studio-hrs {
    font-family: 'Courier New', monospace;
    font-size: 0.5rem; letter-spacing: 0.14em; color: rgba(255,255,255,0.4);
  }

  /* MOBILE */
  @media (max-width: 767px) {
    .page-content { padding: 5rem 6vw 3rem; justify-content: space-between; }
    .contact-title { font-size: 2.2rem; margin-bottom: 0.85rem; }
    .contact-sub { font-size: 0.82rem; margin-bottom: 1.25rem; }
    .line-btn { width: 100%; justify-content: center; margin-bottom: 0.75rem; }
    .bottom-content { gap: 1.5rem; }
    .contact-right { display: grid; grid-template-columns: 1fr 1fr; gap: 0; }
    .ch { padding: 0.75rem 0.5rem 0.75rem 0; }
    .ch:nth-child(2) { border-top: 0.5px solid rgba(255,255,255,0.12); }
    .studio { grid-column: 1 / -1; border-top: 0.5px solid rgba(255,255,255,0.12); padding-top: 0.85rem; }
  }

  /* DESKTOP */
  @media (min-width: 768px) {
    .bottom-content { flex-direction: row; align-items: flex-end; gap: 8rem; }
    .contact-left { flex: 1; }
    .contact-right { width: 36%; flex-shrink: 0; }
  }

  @media (min-width: 1200px) {
    .page-content { padding: 6rem 10vw 5rem; }
    .bottom-content { gap: 10rem; }
  }
</style>
