---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';
import contactData from '../content/settings/contact.json';
import pageData    from '../content/pages/contact.json';

const allProjects = await getCollection('projects');
const projects = allProjects.sort((a, b) => b.data.year - a.data.year);
const featured = projects[0] || null;

function slug(t: string) {
  return t.toLowerCase().replace(/[\u2018\u2019'']/g, '').replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
}

const igHandle = (contactData.instagram || '')
  .replace('https://www.instagram.com/','@')
  .replace('https://instagram.com/','@');

const ttHandle = (contactData.tiktok || '')
  .replace('https://www.tiktok.com/','')
  .replace('https://tiktok.com/','');

const LINE_ICON = 'https://res.cloudinary.com/dynjnftnu/image/upload/v1776531320/LINE_Brand_icon_2_ytuls0.png';
---

<Layout title="Contact — TNC.18">
  <Navbar />

  <main class="contact-main">

    <!-- ── FEATURED PROJECT — full bleed ── -->
    {featured && (
      <a href={`/portfolio/${slug(featured.data.title)}`} class="feat-wrap">
        {featured.data.cover
          ? <img src={featured.data.cover} alt={featured.data.title} class="feat-img" loading="eager" />
          : <div class="feat-ph"></div>
        }
        <div class="feat-veil"></div>
        <div class="feat-content">
          <div class="feat-top">
            <span class="feat-cat">{featured.data.category}</span>
            {featured.data.year && <span class="feat-yr">{featured.data.year}</span>}
          </div>
          <div class="feat-bot">
            {featured.data.location && <p class="feat-loc">{featured.data.location}</p>}
            <h2 class="feat-title">{featured.data.title}</h2>
            <span class="feat-cta">View Project →</span>
          </div>
        </div>
      </a>
    )}

    <!-- ── CONTACT SPLIT ── -->
    <div class="contact-grid">

      <!-- LEFT -->
      <div class="contact-left">
        <div class="contact-left-inner" data-reveal>
          <p class="contact-eyebrow">Get In Touch</p>
          <h1 class="contact-title">{pageData.headline.toUpperCase()}</h1>
          {pageData.subtext && <p class="contact-sub">{pageData.subtext}</p>}

          {contactData.line && (
            <a href={contactData.line} target="_blank" rel="noopener" class="btn-line">
              <img src={LINE_ICON} alt="LINE" class="line-icon" />
              {pageData.line_label || 'Message us on Line'}
            </a>
          )}

          {pageData.promise && (
            <p class="contact-promise">
              <span class="promise-dot"></span>
              {pageData.promise}
            </p>
          )}
        </div>
      </div>

      <!-- RIGHT -->
      <div class="contact-right">
        <div class="contact-right-inner" data-reveal-fade>
          <p class="right-label">Also Find Us</p>
          <div class="channel-list">
            {contactData.instagram && (
              <a href={contactData.instagram} target="_blank" rel="noopener" class="channel-row">
                <div class="channel-meta">
                  <span class="channel-platform">Instagram</span>
                  <span class="channel-handle">{igHandle}</span>
                </div>
                <span class="channel-arr">→</span>
              </a>
            )}
            {contactData.tiktok && (
              <a href={contactData.tiktok} target="_blank" rel="noopener" class="channel-row">
                <div class="channel-meta">
                  <span class="channel-platform">TikTok</span>
                  <span class="channel-handle">{ttHandle}</span>
                </div>
                <span class="channel-arr">→</span>
              </a>
            )}
            {contactData.facebook && (
              <a href={contactData.facebook} target="_blank" rel="noopener" class="channel-row">
                <div class="channel-meta">
                  <span class="channel-platform">Facebook</span>
                  <span class="channel-handle">TNC.18</span>
                </div>
                <span class="channel-arr">→</span>
              </a>
            )}
            {contactData.email && (
              <a href={`mailto:${contactData.email}`} class="channel-row">
                <div class="channel-meta">
                  <span class="channel-platform">Email</span>
                  <span class="channel-handle">{contactData.email}</span>
                </div>
                <span class="channel-arr">→</span>
              </a>
            )}
            {contactData.phone && (
              <a href={`tel:${contactData.phone.replace(/\s/g,'')}`} class="channel-row">
                <div class="channel-meta">
                  <span class="channel-platform">Phone</span>
                  <span class="channel-handle">{contactData.phone}</span>
                </div>
                <span class="channel-arr">→</span>
              </a>
            )}
          </div>

          <div class="studio-block">
            <p class="studio-label">Studio</p>
            <p class="studio-address">Bangkok, Thailand</p>
            <p class="studio-hours">Mon – Sat · 09:00 – 18:00</p>
          </div>
        </div>
      </div>

    </div>

  </main>

  <Footer hideCta={true} />
</Layout>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  .contact-main {
    padding-top: 72px;
    background: var(--bg, #F8F7F4);
  }

  /* ── FEATURED PROJECT ── */
  .feat-wrap {
    display: block;
    position: relative;
    width: 100%;
    height: 60vh;
    overflow: hidden;
    text-decoration: none;
    background: #0a0e18;
  }

  .feat-img {
    width: 100%; height: 100%;
    object-fit: cover; display: block;
    transition: transform 1.4s cubic-bezier(0.4,0,0.2,1);
  }
  .feat-wrap:hover .feat-img { transform: scale(1.03); }

  .feat-ph { width: 100%; height: 100%; background: #1a2a3e; }

  .feat-veil {
    position: absolute; inset: 0;
    background:
      linear-gradient(to top, rgba(4,6,10,0.75) 0%, rgba(4,6,10,0.1) 45%, rgba(4,6,10,0.05) 100%);
  }

  .feat-content {
    position: absolute; inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 2rem var(--pad-x, 5vw);
  }

  .feat-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
  }

  .feat-brand {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 1rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(248,247,244,0.9);
    text-decoration: none;
  }
  .feat-brand em { font-style: normal; color: #fff; }

  .feat-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .feat-outer { position: relative; }

  .feat-cat {
    font-family: 'Courier New', monospace;
    font-size: 0.52rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: rgba(248,247,244,0.6);
    background: rgba(4,6,10,0.45);
    padding: 0.3rem 0.75rem;
  }

  .feat-yr {
    font-family: 'Courier New', monospace;
    font-size: 0.52rem;
    letter-spacing: 0.14em;
    color: rgba(248,247,244,0.35);
  }

  .feat-bot {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-bottom: 0.5rem;
  }

  .feat-loc {
    font-family: 'Courier New', monospace;
    font-size: 0.55rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(248,247,244,0.45);
  }

  .feat-title {
    font-family: var(--font-display, 'Tenor Sans', serif);
    font-size: clamp(1.5rem, 4vw, 3rem);
    font-weight: 400;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #F8F7F4;
    line-height: 1.05;
    max-width: 700px;
  }

  .feat-cta {
    font-family: 'Courier New', monospace;
    font-size: 0.58rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(248,247,244,0.5);
    transition: color 0.2s;
  }
  .feat-wrap:hover .feat-cta { color: #F8F7F4; }

  /* ── SPLIT GRID ── */
  .contact-grid {
    display: flex;
    flex-direction: column;
  }

  .contact-left {
    background: var(--bg, #F8F7F4);
    display: flex;
    align-items: center;
    padding: 4rem var(--pad-x, 5vw);
  }

  .contact-left-inner {
    max-width: 520px;
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .contact-eyebrow {
    font-family: 'Courier New', monospace;
    font-size: 0.55rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--navy, #1A3A6B);
  }

  .contact-title {
    font-family: var(--font-display, 'Tenor Sans', serif);
    font-size: clamp(2.5rem, 7vw, 5rem);
    font-weight: 400;
    letter-spacing: 0.03em;
    color: var(--ink, #1A1A1A);
    line-height: 0.95;
  }

  .contact-sub {
    font-size: 0.92rem;
    line-height: 1.9;
    color: var(--ink-mid, #4A4A4A);
    font-weight: 300;
    max-width: 400px;
  }

  .btn-line {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--navy, #1A3A6B);
    background: transparent;
    padding: 1rem 2rem;
    border: 1.5px solid var(--navy, #1A3A6B);
    transition: background 0.25s, color 0.25s;
    align-self: flex-start;
  }
  .btn-line:hover { background: var(--navy, #1A3A6B); color: #F8F7F4; }

  .line-icon {
    width: 22px; height: 22px;
    object-fit: contain;
    border-radius: 4px;
    flex-shrink: 0;
  }

  .contact-promise {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Courier New', monospace;
    font-size: 0.52rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-light, #6B6B6B);
  }

  .promise-dot {
    display: block;
    width: 5px; height: 5px;
    border-radius: 50%;
    background: #06C755;
    flex-shrink: 0;
  }

  .contact-right {
    background: var(--navy-deep, #0E2140);
    display: flex;
    align-items: flex-start;
    padding: 4rem var(--pad-x, 5vw);
  }

  .contact-right-inner {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .right-label {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(248,247,244,0.4);
    font-weight: 500;
  }

  .channel-list { display: flex; flex-direction: column; }

  .channel-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.1rem 0;
    border-bottom: 0.5px solid rgba(248,247,244,0.08);
    text-decoration: none;
    color: inherit;
    opacity: 0;
    transform: translateX(16px);
    transition: opacity 0.5s ease, transform 0.5s ease, padding-left 0.2s;
  }
  .channel-row:first-child { border-top: 0.5px solid rgba(248,247,244,0.08); }
  .channel-row.visible { opacity: 1; transform: translateX(0); }
  .channel-row:hover { padding-left: 0.5rem; }

  .channel-meta { display: flex; flex-direction: column; gap: 0.25rem; }

  .channel-platform {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 0.6rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(248,247,244,0.45);
    font-weight: 500;
  }

  .channel-handle {
    font-family: var(--font-display, 'Tenor Sans', serif);
    font-size: clamp(1.1rem, 2.2vw, 1.45rem);
    color: #F8F7F4;
    font-weight: 400;
    transition: color 0.2s;
  }

  .channel-arr {
    font-size: 1rem;
    color: rgba(248,247,244,0.2);
    transition: transform 0.2s, color 0.2s;
    flex-shrink: 0;
  }
  .channel-row:hover .channel-arr { transform: translateX(5px); color: rgba(248,247,244,0.65); }

  .studio-block {
    border-top: 0.5px solid rgba(248,247,244,0.08);
    padding-top: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .studio-label {
    font-family: 'Courier New', monospace;
    font-size: 0.5rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(248,247,244,0.3);
    margin-bottom: 0.2rem;
  }

  .studio-address {
    font-family: var(--font-display, 'Tenor Sans', serif);
    font-size: 1.05rem;
    color: rgba(248,247,244,0.8);
  }

  .studio-hours {
    font-family: 'Courier New', monospace;
    font-size: 0.5rem;
    letter-spacing: 0.14em;
    color: rgba(248,247,244,0.25);
  }

  /* ── ANIMATIONS ── */
  [data-reveal] { opacity: 0; transform: translateY(24px); transition: opacity 0.8s ease, transform 0.8s cubic-bezier(0.16,1,0.3,1); }
  [data-reveal].revealed { opacity: 1; transform: none; }
  [data-reveal-fade] { opacity: 0; transition: opacity 0.9s ease; }
  [data-reveal-fade].revealed { opacity: 1; }

  /* ── DESKTOP ── */
  @media (min-width: 768px) {
    .feat-wrap { height: 75vh; }
    .feat-content { padding: 3rem 8vw; }

    .contact-grid {
      flex-direction: row;
      min-height: 55vh;
    }
    .contact-left {
      flex: 1;
      padding: 6rem 6vw 6rem 8vw;
      align-items: center;
    }
    .contact-right {
      width: 42%;
      flex-shrink: 0;
      padding: 6rem 8vw 6rem 5vw;
    }
  }

  @media (min-width: 1200px) {
    .feat-wrap { height: 85vh; }
    .contact-left { padding: 7rem 6vw 7rem 10vw; }
    .contact-right { padding: 7rem 10vw 7rem 5vw; }
  }
</style>

<script>
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (!e.isIntersecting) return;
      e.target.classList.add('revealed');
      io.unobserve(e.target);
    });
  }, { threshold: 0.06 });
  document.querySelectorAll('[data-reveal], [data-reveal-fade]').forEach(el => io.observe(el));

  const rows = document.querySelectorAll('.channel-row');
  const rowObs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (!e.isIntersecting) return;
      const i = Array.from(rows).indexOf(e.target);
      setTimeout(() => e.target.classList.add('visible'), i * 80);
      rowObs.unobserve(e.target);
    });
  }, { threshold: 0.1 });
  rows.forEach(r => rowObs.observe(r));
</script>
