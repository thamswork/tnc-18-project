---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';
import contactData from '../content/settings/contact.json';
import pageData    from '../content/pages/contact.json';

const allProjects = await getCollection('projects');
const projects = allProjects.sort((a, b) => b.data.year - a.data.year);
const featured = projects[0] || null;

function slug(t: string) {
  return t.toLowerCase().replace(/['']/g, '').replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
}

const igHandle = (contactData.instagram || '').replace('https://www.instagram.com/','@').replace('https://instagram.com/','@');
const ttHandle = (contactData.tiktok || '').replace('https://www.tiktok.com/','').replace('https://tiktok.com/','');
const LINE_ICON = 'https://res.cloudinary.com/dynjnftnu/image/upload/v1776531320/LINE_Brand_icon_2_ytuls0.png';
const heroSrc = pageData.hero_image || featured?.data?.cover || null;
---

<Layout title="Contact — TNC.18">
  <Navbar />
  <main>

    <!-- HERO: true full viewport -->
    {heroSrc && (
      <section class="hero">
        <img src={heroSrc} alt="" class="hero-img" />
        <div class="hero-veil"></div>
        <div class="hero-ui">
          <span class="hero-brand">TNC<em>.</em>18</span>
          <p class="hero-tag">Retail & Interior Design · Bangkok</p>
        </div>
      </section>
    )}

    <!-- CONTACT BODY -->
    <section class="body">
      <div class="body-left">
        <p class="eyebrow">Get In Touch</p>
        <h1 class="title">{pageData.headline.toUpperCase()}</h1>
        <p class="sub">{pageData.subtext}</p>
        {contactData.line && (
          <a href={contactData.line} target="_blank" rel="noopener" class="line-btn">
            <img src={LINE_ICON} alt="LINE" class="line-ico" />
            {pageData.line_label || 'Message us on Line'}
          </a>
        )}
        <p class="promise"><span class="dot"></span>{pageData.promise}</p>
      </div>

      <div class="body-right">
        <p class="also">Also Find Us</p>
        <div class="channels">
          {contactData.instagram && (
            <a href={contactData.instagram} target="_blank" rel="noopener" class="ch">
              <span class="ch-left"><span class="ch-plat">Instagram</span><span class="ch-handle">{igHandle}</span></span>
              <span class="ch-arr">→</span>
            </a>
          )}
          {contactData.tiktok && (
            <a href={contactData.tiktok} target="_blank" rel="noopener" class="ch">
              <span class="ch-left"><span class="ch-plat">TikTok</span><span class="ch-handle">{ttHandle}</span></span>
              <span class="ch-arr">→</span>
            </a>
          )}
          {contactData.facebook && (
            <a href={contactData.facebook} target="_blank" rel="noopener" class="ch">
              <span class="ch-left"><span class="ch-plat">Facebook</span><span class="ch-handle">TNC.18</span></span>
              <span class="ch-arr">→</span>
            </a>
          )}
          {contactData.email && (
            <a href={`mailto:${contactData.email}`} class="ch">
              <span class="ch-left"><span class="ch-plat">Email</span><span class="ch-handle">{contactData.email}</span></span>
              <span class="ch-arr">→</span>
            </a>
          )}
          {contactData.phone && (
            <a href={`tel:${contactData.phone.replace(/\s/g,'')}`} class="ch">
              <span class="ch-left"><span class="ch-plat">Phone</span><span class="ch-handle">{contactData.phone}</span></span>
              <span class="ch-arr">→</span>
            </a>
          )}
        </div>
        <div class="studio">
          <p class="studio-lbl">Studio</p>
          <p class="studio-city">Bangkok, Thailand</p>
          <p class="studio-hrs">Mon – Sat · 09:00 – 18:00</p>
        </div>
      </div>
    </section>

  </main>
  <Footer hideCta={true} />
</Layout>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  /* HERO */
  .hero {
    position: relative;
    width: 100%;
    height: 100vh;
    overflow: hidden;
    background: #0a0e18;
  }

  .hero-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .hero-veil {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(4,6,10,0.38) 0%,
      rgba(4,6,10,0.0) 40%,
      rgba(4,6,10,0.0) 70%,
      rgba(4,6,10,0.32) 100%
    );
  }

  .hero-ui {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 5.5rem var(--pad-x, 5vw) 2.5rem;
  }

  .hero-brand {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 1.05rem;
    font-weight: 800;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #fff;
    text-shadow: 0 1px 16px rgba(0,0,0,0.4);
  }
  .hero-brand em { font-style: normal; }

  .hero-tag {
    font-family: 'Courier New', monospace;
    font-size: 0.58rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.55);
    text-shadow: 0 1px 8px rgba(0,0,0,0.5);
  }

  /* CONTACT BODY */
  .body {
    display: flex;
    flex-direction: column;
    gap: 3rem;
    padding: 4rem var(--pad-x, 5vw);
    background: var(--bg, #F8F7F4);
  }

  .eyebrow {
    font-family: 'Courier New', monospace;
    font-size: 0.55rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--navy, #1A3A6B);
    margin-bottom: 0.5rem;
  }

  .title {
    font-family: var(--font-display, 'Tenor Sans', serif);
    font-size: clamp(2.5rem, 7vw, 5rem);
    font-weight: 400;
    letter-spacing: 0.03em;
    color: var(--ink, #1A1A1A);
    line-height: 0.95;
    margin-bottom: 1.25rem;
  }

  .sub {
    font-size: 0.92rem;
    line-height: 1.9;
    color: var(--ink-mid, #4A4A4A);
    font-weight: 300;
    max-width: 420px;
    margin-bottom: 1.75rem;
  }

  .line-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--navy, #1A3A6B);
    padding: 1rem 2rem;
    border: 1.5px solid var(--navy, #1A3A6B);
    transition: background 0.25s, color 0.25s;
    margin-bottom: 1rem;
  }
  .line-btn:hover { background: var(--navy, #1A3A6B); color: #fff; }
  .line-ico { width: 22px; height: 22px; object-fit: contain; border-radius: 4px; }

  .promise {
    display: flex; align-items: center; gap: 0.5rem;
    font-family: 'Courier New', monospace;
    font-size: 0.52rem; letter-spacing: 0.18em;
    text-transform: uppercase; color: var(--ink-light, #6B6B6B);
  }
  .dot {
    display: block; width: 5px; height: 5px;
    border-radius: 50%; background: #06C755; flex-shrink: 0;
  }

  .also {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 0.62rem; letter-spacing: 0.2em;
    text-transform: uppercase; color: var(--ink-light, #6B6B6B);
    font-weight: 500; margin-bottom: 0.5rem;
  }

  .channels { display: flex; flex-direction: column; margin-bottom: 1.5rem; }

  .ch {
    display: flex; align-items: center; justify-content: space-between;
    padding: 1rem 0;
    border-bottom: 0.5px solid rgba(26,26,26,0.08);
    text-decoration: none; color: inherit;
    transition: padding-left 0.2s;
  }
  .ch:first-child { border-top: 0.5px solid rgba(26,26,26,0.08); }
  .ch:hover { padding-left: 0.35rem; }
  .ch-left { display: flex; flex-direction: column; gap: 0.2rem; }
  .ch-plat {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 0.58rem; letter-spacing: 0.14em;
    text-transform: uppercase; color: var(--ink-light, #6B6B6B); font-weight: 500;
  }
  .ch-handle {
    font-family: var(--font-display, 'Tenor Sans', serif);
    font-size: clamp(1rem, 2vw, 1.35rem);
    color: var(--ink, #1A1A1A); transition: color 0.2s;
  }
  .ch:hover .ch-handle { color: var(--navy, #1A3A6B); }
  .ch-arr {
    font-size: 0.9rem; color: rgba(26,26,26,0.2);
    transition: transform 0.2s, color 0.2s;
  }
  .ch:hover .ch-arr { transform: translateX(4px); color: var(--navy, #1A3A6B); }

  .studio { border-top: 0.5px solid rgba(26,26,26,0.08); padding-top: 1.25rem; }
  .studio-lbl {
    font-family: 'Courier New', monospace; font-size: 0.5rem;
    letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--ink-light, #6B6B6B); margin-bottom: 0.35rem;
  }
  .studio-city {
    font-family: var(--font-display, 'Tenor Sans', serif);
    font-size: 1rem; color: var(--ink, #1A1A1A); margin-bottom: 0.2rem;
  }
  .studio-hrs {
    font-family: 'Courier New', monospace; font-size: 0.5rem;
    letter-spacing: 0.14em; color: var(--ink-light, #6B6B6B);
  }

  /* DESKTOP */
  @media (min-width: 768px) {
    .body {
      flex-direction: row;
      align-items: flex-start;
      padding: 6rem 8vw;
      gap: 7rem;
    }
    .body-left { flex: 1; }
    .body-right { width: 40%; flex-shrink: 0; }
  }

  @media (min-width: 1200px) {
    .body { padding: 7rem 10vw; gap: 9rem; }
  }
</style>
