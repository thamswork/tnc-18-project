---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import { getCollection } from 'astro:content';
import homepageData from '../content/pages/homepage.json';
import contactData  from '../content/settings/contact.json';

const allProjects = await getCollection('projects');
const projects = allProjects
  .sort((a, b) => b.data.year - a.data.year)
  .slice(0, 6);

function slug(title: string) {
  return title.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
}
---

<Layout title="TNC.18 — Retail & Interior Design Bangkok">
  <Navbar />

  <!-- ── HERO ─────────────────────────────────────────────────── -->
  <section class="hero">
    <div class="hero-mist" aria-hidden="true"></div>
    <div class="hero-media">
      {homepageData.hero_video
        ? <video autoplay muted loop playsinline class="hero-video">
            <source src={homepageData.hero_video} type="video/mp4" />
          </video>
        : homepageData.hero_image
          ? <img src={homepageData.hero_image} alt="" class="hero-img" />
          : <div class="hero-fallback"></div>
      }
      <div class="hero-overlay"></div>
    </div>

    <div class="hero-content">
      <p class="hero-eyebrow">Bangkok · Thailand</p>
      <h1 class="hero-title">
        <span>{homepageData.hero_line1}</span>
        <span class="hero-title-dim">{homepageData.hero_line2}</span>
      </h1>
    </div>

    <div class="hero-foot">
      {contactData.line && (
        <a href={contactData.line} target="_blank" rel="noopener" class="btn-line hero-line-btn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="flex-shrink:0">
            <path d="M19.365 9.89c.5 0 .907.406.907.907s-.407.907-.907.907h-2.724v1.77h2.724c.5 0 .907.406.907.907s-.407.907-.907.907H15.73a.907.907 0 0 1-.907-.907V9.89c0-.5.406-.907.907-.907h3.636zm-5.453 0c.5 0 .907.406.907.907v4.491a.907.907 0 0 1-1.814 0V10.797a.907.907 0 0 1 .907-.907zm-2.198 0a.907.907 0 0 1 .736.378l2.33 3.176V10.8a.907.907 0 1 1 1.814 0v4.49a.907.907 0 0 1-.907.907.907.907 0 0 1-.735-.377l-2.33-3.177v2.647a.907.907 0 1 1-1.814 0v-4.49c0-.5.406-.907.906-.907zm-3.634 0c.5 0 .906.406.906.907v4.491a.907.907 0 0 1-1.813 0V10.797c0-.5.406-.907.907-.907zM12 2C6.477 2 2 6.108 2 11.148c0 4.515 3.564 8.292 8.37 9.006.325.07.77.214.882.49.1.252.065.647.032.9l-.143.855c-.043.253-.2 1-.876.547-.676-.454-3.647-2.146-4.98-3.627C3.576 17.21 2 14.315 2 11.148 2 6.108 6.477 2 12 2z"/>
          </svg>
          Message us on Line
        </a>
      )}
      <span class="hero-tag">{homepageData.hero_sub || 'Retail · Interior · Construction'}</span>
    </div>

    <div class="hero-scroll-hint" aria-hidden="true">
      <span class="scroll-line"></span>
    </div>
  </section>

  <!-- ── PILLARS ─────────────────────────────────────────────── -->
  <section class="pillars">
    {[
      { n: '01', title: 'Fast Delivery',  body: 'Tight lead times. Built for urgent retail timelines without sacrificing precision.' },
      { n: '02', title: 'Senior Only',    body: 'You deal directly with partners. Zero junior hand-offs, from brief to handover.' },
      { n: '03', title: '24/7 Support',   body: 'Unlimited revisions. Always reachable, always accountable throughout your project.' },
    ].map((p, i) => (
      <div class="pillar" data-reveal data-delay={String(i)}>
        <span class="pillar-accent" aria-hidden="true"></span>
        <span class="pillar-n">{p.n}</span>
        <h3 class="pillar-title">{p.title}</h3>
        <p class="pillar-body">{p.body}</p>
      </div>
    ))}
  </section>

  <!-- ── PORTFOLIO GRID ─────────────────────────────────────── -->
  <section class="portfolio">
    <header class="port-header" data-reveal>
      <div class="port-header-left">
        <span class="accent-bar" aria-hidden="true"></span>
        <span class="section-label">Selected Work</span>
      </div>
      <a href="/portfolio" class="link-all">All Projects →</a>
    </header>

    <div class="grid">
      {projects.map((p, i) => (
        <article class={`grid-card card-navy ${i === 0 ? 'grid-card--hero' : ''}`} data-reveal>
          <a href={`/portfolio/${slug(p.data.title)}`} class="card-link">
            <div class="card-media">
              {p.data.cover && !p.data.cover.includes('placeholder')
                ? <img
                    src={p.data.cover}
                    alt={p.data.title}
                    loading={i < 2 ? 'eager' : 'lazy'}
                    class="card-img"
                  />
                : <div class="card-ph"></div>
              }
              <div class="card-hover-layer">
                <span class="card-view-btn">View Project</span>
              </div>
            </div>
            <div class="card-body">
              <div class="card-meta">
                <span class="card-cat">{p.data.category}</span>
                {p.data.location && <span class="card-loc">{p.data.location}</span>}
                <span class="card-year">{p.data.year}</span>
              </div>
              <h2 class="card-title">{p.data.title}</h2>
            </div>
          </a>
        </article>
      ))}

      {projects.length === 0 && (
        <article class="grid-card grid-card--hero card-navy" data-reveal>
          <a href="/admin" class="card-link">
            <div class="card-media"><div class="card-ph"></div></div>
            <div class="card-body">
              <div class="card-meta"><span class="card-cat">Portfolio</span></div>
              <h2 class="card-title">Add your first project in the CMS</h2>
            </div>
          </a>
        </article>
      )}
    </div>

    <div class="port-foot" data-reveal>
      <a href="/portfolio" class="btn-navy-ghost">See All Work →</a>
    </div>
  </section>

  <!-- ── STATEMENT ──────────────────────────────────────────── -->
  <section class="statement" data-reveal>
    <div class="statement-inner">
      <span class="statement-bar" aria-hidden="true"></span>
      <blockquote class="statement-quote">{homepageData.statement}</blockquote>
    </div>
  </section>

  <!-- ── CTA BAND ───────────────────────────────────────────── -->
  <section class="cta-band" data-reveal>
    <div class="cta-mist" aria-hidden="true"></div>
    <div class="cta-band-inner">
      <div>
        <h2 class="cta-title">Ready to start?</h2>
        <p class="cta-sub">Senior partners. Fast delivery. We reply within 2 hours.</p>
      </div>
      <div class="cta-actions">
        {contactData.line && (
          <a href={contactData.line} target="_blank" rel="noopener" class="btn-line">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="flex-shrink:0">
              <path d="M19.365 9.89c.5 0 .907.406.907.907s-.407.907-.907.907h-2.724v1.77h2.724c.5 0 .907.406.907.907s-.407.907-.907.907H15.73a.907.907 0 0 1-.907-.907V9.89c0-.5.406-.907.907-.907h3.636zm-5.453 0c.5 0 .907.406.907.907v4.491a.907.907 0 0 1-1.814 0V10.797a.907.907 0 0 1 .907-.907zm-2.198 0a.907.907 0 0 1 .736.378l2.33 3.176V10.8a.907.907 0 1 1 1.814 0v4.49a.907.907 0 0 1-.907.907.907.907 0 0 1-.735-.377l-2.33-3.177v2.647a.907.907 0 1 1-1.814 0v-4.49c0-.5.406-.907.906-.907zm-3.634 0c.5 0 .906.406.906.907v4.491a.907.907 0 0 1-1.813 0V10.797c0-.5.406-.907.907-.907zM12 2C6.477 2 2 6.108 2 11.148c0 4.515 3.564 8.292 8.37 9.006.325.07.77.214.882.49.1.252.065.647.032.9l-.143.855c-.043.253-.2 1-.876.547-.676-.454-3.647-2.146-4.98-3.627C3.576 17.21 2 14.315 2 11.148 2 6.108 6.477 2 12 2z"/>
            </svg>
            Line OA
          </a>
        )}
        {contactData.instagram && (
          <a href={contactData.instagram} target="_blank" rel="noopener" class="btn-navy-ghost">Instagram</a>
        )}
        {contactData.tiktok && (
          <a href={contactData.tiktok} target="_blank" rel="noopener" class="btn-navy-ghost">TikTok</a>
        )}
      </div>
    </div>
  </section>

  <!-- ── FOOTER ─────────────────────────────────────────────── -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-brand">
        <span class="footer-logo">TNC<em>.</em>18</span>
        <p class="footer-sub">Retail & Interior Design · Bangkok</p>
      </div>
      <nav class="footer-nav" aria-label="Footer">
        <a href="/portfolio">Work</a>
        <a href="/about-services">Studio</a>
        <a href="/contact">Contact</a>
        {contactData.instagram && <a href={contactData.instagram} target="_blank" rel="noopener">Instagram</a>}
        {contactData.tiktok    && <a href={contactData.tiktok}    target="_blank" rel="noopener">TikTok</a>}
        {contactData.line      && <a href={contactData.line}      target="_blank" rel="noopener">Line OA</a>}
      </nav>
      <p class="footer-copy">© {new Date().getFullYear()} TNC.18</p>
    </div>
  </footer>
</Layout>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  .hero {
    position: relative; width: 100%; min-height: 100svh;
    display: flex; flex-direction: column; justify-content: flex-end;
    overflow: hidden; background: var(--charcoal); padding-top: 60px;
  }
  .hero-mist { position: absolute; top: 60px; left: 0; right: 0; height: 100px; background: linear-gradient(to bottom,rgba(26,58,107,.08),transparent); z-index: 2; pointer-events: none; }
  .hero-media { position: absolute; inset: 0; z-index: 0; }
  .hero-video, .hero-img { width: 100%; height: 100%; object-fit: cover; opacity: .48; }
  .hero-fallback { position: absolute; inset: 0; background: linear-gradient(155deg,#2c3a52,#141c28); }
  .hero-overlay { position: absolute; inset: 0; background: linear-gradient(to top,rgba(20,18,15,.88) 0%,transparent 55%),linear-gradient(to bottom,rgba(20,18,15,.35) 0%,transparent 35%); }
  .hero-content { position: relative; z-index: 3; padding: 0 5% 1.5rem; }
  .hero-eyebrow { font-size: .58rem; letter-spacing: .28em; text-transform: uppercase; color: rgba(244,240,230,.35); margin-bottom: .9rem; animation: fadeUp .8s .2s both; }
  .hero-title { font-family: var(--font-display); font-size: clamp(2.6rem,11vw,6.5rem); font-weight: 400; letter-spacing: .04em; text-transform: uppercase; color: var(--warm-white); line-height: 1.0; display: flex; flex-direction: column; animation: slideUp 1s cubic-bezier(.16,1,.3,1) .05s both; }
  .hero-title-dim { color: rgba(244,240,230,.35); }
  .hero-foot { position: relative; z-index: 3; display: flex; align-items: center; gap: 1.25rem; flex-wrap: wrap; padding: 1.25rem 5% 2.25rem; border-top: .5px solid rgba(244,240,230,.07); animation: fadeUp .8s .65s both; }
  .hero-line-btn { font-size: .7rem; padding: .8rem 1.5rem; }
  .hero-tag { font-size: .55rem; letter-spacing: .2em; text-transform: uppercase; color: rgba(244,240,230,.2); }
  .hero-scroll-hint { position: absolute; bottom: 1.75rem; right: 5%; z-index: 3; }
  .scroll-line { display: block; width: 1px; height: 44px; background: linear-gradient(to bottom,var(--navy),transparent); animation: scrollPulse 2.2s ease-in-out infinite; }
  @keyframes slideUp { from{transform:translateY(48px);opacity:0} to{transform:none;opacity:1} }
  @keyframes fadeUp  { from{opacity:0;transform:translateY(6px)} to{opacity:1;transform:none} }
  @keyframes scrollPulse { 0%,100%{opacity:.22} 50%{opacity:1} }

  .pillars { display: grid; grid-template-columns: 1fr; background: var(--warm-white); border-top: .5px solid var(--cream-dark); }
  .pillar { padding: 2rem 5%; border-bottom: .5px solid var(--cream-dark); display: flex; flex-direction: column; gap: .5rem; }
  .pillar-accent { display: block; width: 24px; height: 2px; background: var(--navy); margin-bottom: .35rem; }
  .pillar-n { font-size: .52rem; letter-spacing: .22em; color: var(--navy); font-weight: 600; }
  .pillar-title { font-family: var(--font-display); font-size: 1rem; font-weight: 400; letter-spacing: .08em; text-transform: uppercase; color: var(--charcoal); }
  .pillar-body { font-size: .78rem; line-height: 1.75; color: var(--muted); font-weight: 300; max-width: 280px; }

  .portfolio { background: var(--cream); padding: 3rem 5%; }
  .port-header { display: flex; justify-content: space-between; align-items: center; border-bottom: .5px solid var(--cream-dark); padding-bottom: .75rem; margin-bottom: 1.5rem; }
  .port-header-left { display: flex; align-items: center; gap: .65rem; }
  .accent-bar { display: inline-block; width: 3px; background: var(--navy); align-self: stretch; min-height: 14px; flex-shrink: 0; }
  .section-label { font-family: var(--font-body); font-size: .55rem; font-weight: 600; letter-spacing: .26em; text-transform: uppercase; color: var(--muted); }
  .link-all { font-size: .58rem; letter-spacing: .12em; color: var(--charcoal); text-decoration: none; transition: color .2s; }
  .link-all:hover { color: var(--navy); }

  .grid { display: grid; grid-template-columns: 1fr; gap: 2px; }
  .grid-card { overflow: hidden; }
  .card-link { display: block; text-decoration: none; color: inherit; }
  .card-media { position: relative; width: 100%; overflow: hidden; background: var(--cream-dark); }
  .grid-card--hero .card-media { aspect-ratio: 4/3; }
  .grid-card:not(.grid-card--hero) .card-media { aspect-ratio: 3/2; }
  .card-img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 1s cubic-bezier(.4,0,.2,1); }
  .card-ph { width: 100%; height: 100%; background: linear-gradient(135deg,var(--cream-mid),var(--cream-dark)); transition: transform 1s cubic-bezier(.4,0,.2,1); }
  .card-link:hover .card-img, .card-link:hover .card-ph { transform: scale(1.04); }
  .card-hover-layer { position: absolute; inset: 0; display: flex; align-items: flex-end; justify-content: flex-end; padding: 1rem; opacity: 0; transition: opacity .3s; }
  .card-link:hover .card-hover-layer { opacity: 1; }
  .card-view-btn { font-family: var(--font-body); font-size: .56rem; font-weight: 500; letter-spacing: .16em; text-transform: uppercase; color: var(--warm-white); background: var(--navy); padding: .4rem .85rem; }
  .card-body { padding: .65rem 0 1.1rem; background: var(--warm-white); }
  .card-meta { display: flex; align-items: center; gap: .65rem; margin-bottom: .3rem; }
  .card-cat { font-size: .5rem; letter-spacing: .22em; text-transform: uppercase; color: var(--navy); font-weight: 600; }
  .card-loc { font-size: .5rem; letter-spacing: .14em; text-transform: uppercase; color: var(--muted); }
  .card-year { font-size: .5rem; color: var(--muted-light,#B8B4AF); margin-left: auto; letter-spacing: .08em; }
  .card-title { font-family: var(--font-display); font-size: clamp(.95rem,3.5vw,1.3rem); font-weight: 400; letter-spacing: .05em; text-transform: uppercase; color: var(--charcoal); line-height: 1.2; }
  .card-navy { background: var(--warm-white); border: .5px solid var(--cream-dark); border-top: 2.5px solid var(--navy); }
  .port-foot { margin-top: 2rem; text-align: center; }

  .btn-navy-ghost { display: inline-flex; align-items: center; gap: .5rem; font-family: var(--font-body); font-size: .62rem; font-weight: 500; letter-spacing: .16em; text-transform: uppercase; text-decoration: none; color: var(--navy); background: transparent; padding: .75rem 1.4rem; border: 1.5px solid var(--navy); cursor: pointer; transition: background .25s,color .25s; white-space: nowrap; }
  .btn-navy-ghost:hover { background: var(--navy); color: var(--warm-white); }

  .statement { background: var(--warm-white); border-top: .5px solid var(--cream-dark); border-bottom: .5px solid var(--cream-dark); padding: 3.5rem 5%; }
  .statement-inner { display: flex; gap: 1.25rem; align-items: flex-start; max-width: 680px; }
  .statement-bar { display: block; width: 3px; background: var(--navy); flex-shrink: 0; align-self: stretch; min-height: 1em; margin-top: .15em; }
  .statement-quote { font-family: var(--font-display); font-size: clamp(1.05rem,3.5vw,1.6rem); font-weight: 400; letter-spacing: .03em; color: var(--charcoal); line-height: 1.55; font-style: normal; }

  .cta-band { background: var(--cream); border-top: .5px solid var(--cream-dark); padding: 3rem 5%; position: relative; overflow: hidden; }
  .cta-mist { position: absolute; bottom: 0; left: 0; right: 0; height: 80px; background: linear-gradient(to top,rgba(26,58,107,.06),transparent); pointer-events: none; }
  .cta-band-inner { position: relative; z-index: 1; display: flex; flex-direction: column; gap: 1.75rem; }
  .cta-title { font-family: var(--font-display); font-size: clamp(1.5rem,6vw,2.5rem); font-weight: 400; letter-spacing: .06em; text-transform: uppercase; color: var(--navy); line-height: 1.05; }
  .cta-sub { font-size: .78rem; color: var(--muted); margin-top: .4rem; line-height: 1.75; font-weight: 300; }
  .cta-actions { display: flex; flex-wrap: wrap; gap: .65rem; }

  .btn-line { display: inline-flex; align-items: center; gap: .55rem; font-family: var(--font-body); font-size: .65rem; font-weight: 500; letter-spacing: .14em; text-transform: uppercase; text-decoration: none; color: #fff; background: #06C755; padding: .8rem 1.6rem; border: none; cursor: pointer; transition: background .25s; white-space: nowrap; }
  .btn-line:hover { background: #05b34c; }

  .footer { background: var(--navy-deep,#102448); border-top: .5px solid rgba(244,240,230,.06); padding: 2.5rem 5%; }
  .footer-inner { display: flex; flex-direction: column; gap: 1.5rem; }
  .footer-logo { font-family: var(--font-body); font-size: .8rem; font-weight: 600; letter-spacing: .18em; color: rgba(244,240,230,.32); display: block; margin-bottom: .2rem; }
  .footer-logo em { font-style: normal; color: rgba(244,240,230,.68); }
  .footer-sub { font-size: .5rem; letter-spacing: .16em; text-transform: uppercase; color: rgba(244,240,230,.14); line-height: 1; }
  .footer-nav { display: flex; flex-wrap: wrap; gap: .4rem 1.4rem; }
  .footer-nav a { font-size: .56rem; letter-spacing: .14em; text-transform: uppercase; color: rgba(244,240,230,.26); text-decoration: none; transition: color .2s; }
  .footer-nav a:hover { color: rgba(244,240,230,.8); }
  .footer-copy { font-size: .48rem; color: rgba(244,240,230,.1); letter-spacing: .1em; }

  @media (min-width: 768px) {
    .pillars { grid-template-columns: repeat(3,1fr); }
    .pillar { border-bottom: none; border-right: .5px solid var(--cream-dark); padding: 2.5rem 5%; }
    .pillar:last-child { border-right: none; }
    .grid { grid-template-columns: repeat(2,1fr); }
    .grid-card--hero { grid-column: 1/-1; }
    .grid-card--hero .card-media { aspect-ratio: 16/6; }
    .statement { padding: 5rem 10%; }
    .cta-band { padding: 5rem 10%; }
    .cta-band-inner { flex-direction: row; align-items: center; justify-content: space-between; gap: 3rem; }
    .footer-inner { flex-direction: row; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem; }
  }
  @media (min-width: 1100px) {
    .grid { grid-template-columns: repeat(3,1fr); }
    .grid-card--hero { grid-column: 1/-1; }
  }
</style>

<script>
  const io = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      entry.target.classList.add('revealed');
      io.unobserve(entry.target);
    });
  }, { threshold: 0.06, rootMargin: '0px 0px -30px 0px' });
  document.querySelectorAll('[data-reveal]').forEach(el => io.observe(el));
</script>
