  .ig-handle:hover { color: var(--navy,#1A3A6B); }

  /* 3×3 grid — matches PIA exactly */
  .ig-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3px;
  }

  .ig-item {
    position: relative; display: block;
