---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import { getCollection } from 'astro:content';
import homepageData from '../content/pages/homepage.json';
import contactData  from '../content/settings/contact.json';

const allProjects = await getCollection('projects');
const projects = allProjects.sort((a, b) => b.data.year - a.data.year);

function slug(t: string) {
  return t.toLowerCase().replace(/['’]/g, '').replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
}

const slides: string[] = (homepageData.hero_slides && homepageData.hero_slides.length > 0)
  ? homepageData.hero_slides.map((s: any) => typeof s === 'string' ? s : s.image)
  : homepageData.hero_image ? [homepageData.hero_image] : [];

const categories = ['All', ...new Set(projects.map(p => p.data.category).filter(Boolean))] as string[];

// ── CONFIGURE THESE ──────────────────────────────────────────────
// Update these when you have the real handles:
const FB_PAGE_URL   = contactData.facebook || 'https://www.facebook.com/tnc18';
const IG_HANDLE     = (contactData.instagram || 'https://instagram.com/tnc18').replace('https://instagram.com/','@').replace('https://www.instagram.com/','@');
const IG_URL        = contactData.instagram || 'https://instagram.com/tnc18';
// ─────────────────────────────────────────────────────────────────
---

<Layout title="TNC.18 — Retail & Interior Design Bangkok">
  <Navbar />

  <!-- ── HERO SLIDER ─────────────────────────────────────────── -->
  <section class="hero" id="hero">
    <div class="hero-track" id="hero-track">
      {slides.length > 0
        ? slides.map((src, i) => (
            <div class={`hero-slide ${i === 0 ? 'active' : ''}`}>
              <img src={src} alt="" class="slide-img" loading={i === 0 ? 'eager' : 'lazy'} />
              <div class="slide-veil"></div>
            </div>
          ))
        : (
          <div class="hero-slide active">
            {homepageData.hero_video
              ? <video autoplay muted loop playsinline class="slide-video">
                  <source src={homepageData.hero_video} type="video/mp4" />
                </video>
              : <div class="slide-ph"></div>
            }
            <div class="slide-veil"></div>
          </div>
        )
      }
    </div>

    <div class="hero-content">
      <p class="hero-loc">Bangkok · Thailand</p>
      <h1 class="hero-title">
        <span class="ht-1">{homepageData.hero_line1}</span>
        <span class="ht-2">{homepageData.hero_line2}</span>
      </h1>
      <a href="/about-services" class="hero-more">More About Us <span>→</span></a>
    </div>

    {slides.length > 1 && (
      <div class="hero-arrows">
        <button class="hero-arr-btn" id="hero-prev" aria-label="Previous">←</button>
        <button class="hero-arr-btn" id="hero-next" aria-label="Next">→</button>
      </div>
    )}

    {slides.length > 1 && (
      <div class="hero-dots" id="hero-dots">
        {slides.map((_, i) => (
          <button class={`hero-dot ${i === 0 ? 'active' : ''}`} data-slide={i} aria-label={`Slide ${i+1}`}></button>
        ))}
      </div>
    )}

    <div class="hero-label" style="display:none">
      <span>{homepageData.hero_sub || 'Retail Design · Interior · Construction'}</span>
    </div>
  </section>

  <!-- ── PILLARS ─────────────────────────────────────────────── -->
  <section class="pillars">
    {[
      { n: '01', title: 'Fast Delivery',  body: 'Tight lead times. Built for urgent retail timelines without compromising quality.' },
      { n: '02', title: 'Senior Only',    body: 'You work directly with founding partners. Zero junior hand-offs, from brief to handover.' },
      { n: '03', title: '24 / 7 Support', body: 'Unlimited revisions. Always reachable. Always accountable throughout your project.' },
    ].map((p, i) => (
      <div class="pillar" data-reveal data-delay={String(i)}>
        <span class="pillar-n">{p.n}</span>
        <h3 class="pillar-title">{p.title}</h3>
        <p class="pillar-body">{p.body}</p>
      </div>
    ))}
  </section>

  <!-- ── WORKS — PIA full-height carousel ────────────────────── -->
  <section class="works">
    <div class="works-head">
      <h2 class="works-title">Works</h2>
      <div class="works-nav" style="position:absolute;right:var(--pad-x,5vw)">
        <button class="works-arr" id="works-prev" aria-label="Previous">←</button>
        <button class="works-arr" id="works-next" aria-label="Next">→</button>
      </div>
    </div>

    <div class="works-cats" id="works-cats">
      {categories.map((cat, i) => (
        <button class={`cat-btn ${i === 0 ? 'active' : ''}`} data-cat={cat}>{cat}</button>
      ))}
    </div>

    <div class="works-wrap">
      <div class="works-track" id="works-track">
        {projects.map((p, i) => (
          <article class="works-card" data-category={p.data.category}>
            <a href={`/portfolio/${slug(p.data.title)}`} class="works-link">
              <div class="works-img-wrap">
                {p.data.cover && !p.data.cover.includes('placeholder')
                  ? <img src={p.data.cover} alt={p.data.title}
                      loading={i < 2 ? 'eager' : 'lazy'} class="works-img" />
                  : <div class="works-ph"></div>
                }
                <div class="works-overlay">
                  <div class="works-overlay-top">
                    <span class="works-num">{String(i+1).padStart(2,'0')}</span>
                    <span class="works-cat-tag">{p.data.category}</span>
                  </div>
                  <div class="works-overlay-bot">
                    <h3 class="works-overlay-title">{p.data.title}</h3>
                    <span class="works-read">Read More →</span>
                  </div>
                </div>
              </div>
              <div class="works-info">
                <p class="works-meta">{p.data.category?.toUpperCase()}{p.data.location ? ` — ${p.data.location.toUpperCase()}` : ''}</p>
                <h3 class="works-name">{p.data.title}</h3>
              </div>
            </a>
          </article>
        ))}
        {projects.length === 0 && (
          <div class="works-empty">No projects yet. <a href="/admin">Add in CMS →</a></div>
        )}
      </div>
    </div>

    <div class="works-dots" id="works-dots"></div>

    <div class="works-foot" data-reveal>
      <a href="/portfolio" class="btn-ghost">View All Works →</a>
    </div>
  </section>

  <!-- ── STATEMENT ─────────────────────────────────────────────── -->
  <section class="statement">
    <div class="statement-bg">
      {homepageData.statement_image
        ? <img src={homepageData.statement_image} alt="" class="statement-img" />
        : <div class="statement-ph"></div>
      }
      <div class="statement-veil"></div>
    </div>
    <div class="statement-content" data-reveal>
      <blockquote class="statement-q">{homepageData.statement}</blockquote>
    </div>
  </section>

  <!-- ── NEWS — Facebook Page Plugin ──────────────────────────── -->
  <section class="news">
    <div class="news-head">
      <h2 class="news-title">News</h2>
      <a href={FB_PAGE_URL} target="_blank" rel="noopener" class="news-more">View More →</a>
    </div>

    <div class="news-embed-wrap">
      <!-- Facebook Page Plugin — replace YOUR_PAGE_URL with your actual Facebook page URL -->
      <div id="fb-root"></div>
      <div class="fb-page"
        data-href={FB_PAGE_URL}
        data-tabs="timeline"
        data-width="500"
        data-height="600"
        data-small-header="true"
        data-adapt-container-width="true"
        data-hide-cover="false"
        data-show-facepile="false">
        <!-- Fallback while plugin loads -->
        <div class="fb-fallback">
          <p class="fb-fallback-text">Loading news from Facebook...</p>
          <a href={FB_PAGE_URL} target="_blank" rel="noopener" class="fb-fallback-link">
            View on Facebook →
          </a>
        </div>
      </div>
    </div>

    <div class="news-foot">
      <a href={FB_PAGE_URL} target="_blank" rel="noopener" class="btn-ghost">
        View More →
      </a>
    </div>
  </section>

  <!-- ── INSTAGRAM ─────────────────────────────────────────────── -->
  <section class="instagram">
    <div class="ig-head">
      <h2 class="ig-title">Instagram</h2>
      <div class="ig-follow">
        <span class="ig-follow-label">Follow Us</span>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
          <circle cx="12" cy="12" r="4"/>
          <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
        </svg>
        <a href={IG_URL} target="_blank" rel="noopener" class="ig-handle">{IG_HANDLE}</a>
      </div>
    </div>

    <!-- Placeholder grid — swap for real API feed when token is ready -->
    <div class="ig-grid" id="ig-grid">
      {Array.from({length: 9}).map((_, i) => (
        <a href={IG_URL} target="_blank" rel="noopener" class="ig-item ig-placeholder">
          <div class="ig-ph"></div>
          <div class="ig-item-overlay">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="1.5" fill="white" stroke="none"/>
            </svg>
          </div>
        </a>
      ))}
    </div>

    <!-- SWAP INSTRUCTION:
         When you have your Instagram API token, replace the ig-grid contents with:
         fetch(`https://graph.instagram.com/me/media?fields=id,media_url,permalink,media_type&access_token=YOUR_TOKEN`)
         then inject real images. The grid CSS stays the same.
    -->

    <div class="ig-foot">
      <a href={IG_URL} target="_blank" rel="noopener" class="ig-view-btn">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
          <circle cx="12" cy="12" r="4"/>
          <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
        </svg>
        View on Instagram
      </a>
    </div>
  </section>

  <!-- ── CTA ──────────────────────────────────────────────────── -->
  <section class="cta" data-reveal>
    <div class="cta-inner">
      <div class="cta-left">
        <h2 class="cta-headline">Ready to<br/>Start?</h2>
        <p class="cta-sub">Senior partners only. Fast turnaround. We reply within 2 hours.</p>
      </div>
      <div class="cta-right">
        {contactData.line && (
          <a href={contactData.line} target="_blank" rel="noopener" class="cta-line-btn">
            <span class="line-dot"></span>
            Message on Line
          </a>
        )}
        <div class="cta-socials">
          {contactData.instagram && <a href={contactData.instagram} target="_blank" rel="noopener" class="social-l">Instagram</a>}
          {contactData.tiktok    && <a href={contactData.tiktok}    target="_blank" rel="noopener" class="social-l">TikTok</a>}
          {contactData.email     && <a href={`mailto:${contactData.email}`} class="social-l">{contactData.email}</a>}
        </div>
      </div>
    </div>
  </section>

  <!-- ── FOOTER ─────────────────────────────────────────────────── -->
  <footer class="site-footer">
    <div class="site-footer-inner">
      <div>
        <span class="site-footer-logo">TNC<em>.</em>18</span>
        <p class="site-footer-sub">Retail & Interior Design · Bangkok</p>
      </div>
      <nav class="site-footer-nav">
        <a href="/portfolio">Work</a>
        <a href="/about-services">Studio</a>
        <a href="/contact">Contact</a>
        {contactData.instagram && <a href={contactData.instagram} target="_blank" rel="noopener">Instagram</a>}
        {contactData.tiktok    && <a href={contactData.tiktok}    target="_blank" rel="noopener">TikTok</a>}
        {contactData.line      && <a href={contactData.line}      target="_blank" rel="noopener">Line OA</a>}
      </nav>
      <p class="site-footer-copy">© {new Date().getFullYear()} TNC.18. All rights reserved.</p>
    </div>
  </footer>
</Layout>

<!-- Facebook SDK — loads async after page -->
<script is:inline>
  window.fbAsyncInit = function() {
    FB.init({ xfbml: true, version: 'v19.0' });
  };
  (function(d, s, id) {
    var js, fjs = d.getElementsByTagName(s)[0];
    if (d.getElementById(id)) return;
    js = d.createElement(s); js.id = id;
    js.src = "https://connect.facebook.net/en_US/sdk.js";
    fjs.parentNode.insertBefore(js, fjs);
  }(document, 'script', 'facebook-jssdk'));
</script>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  /* ── HERO ── */
  .hero {
    position: relative; width: 100%; height: 100svh;
    overflow: hidden; background: #08080a; padding-top: 64px;
  }
  .hero-track { position: absolute; inset: 0; z-index: 0; }
  .hero-slide {
    position: absolute; inset: 0; opacity: 0;
    transition: opacity 1.2s cubic-bezier(0.4,0,0.2,1);
  }
  .hero-slide.active { opacity: 1; }
  .slide-img, .slide-video { width:100%; height:100%; object-fit:cover; display:block; }
  .slide-ph { width:100%; height:100%; background: linear-gradient(155deg,#1a2a3e,#06080e); }
  .slide-veil {
    position: absolute; inset: 0;
    background:
      linear-gradient(to top, rgba(4,6,10,0.88) 0%, rgba(4,6,10,0.08) 50%, transparent 70%),
      linear-gradient(to bottom, rgba(4,6,10,0.4) 0%, transparent 28%);
  }
  .hero-content {
    position: absolute; bottom: 0; left: 0; right: 0; z-index: 3;
    padding: 0 var(--pad-x,5vw) 7rem; display: flex; flex-direction: column; align-items: center; text-align: center;
  }
  .hero-loc {
    font-family: 'Courier New',monospace; font-size: 0.58rem;
    letter-spacing: 0.34em; text-transform: uppercase;
    color: rgba(248,247,244,0.4); margin-bottom: 1.25rem;
  }
  .hero-title {
    font-family: var(--font-display,'Tenor Sans',serif);
    font-size: clamp(1.75rem,5vw,3.5rem); font-weight: 400;
    letter-spacing: 0.03em; text-transform: uppercase;
    line-height: 1.1; display: flex; flex-direction: column; margin-bottom: 2rem; align-items: center; text-align: center;
  }
  .ht-1 { color: #F8F7F4; }
  .ht-2 { color: rgba(248,247,244,0.22); }
  .hero-more {
    display: inline-flex; align-items: center; gap: 0.75rem;
    font-family: 'Courier New',monospace; font-size: 0.62rem;
    letter-spacing: 0.22em; text-transform: uppercase;
    color: rgba(248,247,244,0.65); text-decoration: none; transition: color 0.2s;
  }
  .hero-more:hover { color: #F8F7F4; }
  .hero-arrows {
    position: absolute; bottom: 2.5rem; left: var(--pad-x,5vw);
    z-index: 4; display: flex; gap: 1rem;
  }
  .hero-arr-btn {
    background: none; border: none; cursor: pointer;
    font-size: 1.2rem; color: rgba(248,247,244,0.55); padding: 0.25rem 0.5rem;
    transition: color 0.2s; font-family: sans-serif;
  }
  .hero-arr-btn:hover { color: #F8F7F4; }
  .hero-dots {
    position: absolute; bottom: 2.75rem; left: 50%; transform: translateX(-50%);
    z-index: 4; display: flex; align-items: center; gap: 6px;
  }
  .hero-dot {
    width: 2px; height: 20px; background: rgba(248,247,244,0.3);
    border: none; cursor: pointer; padding: 0; transition: background 0.3s, height 0.3s;
  }
  .hero-dot.active { background: #F8F7F4; height: 28px; }
  .hero-label {
    position: absolute; top: 5.5rem; right: var(--pad-x,5vw); z-index: 4;
  }
  .hero-label span {
    font-family: 'Courier New',monospace; font-size: 0.5rem;
    letter-spacing: 0.22em; text-transform: uppercase;
    color: rgba(248,247,244,0.32); writing-mode: vertical-rl; transform: rotate(180deg);
  }

  /* ── PILLARS ── */
  .pillars {
    display: grid; grid-template-columns: 1fr;
    background: var(--bg,#F8F7F4); padding: 6rem var(--pad-x,5vw) 0; gap: 3rem;
  }
  .pillar { display: flex; flex-direction: column; gap: 0.75rem; }
  .pillar-n { font-family:'Courier New',monospace; font-size:0.54rem; letter-spacing:0.28em; color:var(--navy,#1A3A6B); margin-bottom:0.35rem; }
  .pillar-title { font-family:var(--font-display,'Tenor Sans',serif); font-size:1.3rem; font-weight:600; letter-spacing:0.1em; text-transform:uppercase; color:var(--ink,#1A1A1A); line-height:1.15; }
  .pillar-body { font-size:0.95rem; line-height:1.9; color:var(--ink-light,#6B6B6B); font-weight:400; max-width:300px; }

  /* ── WORKS ── */
  .works { padding: 6rem 0 4rem; background: var(--bg,#F8F7F4); }
  .works-head {
    display: flex; justify-content: flex-start; align-items: center; position: relative;
    padding: 0 var(--pad-x,5vw) 1.5rem;
  }
  .works-title {
    font-family: var(--font-display,'Tenor Sans',serif);
    font-size: clamp(2rem,5vw,3rem); font-weight: 700;
    letter-spacing: 0.04em; text-transform: uppercase; color: var(--ink,#1A1A1A);
  }
  .works-nav { display: flex; gap: 0.75rem; }
  .works-arr {
    background: none; border: none; cursor: pointer;
    font-size: 1.2rem; color: var(--ink-light,#6B6B6B);
    padding: 0.3rem 0.5rem; transition: color 0.2s; font-family: sans-serif;
  }
  .works-arr:hover { color: var(--ink,#1A1A1A); }

  /* Category tabs */
  .works-cats {
    display: flex; gap: 0; padding: 0 var(--pad-x,5vw);
    border-bottom: 0.5px solid rgba(26,26,26,0.1);
    margin-bottom: 0; overflow-x: auto; scrollbar-width: none;
  }
  .works-cats::-webkit-scrollbar { display: none; }
  .cat-btn {
    font-family:var(--font-body,'Inter',sans-serif); font-size:0.75rem; letter-spacing:0.14em;
    text-transform:uppercase; color:#1A1A1A;
    background:none; border:none; cursor:pointer;
    padding:0.65rem 1.5rem 0.65rem 0;
    position:relative; white-space:nowrap; transition:color 0.2s; flex-shrink:0;
  }
  .cat-btn::after {
    content:''; position:absolute; bottom:-0.5px; left:0; right:0;
    height:2px; background:var(--navy,#1A3A6B);
    transform:scaleX(0); transform-origin:left; transition:transform 0.3s;
  }
  .cat-btn:hover { color:var(--ink,#1A1A1A); }
  .cat-btn.active { color:var(--ink,#1A1A1A); font-weight:600; }
  .cat-btn.active::after { transform:scaleX(1); }

  /* Track */
  .works-wrap { overflow: hidden; cursor: grab; user-select: none; }
  .works-wrap:active { cursor: grabbing; }
  .works-track {
    display: flex; gap: 3px;
    transition: transform 0.5s cubic-bezier(0.4,0,0.2,1); will-change: transform;
  }

  /* ── PIA-SCALE CARD — near full-screen height ── */
  .works-card {
    flex-shrink: 0;
    width: 78vw; /* single card dominates viewport */
    background: var(--bg,#F8F7F4);
  }
  .works-card.hidden { display: none; }
  .works-link { display: block; text-decoration: none; color: inherit; }

  .works-img-wrap {
    position: relative; width: 100%; overflow: hidden;
    background: #E0DDD8;
    /* PIA: near full viewport height */
    aspect-ratio: 4/5; height: auto;
  }
  .works-img {
    width:100%; height:100%; object-fit:cover; display:block;
    transition: transform 1.3s cubic-bezier(0.4,0,0.2,1);
  }
  .works-ph { width:100%; height:100%; background:#E0DDD8; }
  .works-link:hover .works-img { transform: scale(1.03); }

  /* Overlay — PIA style with number, category, title, Read More */
  .works-overlay {
    position:absolute; inset:0; display:flex; flex-direction:column;
    justify-content:space-between; padding:1.75rem;
    background:rgba(26,58,107,0); transition:background 0.4s;
  }
  .works-link:hover .works-overlay { background:rgba(10,18,36,0.52); }
  .works-overlay-top { display:flex; justify-content:space-between; align-items:flex-start; }
  .works-num {
    font-family:'Courier New',monospace; font-size:1rem; font-weight:700;
    color:rgba(248,247,244,0.9);
  }
  .works-cat-tag {
    font-family:'Courier New',monospace; font-size:0.52rem; letter-spacing:0.2em;
    text-transform:uppercase; color:rgba(248,247,244,0.75);
    background:rgba(4,6,10,0.5); padding:0.28rem 0.7rem;
  }
  .works-overlay-bot { display:flex; flex-direction:column; gap:0.65rem; }
  .works-overlay-title {
    font-family:var(--font-display,'Tenor Sans',serif);
    font-size:clamp(1.2rem,3vw,2rem); font-weight:500;
    letter-spacing:0.05em; text-transform:uppercase;
    color:#F8F7F4; line-height:1.1;
    opacity:0; transform:translateY(10px);
    transition:opacity 0.4s, transform 0.4s;
  }
  .works-link:hover .works-overlay-title { opacity:1; transform:none; }
  .works-read {
    font-family:'Courier New',monospace; font-size:0.62rem; letter-spacing:0.24em;
    text-transform:uppercase; color:rgba(248,247,244,0.8);
    opacity:0; transform:translateY(6px);
    transition:opacity 0.35s 0.05s, transform 0.35s 0.05s;
  }
  .works-link:hover .works-read { opacity:1; transform:none; }

  .works-info { padding:1rem 0.5rem 1.5rem; }
  .works-meta { font-family:'Courier New',monospace; font-size:0.48rem; letter-spacing:0.22em; color:var(--navy,#1A3A6B); margin-bottom:0.4rem; }
  .works-name { font-family:var(--font-display,'Tenor Sans',serif); font-size:clamp(1rem,2.5vw,1.35rem); font-weight:600; letter-spacing:0.05em; text-transform:uppercase; color:var(--ink,#1A1A1A); line-height:1.2; }

  /* Works dots */
  .works-dots { display:flex; justify-content:center; gap:6px; padding:1.5rem var(--pad-x,5vw) 0; }
  .works-dot { width:2px; height:16px; background:rgba(26,26,26,0.18); border:none; cursor:pointer; padding:0; transition:background 0.3s, height 0.3s; }
  .works-dot.active { background:var(--navy,#1A3A6B); height:22px; }
  .works-foot { padding:2.5rem var(--pad-x,5vw) 0; text-align:center; }
  .works-empty { padding:3rem var(--pad-x,5vw); font-size:0.9rem; color:var(--ink-light,#6B6B6B); }
