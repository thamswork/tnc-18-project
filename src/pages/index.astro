---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
import TrustedBy from "../components/TrustedBy.astro";
import { getCollection } from "astro:content";
import homepageData from "../content/pages/homepage.json";
import contactData from "../content/settings/contact.json";

const allProjects = await getCollection("projects");
const projects = allProjects.sort((a, b) => b.data.year - a.data.year);

function slug(t: string) {
  return t.toLowerCase().replace(/[\u2018\u2019'']/g, "").replace(/[^a-z0-9]+/g, "-").replace(/^-|-$/g, "");
}

const slides: string[] = (homepageData.hero_slides && homepageData.hero_slides.length > 0)
  ? homepageData.hero_slides.map((s: any) => typeof s === "string" ? s : s.image)
  : homepageData.hero_image ? [homepageData.hero_image] : [];

const categories = ["All", ...new Set(projects.map(p => p.data.category).filter(Boolean))] as string[];
const FB_PAGE_URL = contactData.facebook || "https://www.facebook.com/tnc18";
const IG_HANDLE = (contactData.instagram || "https://instagram.com/tnc18").replace("https://instagram.com/","@").replace("https://www.instagram.com/","@");
const IG_URL = contactData.instagram || "https://instagram.com/tnc18";
---

<Layout title="TNC BUILD STUDIO — Retail & Interior Design Bangkok">

  <!-- ── HERO ── -->
  <section class="hero" id="hero">
    <div class="hero-track" id="hero-track">
      {slides.length > 0
        ? slides.map((src, i) => (
            <div class={`hero-slide ${i === 0 ? "active" : ""}`}>
              <img src={src} alt="" class="slide-img" loading={i === 0 ? "eager" : "lazy"} />
              <div class="slide-veil"></div>
            </div>
          ))
        : (
          <div class="hero-slide active">
            {homepageData.hero_video
              ? <video autoplay muted loop playsinline class="slide-video"><source src={homepageData.hero_video} type="video/mp4" /></video>
              : <div class="slide-ph"></div>
            }
            <div class="slide-veil"></div>
          </div>
        )
      }
    </div>

    <div class="hero-content">
      <div class="hero-words">
        <p class="hero-loc">Bangkok · Thailand</p>
        <h1 class="hero-title">
          <span class="hero-line" data-line="0">
            <span class="hero-line-inner">{homepageData.hero_line1}</span>
          </span>
          <span class="hero-line" data-line="1">
            <span class="hero-line-inner hero-line-dim">{homepageData.hero_line2}</span>
          </span>
        </h1>
        <div class="hero-cta-wrap">
          <a href="/about-services" class="hero-more">More About Us <span class="hero-arrow">→</span></a>
          <a href="/portfolio" class="hero-more hero-more-sec">View Work <span class="hero-arrow">↓</span></a>
        </div>
      </div>
    </div>

    {slides.length > 1 && (
      <div class="hero-dots" id="hero-dots">
        {slides.map((_, i) => (
          <button class={`hero-dot ${i === 0 ? "active" : ""}`} data-slide={i} aria-label={`Slide ${i+1}`}></button>
        ))}
      </div>
    )}

    <div class="hero-scroll-hint">
      <span class="scroll-line"></span>
      <span class="scroll-label">Scroll</span>
    </div>
  </section>

  <TrustedBy />

  <!-- ── PILLARS ── -->
  <section class="pillars" id="pillars">
    <div class="pillars-divider"></div>
    <div class="pillars-grid">
      {[
        { n: "01", title: "Fast Delivery",  body: "Tight lead times. Built for urgent retail timelines without compromising quality." },
        { n: "02", title: "Senior Only",    body: "You work directly with founding partners. Zero junior hand-offs, from brief to handover." },
        { n: "03", title: "24 / 7 Support", body: "Unlimited revisions. Always reachable. Always accountable throughout your project." },
      ].map((p, i) => (
        <div class="pillar" data-pillar={i}>
          <span class="pillar-n" data-count={p.n}>{p.n}</span>
          <h3 class="pillar-title">{p.title}</h3>
          <p class="pillar-body">{p.body}</p>

        </div>
      ))}
    </div>
  </section>

  <!-- ── WORKS — vertical scroll stack ── -->
  <section class="works" id="works">
    <div class="works-header">
      <div class="works-header-left">
        <h2 class="works-title">Works</h2>
        <div class="works-cats" id="works-cats">
          {categories.map((cat, i) => (
            <button class={`cat-btn ${i === 0 ? "active" : ""}`} data-cat={cat}>{cat}</button>
          ))}
        </div>
      </div>
      <a href="/portfolio" class="works-view-all">View All <span>→</span></a>
    </div>

    <!-- Vertical scroll stack -->
    <div class="works-stack" id="works-stack">
      {projects.map((p, i) => (
        <article class="wcard" data-category={p.data.category} data-index={i}>
          <a href={`/portfolio/${slug(p.data.title)}`} class="wcard-link">
            <div class="wcard-img-wrap">
              {p.data.cover && !p.data.cover.includes("placeholder")
                ? <img src={p.data.cover} alt={p.data.title} loading={i < 2 ? "eager" : "lazy"} class="wcard-img" />
                : <div class="wcard-ph"></div>
              }
              <div class="wcard-overlay"></div>
            </div>
            <div class="wcard-info">
              <span class="wcard-num">{String(i+1).padStart(2,"0")}</span>
              <div class="wcard-meta">
                <span class="wcard-cat">{p.data.category}</span>
                {p.data.location && <span class="wcard-loc">{p.data.location}</span>}
              </div>
              <span class="wcard-read-wrap wcard-read">View Project →</span>
              <h3 class="wcard-name">{p.data.title}</h3>
              <span class="wcard-year">{p.data.year}</span>
            </div>
          </a>
        </article>
      ))}
      {projects.length === 0 && (
        <div class="works-empty">No projects yet. <a href="/admin">Add in CMS →</a></div>
      )}
    </div>
  </section>

  <!-- ── DIVIDER ── -->
  <div class="section-divider">
    <div class="section-divider-line"></div>
    <span class="section-divider-label">Our Philosophy</span>
    <div class="section-divider-line"></div>
  </div>

  <!-- ── STATEMENT ── -->
  <section class="statement">
    <div class="statement-bg">
      {homepageData.statement_image
        ? <img src={homepageData.statement_image} alt="" class="statement-img" />
        : <div class="statement-ph"></div>
      }
      <div class="statement-veil"></div>
    </div>
    <div class="statement-body">
      <blockquote class="statement-q" id="statement-q">{homepageData.statement}</blockquote>
      <a href="/about-services" class="statement-link">About the Studio →</a>
    </div>
  </section>

  <!-- ── NEWS ── -->
  <section class="news">
    <div class="news-head">
      <h2 class="news-title">News</h2>
      <a href={FB_PAGE_URL} target="_blank" rel="noopener" class="news-more">View More →</a>
    </div>
    <div class="news-embed-wrap">
      <div id="fb-root"></div>
      <div class="fb-page"
        data-href={FB_PAGE_URL} data-tabs="timeline" data-width="500"
        data-height="600" data-small-header="true" data-adapt-container-width="true"
        data-hide-cover="false" data-show-facepile="false">
        <div class="fb-fallback">
          <p class="fb-fallback-text">Loading news from Facebook...</p>
          <a href={FB_PAGE_URL} target="_blank" rel="noopener" class="fb-fallback-link">View on Facebook →</a>
        </div>
      </div>
    </div>
    <div class="news-foot">
      <a href={FB_PAGE_URL} target="_blank" rel="noopener" class="btn-ghost">View More →</a>
    </div>
  </section>

  <!-- ── INSTAGRAM ── -->
  <section class="instagram">
    <div class="ig-head">
      <h2 class="ig-title">Instagram</h2>
      <div class="ig-follow">
        <span class="ig-follow-label">Follow Us</span>
        <a href={IG_URL} target="_blank" rel="noopener" class="ig-handle">{IG_HANDLE}</a>
      </div>
    </div>
    <div class="ig-grid">
      {Array.from({length: 9}).map((_, i) => (
        <a href={IG_URL} target="_blank" rel="noopener" class="ig-item">
          <div class="ig-ph"></div>
          <div class="ig-item-overlay">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1.5" fill="white" stroke="none"/></svg>
          </div>
        </a>
      ))}
    </div>
    <div class="ig-foot">
      <a href={IG_URL} target="_blank" rel="noopener" class="ig-view-btn">View on Instagram</a>
    </div>
  </section>

  <Footer />
</Layout>

<script is:inline>
  window.fbAsyncInit = function() { FB.init({ xfbml: true, version: "v19.0" }); };
  (function(d,s,id){ var js,fjs=d.getElementsByTagName(s)[0]; if(d.getElementById(id))return;
    js=d.createElement(s); js.id=id; js.src="https://connect.facebook.net/en_US/sdk.js";
    fjs.parentNode.insertBefore(js,fjs); }(document,"script","facebook-jssdk"));
</script>

<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

/* ══ HERO ══════════════════════════════════════════════════════════ */
.hero {
  position: relative;
  width: 100%; height: 100svh;
  overflow: hidden;
  background: #060608;
}

.hero-track { position: absolute; inset: 0; z-index: 0; }
.hero-slide { position: absolute; inset: 0; opacity: 0; transition: opacity 1.4s cubic-bezier(0.4,0,0.2,1); }
.hero-slide.active { opacity: 1; }
.slide-img, .slide-video { width: 100%; height: 100%; object-fit: cover; display: block; }
.slide-ph { width: 100%; height: 100%; background: linear-gradient(155deg,#0e1a2e,#060608); }

.slide-veil {
  position: absolute; inset: 0;
  background:
    linear-gradient(to top,  rgba(4,6,10,0.92) 0%, rgba(4,6,10,0.4) 40%, rgba(4,6,10,0.08) 65%),
    linear-gradient(to right, rgba(4,6,10,0.6) 0%, rgba(4,6,10,0.0) 60%);
}

/* Content — left-aligned, bottom-anchored */
.hero-content {
  position: absolute;
  inset: 0; z-index: 3;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 var(--pad-x,5vw);
}

.hero-words {
  display: flex; flex-direction: column; gap: 0;
  max-width: 720px; width: 100%;
  text-align: center;
  align-items: center;
  will-change: transform;
  transform: translateX(0) translateY(0);
  transition: text-align 0.3s;
  flex-shrink: 0;
}

.hero-loc {
  font-size: 0.6rem; font-weight: 500;
  letter-spacing: 0.28em; text-transform: uppercase;
  color: rgba(244,243,239,0.45);
  margin-bottom: 1.5rem;
  text-align: center;
  width: 100%;
}

/* Word-reveal: each line clips from bottom */
.hero-title {
  font-size: clamp(1.8rem, 4vw, 3.75rem);
  font-weight: 800;
  letter-spacing: -0.03em;
  line-height: 1.0;
  text-transform: uppercase;
  display: flex; flex-direction: column;
  margin-bottom: 3rem;
  align-items: center;
  gap: 0.15em;
  width: 100%;
  text-align: center;
}

.hero-line {
  overflow: hidden;
  display: block;
}

.hero-line-inner {
  display: block;
  color: #F4F3EF;
  transform: translateY(110%);
  transition: transform 1.1s cubic-bezier(0.16,1,0.3,1);
  will-change: transform;
}
.hero-line-inner.hero-line-dim { color: rgba(244,243,239,0.5); }
.hero-line[data-line="1"] .hero-line-inner { transition-delay: 0.12s; }

/* Triggered by JS */
.hero-title.revealed .hero-line-inner { transform: translateY(0); }

.hero-cta-wrap {
  display: flex; align-items: center; gap: 2.5rem;
  justify-content: center;
  width: 100%;
  opacity: 0;
  transition: opacity 0.8s cubic-bezier(0.16,1,0.3,1);
}
.hero-cta-wrap.visible { opacity: 1; }

.hero-more {
  display: inline-flex; align-items: center; gap: 0.5rem;
  font-size: 0.7rem; font-weight: 600;
  letter-spacing: 0.1em; text-transform: uppercase;
  color: rgba(244,243,239,0.8); text-decoration: none;
  border-bottom: 1px solid rgba(244,243,239,0.25);
  padding-bottom: 2px;
  transition: color 0.2s, border-color 0.2s;
}
.hero-more:hover { color: #F4F3EF; border-color: rgba(244,243,239,0.7); }
.hero-more-sec { color: rgba(244,243,239,0.45); }
.hero-more-sec:hover { color: rgba(244,243,239,0.8); }

/* Dots */
.hero-dots {
  position: absolute; bottom: 2.5rem; right: var(--pad-x,5vw);
  z-index: 4; display: flex; flex-direction: column; gap: 6px;
}
.hero-dot {
  width: 16px; height: 2px;
  background: rgba(244,243,239,0.25);
  border: none; cursor: pointer; padding: 0;
  transition: background 0.3s, width 0.3s;
}
.hero-dot.active { background: #F4F3EF; width: 28px; }

/* Scroll hint */
.hero-scroll-hint {
  position: absolute; bottom: 2.5rem; left: var(--pad-x,5vw);
  z-index: 4; display: flex; flex-direction: column; align-items: center; gap: 8px;
  opacity: 0; animation: fadeIn 1s 1.4s forwards;
}
@keyframes fadeIn { to { opacity: 1; } }
.scroll-line {
  width: 1px; height: 40px;
  background: rgba(244,243,239,0.3);
  animation: scrollPulse 2s 1.5s infinite;
}
@keyframes scrollPulse {
  0%   { transform: scaleY(1);   opacity: 0.3; }
  50%  { transform: scaleY(0.5); opacity: 0.8; }
  100% { transform: scaleY(1);   opacity: 0.3; }
}
.scroll-label {
  font-size: 0.5rem; font-weight: 600;
  letter-spacing: 0.22em; text-transform: uppercase;
  color: rgba(244,243,239,0.3);
  writing-mode: vertical-rl;
}

/* ══ PILLARS ════════════════════════════════════════════════════════ */
.pillars {
  background: var(--bg, #F4F3EF);
  padding: 2.5rem var(--pad-x,5vw) 2.5rem;
}

.pillars-divider {
  width: 100%; height: 1px;
  background: rgba(17,17,17,0.08);
  margin-bottom: 2rem;
}

.pillars-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1.5rem;
}

@media (min-width: 768px) {
  .pillars-grid { grid-template-columns: repeat(3,1fr); gap: 0; }
  .pillar { padding-right: 2.5rem; border-right: 1px solid rgba(17,17,17,0.06); }
  .pillar:last-child { padding-right: 0; border-right: none; }
  .pillar { padding-left: 1.75rem; }
  .pillar:first-child { padding-left: 0; }
}

.pillar {
  display: flex; flex-direction: column; gap: 0.85rem;
  opacity: 0; transform: translateY(30px);
  transition: opacity 0.7s cubic-bezier(0.16,1,0.3,1), transform 0.7s cubic-bezier(0.16,1,0.3,1);
}
.pillar.in-view { opacity: 1; transform: none; }
.pillar:nth-child(1) { transition-delay: 0s; }
.pillar:nth-child(2) { transition-delay: 0.12s; }
.pillar:nth-child(3) { transition-delay: 0.24s; }

.pillar-n {
  font-size: 0.6rem; font-weight: 600;
  letter-spacing: 0.2em; color: var(--navy, #1A3A6B);
  display: block; margin-bottom: 0.5rem;
  position: relative;
}
.pillar-n::after {
  content: attr(data-count);
  position: absolute;
  right: 0; top: -1.5rem;
  font-size: 6rem; font-weight: 800;
  letter-spacing: -0.05em;
  color: rgba(17,17,17,0.04);
  line-height: 1;
  pointer-events: none;
  user-select: none;
}

.pillar-title {
  font-size: 0.95rem; font-weight: 700;
  letter-spacing: -0.01em; text-transform: uppercase;
  color: var(--ink, #111111); line-height: 1.1;
}

.pillar-body {
  font-size: 0.78rem; line-height: 1.7;
  color: var(--ink-light, #777777); font-weight: 400;
}

/* Animated progress bar under each pillar */


/* ══ WORKS ══════════════════════════════════════════════════════════ */
.works {
  padding: 3rem 0 2rem;
  background: var(--bg, #F4F3EF);
}

.works-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  padding: 0 var(--pad-x,5vw) 2.5rem;
  border-bottom: 1px solid rgba(17,17,17,0.07);
}

.works-header-left { display: flex; flex-direction: column; gap: 1.25rem; }

.works-title {
  font-size: clamp(2.5rem,6vw,5rem);
  font-weight: 800;
  letter-spacing: -0.04em;
  text-transform: uppercase;
  color: var(--ink, #111111);
  line-height: 0.92;
}

.works-cats {
  display: flex; gap: 0; overflow-x: auto; scrollbar-width: none;
}
.works-cats::-webkit-scrollbar { display: none; }

.cat-btn {
  font-size: 0.65rem; font-weight: 500;
  letter-spacing: 0.1em; text-transform: uppercase;
  color: var(--ink-light, #777); background: none; border: none;
  cursor: pointer; padding: 0.4rem 1.25rem 0.4rem 0;
  position: relative; white-space: nowrap; transition: color 0.2s; flex-shrink: 0;
}
.cat-btn::after {
  content: ""; position: absolute;
  bottom: 0; left: 0; right: 0; height: 1.5px;
  background: var(--ink,#111); transform: scaleX(0);
  transform-origin: left; transition: transform 0.3s cubic-bezier(0.4,0,0.2,1);
}
.cat-btn.active { color: var(--ink,#111); font-weight: 600; }
.cat-btn.active::after { transform: scaleX(1); }

.works-view-all {
  font-size: 0.65rem; font-weight: 600;
  letter-spacing: 0.1em; text-transform: uppercase;
  color: var(--ink-light, #777); text-decoration: none;
  border-bottom: 1px solid rgba(17,17,17,0.2);
  padding-bottom: 2px; white-space: nowrap;
  transition: color 0.2s, border-color 0.2s;
  flex-shrink: 0;
}
.works-view-all:hover { color: var(--ink,#111); border-color: var(--ink,#111); }

/* Vertical stack — each card slides in from bottom as you scroll */
.works-stack {
  display: flex; flex-direction: column;
  gap: 1px;
  background: rgba(17,17,17,0.06);
  margin-top: 1px;
  margin-bottom: 0;
}

.wcard {
  background: var(--bg, #F4F3EF);
  opacity: 0; transform: translateY(40px);
  transition: opacity 0.75s cubic-bezier(0.16,1,0.3,1), transform 0.75s cubic-bezier(0.16,1,0.3,1);
}
.wcard.in-view { opacity: 1; transform: none; }
.wcard.hidden { display: none; }

.wcard-link {
  display: block;
  text-decoration: none; color: inherit;
  position: relative;
}

/* Image */
.wcard-img-wrap {
  position: relative; width: 100%; overflow: hidden;
  background: var(--bg-dark, #ECEAE3);
  aspect-ratio: 16/9;
}
@media (min-width: 768px) {
  .wcard-img-wrap { aspect-ratio: 21/9; }
}

.wcard-img {
  width: 100%; height: 100%; object-fit: cover; display: block;
  transition: transform 1.2s cubic-bezier(0.4,0,0.2,1);
}
.wcard-ph { width: 100%; height: 100%; background: var(--bg-dark); }
.wcard-link:hover .wcard-img { transform: scale(1.04); }

.wcard-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(to top, rgba(10,18,36,0.85) 0%, rgba(10,18,36,0.2) 50%, rgba(10,18,36,0) 100%);
  transition: background 0.4s;
}
.wcard-link:hover .wcard-overlay {
  background: linear-gradient(to top, rgba(10,18,36,0.95) 0%, rgba(10,18,36,0.35) 60%, rgba(10,18,36,0) 100%);
}
.wcard-read {
  font-size: 0.6rem; font-weight: 600; letter-spacing: 0.18em;
  text-transform: uppercase; color: rgba(244,243,239,0.7);
  opacity: 0; transform: translateX(6px);
  transition: opacity 0.3s, transform 0.3s;
}
.wcard-link:hover .wcard-read { opacity: 1; transform: none; }

/* Info panel — overlaid at bottom of image */
.wcard-info {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  padding: 1.5rem 2rem 1.75rem;
  display: grid;
  grid-template-columns: auto 1fr auto;
  grid-template-rows: auto auto;
  gap: 0.2rem 1rem;
  align-items: end;
  z-index: 2;
}
.wcard-num {
  grid-column: 1; grid-row: 1 / 3;
  align-self: end;
}
.wcard-meta {
  grid-column: 2; grid-row: 1;
  align-self: end;
}
.wcard-name {
  grid-column: 2; grid-row: 2;
}
.wcard-year {
  grid-column: 3; grid-row: 2;
  align-self: end; text-align: right;
}
.wcard-read-wrap {
  grid-column: 3; grid-row: 1;
  align-self: end; text-align: right;
}

.wcard-num {
  font-size: 0.55rem; font-weight: 600;
  letter-spacing: 0.2em; color: rgba(244,243,239,0.5);
}

.wcard-meta {
  display: flex; align-items: center; gap: 1rem;
  flex-wrap: wrap; flex: 1;
}

.wcard-cat {
  font-size: 0.6rem; font-weight: 600; letter-spacing: 0.14em;
  text-transform: uppercase; color: rgba(244,243,239,0.7);
}

.wcard-loc {
  font-size: 0.6rem; font-weight: 400; letter-spacing: 0.08em;
  text-transform: uppercase; color: rgba(244,243,239,0.45);
}

.wcard-name {
  font-size: clamp(1.1rem, 2vw, 1.75rem);
  font-weight: 700; letter-spacing: -0.025em;
  color: #F4F3EF; line-height: 1.1;
  transition: color 0.2s;
}
.wcard-link:hover .wcard-name { color: #fff; }

.wcard-year {
  font-size: 0.6rem; font-weight: 400;
  color: rgba(244,243,239,0.45); letter-spacing: 0.06em;
  flex-shrink: 0; align-self: flex-end;
}

.works-empty {
  padding: 4rem var(--pad-x,5vw);
  font-size: 0.9rem; color: var(--ink-light);
}
.works-empty a { color: var(--navy); }

/* ══ DIVIDER ════════════════════════════════════════════════════════ */
.section-divider {
  display: flex;
  align-items: center;
  gap: 1.5rem;
  padding: 2.5rem var(--pad-x, 5vw);
  background: var(--bg, #F4F3EF);
}
.section-divider-line {
  flex: 1;
  height: 1px;
  background: rgba(17,17,17,0.12);
}
.section-divider-label {
  font-size: 0.55rem;
  font-weight: 600;
  letter-spacing: 0.26em;
  text-transform: uppercase;
  color: var(--ink-light, #777);
  white-space: nowrap;
  flex-shrink: 0;
}

/* ══ STATEMENT ══════════════════════════════════════════════════════ */
.statement {
  position: relative; width: 100%;
  min-height: 55vh;
  display: flex; align-items: center;
  overflow: hidden;
  margin-top: 0;
}

.statement-bg { position: absolute; inset: 0; z-index: 0; }
.statement-img { width: 100%; height: 100%; object-fit: cover; display: block; }
.statement-ph { width: 100%; height: 100%; background: linear-gradient(135deg,#0e1a2e,#060608); }
.statement-veil { position: absolute; inset: 0; background: rgba(6,8,14,0.68); }

.statement-body {
  position: relative; z-index: 2;
  padding: 5rem var(--pad-x,5vw);
  display: flex; flex-direction: column;
  align-items: flex-start; gap: 1.5rem;
  max-width: 800px;
}

.statement-q {
  font-size: clamp(1.4rem, 3vw, 2.25rem);
  font-weight: 700;
  letter-spacing: -0.025em;
  line-height: 1.25;
  color: #F4F3EF;
  font-style: italic;
}

.statement-link {
  font-size: 0.7rem; font-weight: 600;
  letter-spacing: 0.1em; text-transform: uppercase;
  color: rgba(244,243,239,0.6); text-decoration: none;
  border-bottom: 1px solid rgba(244,243,239,0.2);
  padding-bottom: 2px;
  transition: color 0.2s, border-color 0.2s;
}
.statement-link:hover { color: #F4F3EF; border-color: rgba(244,243,239,0.6); }

/* ══ NEWS ═══════════════════════════════════════════════════════════ */
.news { padding: 6rem var(--pad-x,5vw); background: var(--bg-dark,#ECEAE3); }
.news-head { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 2.5rem; }
.news-title { font-size: clamp(1.75rem,4vw,2.5rem); font-weight: 800; letter-spacing: -0.03em; text-transform: uppercase; color: var(--ink,#111); }
.news-more { font-size: 0.6rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-light,#777); text-decoration: none; transition: color 0.2s; }
.news-more:hover { color: var(--ink,#111); }
.news-embed-wrap { width: 100%; max-width: 540px; min-height: 400px; background: #fff; overflow: hidden; }
.fb-fallback { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 3rem; gap: 1rem; min-height: 300px; }
.fb-fallback-text { font-size: 0.85rem; color: var(--ink-light,#777); }
.fb-fallback-link { font-size: 0.6rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--navy,#1A3A6B); text-decoration: none; border: 1px solid var(--navy,#1A3A6B); padding: 0.65rem 1.25rem; transition: background 0.2s, color 0.2s; }
.fb-fallback-link:hover { background: var(--navy,#1A3A6B); color: #fff; }
.news-foot { margin-top: 2rem; }
.btn-ghost { display: inline-flex; align-items: center; font-size: 0.65rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; text-decoration: none; color: var(--ink,#111); background: transparent; padding: 0.85rem 1.75rem; border: 1px solid rgba(17,17,17,0.3); transition: background 0.22s, color 0.22s; }
.btn-ghost:hover { background: var(--ink,#111); color: var(--bg,#F4F3EF); }

/* ══ INSTAGRAM ══════════════════════════════════════════════════════ */
.instagram { padding: 6rem var(--pad-x,5vw); background: var(--bg,#F4F3EF); }
.ig-head { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 2rem; }
.ig-title { font-size: clamp(1.75rem,4vw,2.5rem); font-weight: 800; letter-spacing: -0.03em; text-transform: uppercase; color: var(--ink,#111); flex: 1; }
.ig-follow { display: flex; flex-direction: column; align-items: flex-end; gap: 0.3rem; }
.ig-follow-label { font-size: 0.55rem; font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ink-light,#777); }
.ig-handle { font-size: 0.7rem; font-weight: 600; letter-spacing: 0.06em; color: var(--ink,#111); text-decoration: none; transition: color 0.2s; }
.ig-handle:hover { color: var(--navy,#1A3A6B); }
.ig-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 3px; }
.ig-item { position: relative; display: block; aspect-ratio: 1/1; overflow: hidden; background: var(--bg-dark); text-decoration: none; }
.ig-ph { width: 100%; height: 100%; background: linear-gradient(135deg, #E8E4DE, #D4D0CA); transition: transform 1.1s cubic-bezier(0.4,0,0.2,1); }
.ig-item:hover .ig-ph { transform: scale(1.04); }
.ig-item-overlay { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; background: rgba(26,58,107,0); transition: background 0.35s; }
.ig-item:hover .ig-item-overlay { background: rgba(26,58,107,0.4); }
.ig-item-overlay svg { opacity: 0; transform: scale(0.8); transition: opacity 0.3s, transform 0.3s; }
.ig-item:hover .ig-item-overlay svg { opacity: 1; transform: scale(1); }
.ig-foot { margin-top: 2rem; display: flex; justify-content: center; }
.ig-view-btn { display: inline-flex; align-items: center; gap: 0.5rem; font-size: 0.65rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; text-decoration: none; color: #fff; background: var(--navy,#1A3A6B); padding: 0.85rem 1.75rem; transition: background 0.22s; }
.ig-view-btn:hover { background: var(--navy-mid,#254E8F); }
</style>

<script>
/* ── HERO: center → scroll down to bottom-left ── */
(function() {
  const words = document.querySelector(".hero-words") as HTMLElement;
  const title = document.querySelector(".hero-title") as HTMLElement;
  const cta   = document.querySelector(".hero-cta-wrap") as HTMLElement;
  const hero  = document.getElementById("hero") as HTMLElement;
  if (!words || !hero) return;

  // Reveal lines
  setTimeout(() => { if (title) title.classList.add("revealed"); }, 150);

  let ticking = false;
  function update() {
    const progress = Math.min(1, window.scrollY / (hero.offsetHeight * 0.55));
    // ease-in-out cubic
    const e = progress < 0.5
      ? 4 * progress * progress * progress
      : 1 - Math.pow(-2 * progress + 2, 3) / 2;

    // CSS custom props drive the transform — no absolute positioning
    words.style.setProperty("--hero-progress", String(e));

    // translateX: 0 → negative (move left from center)
    const maxX = -(hero.offsetWidth / 2 - words.offsetWidth / 2 - (window.innerWidth * 0.05));
    // translateY: 0 → positive (move down from center)
    const maxY = hero.offsetHeight / 2 - words.offsetHeight / 2 - (window.innerHeight * 0.08);

    words.style.transform = `translateX(${maxX * e}px) translateY(${maxY * e}px)`;
    words.style.textAlign = e > 0.5 ? "left" : "center";
    (words as any).style.alignItems = e > 0.5 ? "flex-start" : "center";

    if (cta) cta.classList.toggle("visible", e > 0.7);
    ticking = false;
  }

  update();
  window.addEventListener("scroll", () => {
    if (ticking) return;
    requestAnimationFrame(update);
    ticking = true;
  }, { passive: true });
  window.addEventListener("resize", update, { passive: true });
})();

/* ── HERO: slide auto-play ── */
(function() {
  const slides = document.querySelectorAll<HTMLElement>(".hero-slide");
  const dots = document.querySelectorAll<HTMLElement>(".hero-dot");
  if (slides.length <= 1) return;
  let cur = 0, timer: any;
  function goTo(n: number) {
    slides[cur].classList.remove("active");
    dots[cur]?.classList.remove("active");
    cur = (n + slides.length) % slides.length;
    slides[cur].classList.add("active");
    dots[cur]?.classList.add("active");
  }
  function start() { clearInterval(timer); timer = setInterval(() => goTo(cur+1), 5500); }
  dots.forEach((d,i) => d.addEventListener("click", () => { goTo(i); start(); }));
  start();
})();

/* ── PILLARS: in-view trigger ── */
(function() {
  const pillars = document.querySelectorAll<HTMLElement>(".pillar");
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (!e.isIntersecting) return;
      e.target.classList.add("in-view");
      io.unobserve(e.target);
    });
  }, { threshold: 0.15 });
  pillars.forEach(p => io.observe(p));
})();

/* ── WORKS: vertical scroll stack reveal ── */
(function() {
  const cards = document.querySelectorAll<HTMLElement>(".wcard");
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (!e.isIntersecting) return;
      const card = e.target as HTMLElement;
      const idx = parseInt(card.dataset.index || "0");
      setTimeout(() => card.classList.add("in-view"), idx * 60);
      io.unobserve(card);
    });
  }, { threshold: 0.08 });
  cards.forEach(c => io.observe(c));
})();

/* ── WORKS: category filter ── */
(function() {
  document.querySelectorAll(".cat-btn").forEach(btn => {
    btn.addEventListener("click", () => {
      document.querySelectorAll(".cat-btn").forEach(b => b.classList.remove("active"));
      btn.classList.add("active");
      const cat = btn.getAttribute("data-cat");
      document.querySelectorAll<HTMLElement>(".wcard").forEach(c => {
        c.classList.toggle("hidden", cat !== "All" && c.dataset.category !== cat);
      });
    });
  });
})();

/* ── STATEMENT: parallax on scroll ── */
(function() {
  const img = document.querySelector<HTMLElement>(".statement-img");
  if (!img) return;
  let ticking = false;
  window.addEventListener("scroll", () => {
    if (ticking) return;
    requestAnimationFrame(() => {
      const section = img.closest(".statement") as HTMLElement;
      if (!section) { ticking = false; return; }
      const rect = section.getBoundingClientRect();
      const progress = -rect.top / (window.innerHeight + rect.height);
      img.style.transform = `translateY(${progress * 60}px) scale(1.08)`;
      ticking = false;
    });
    ticking = true;
  }, { passive: true });
})();

/* ── GLOBAL REVEAL ── */
const revealIo = new IntersectionObserver((entries) => {
  entries.forEach(e => {
    if (!e.isIntersecting) return;
    e.target.classList.add("revealed");
    revealIo.unobserve(e.target);
  });
}, { threshold: 0.08 });
document.querySelectorAll("[data-reveal]").forEach(el => revealIo.observe(el));
</script>
