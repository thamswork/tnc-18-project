---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

let posts: any[] = [];
let thPosts: any[] = [];
try {
  const all = await getCollection('specbook');
  const sorted = all
    .filter((p: any) => !p.data.draft)
    .sort((a: any, b: any) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
  posts = sorted.filter((p: any) => p.data.lang !== 'th' && !p.id.startsWith('th-'));
  thPosts = sorted.filter((p: any) => p.data.lang === 'th' || p.id.startsWith('th-'));
} catch(e) {
  posts = [];
  thPosts = [];
}

// No hardcoded fallback — use real CMS data only
---

<Layout
  title="Specbook — TNC.18"
  description="Weekly design updates, project insights, and retail interior perspectives from TNC.18 Bangkok."
>
  <Navbar />
  <main class="sb-main">
    <header class="sb-header">
      <div class="sb-header-inner">
        <p class="sb-eyebrow">Activity Feed</p>
        <h1 class="sb-title">Specbook</h1>
        <p class="sb-sub">Weekly updates, project insights, and design perspectives from TNC.18 Bangkok.</p>
      </div>
    </header>

    <section class="sb-feed sb-grid">
      {posts.map((post: any, i: number) => (
        <article class="sb-card" data-reveal>
          <a href={`/specbook/${post.id}`} class="sb-card-link">
            <div class="sb-thumb">
              {post.data.cover
                ? <img src={post.data.cover} alt={post.data.title} loading={i < 2 ? 'eager' : 'lazy'} class="sb-thumb-img" />
                : <div class="sb-thumb-ph"></div>
              }
              <div class="sb-thumb-overlay">
                <span class="sb-read">Read →</span>
              </div>
            </div>
            <div class="sb-info">
              <div class="sb-meta">
                {post.data.category && <span class="sb-cat">{post.data.category}</span>}
                <span class="sb-date">{new Date(post.data.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })}</span>
                {post.data.tags?.slice(0,3).map((tag: string) => (
                  <span class="sb-tag">{tag}</span>
                ))}
              </div>
              <h2 class="sb-card-title">{post.data.title}</h2>
              {post.data.excerpt && <p class="sb-excerpt">{post.data.excerpt}</p>}
            </div>
          </a>
        </article>
      ))}
      {posts.length === 0 && (
        <div class="sb-empty">
          <p>No specbook entries yet. <a href="/admin">Add in CMS →</a></p>
        </div>
      )}
    </section>

    {thPosts.length > 0 && (
      <section class="sb-thai-section">
        <div class="sb-thai-header">
          <span class="sb-thai-label">ภาษาไทย</span>
          <h2 class="sb-thai-title">บทความภาษาไทย</h2>
        </div>
        <div class="sb-thai-grid">
        {thPosts.map((post: any, i: number) => (
          <article class="sb-card" data-reveal>
            <a href={`/specbook/${post.id}`} class="sb-card-link">
              <div class="sb-thumb">
                {post.data.cover
                  ? <img src={post.data.cover} alt={post.data.title} loading={i < 2 ? 'eager' : 'lazy'} class="sb-thumb-img" />
                  : <div class="sb-thumb-ph"></div>
                }
                <div class="sb-thumb-overlay"><span class="sb-read">อ่าน →</span></div>
              </div>
              <div class="sb-info">
                <div class="sb-meta">
                  {post.data.category && <span class="sb-cat">{post.data.category}</span>}
                  <span class="sb-date">{new Date(post.data.date).toLocaleDateString('th-TH', { day: 'numeric', month: 'short', year: 'numeric' })}</span>
                </div>
                <h2 class="sb-card-title sb-card-title-th">{post.data.title}</h2>
                {post.data.excerpt && <p class="sb-excerpt sb-excerpt-th">{post.data.excerpt}</p>}
              </div>
            </a>
          </article>
        ))}
        </div>
      </section>
    )}
  </main>
  <Footer ctaTitle="Want to Work Together?" ctaSub="Senior partners only. We reply within 2 hours." />
<script>
  const cards = document.querySelectorAll('[data-reveal]');
  if ('IntersectionObserver' in window) {
    const io = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('revealed'); io.unobserve(e.target); } });
    }, { threshold: 0.08 });
    cards.forEach((c, i) => {
      (c as HTMLElement).style.transitionDelay = `${(i % 3) * 0.08}s`;
      io.observe(c);
    });
  } else {
    cards.forEach(c => c.classList.add('revealed'));
  }
</script>
</Layout>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  .sb-main { padding-top: 64px; background: var(--bg, #F4F3EF); min-height: 100vh; }

  /* ── HEADER ── */
  .sb-header {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    padding: 4rem var(--pad-x, 5vw) 2.5rem;
    border-bottom: 0.5px solid rgba(26,26,26,0.08);
  }
  @media (min-width: 768px) {
    .sb-header {
      flex-direction: row;
      align-items: flex-end;
      justify-content: space-between;
      gap: 3rem;
    }
  }
  .sb-header-inner { display: flex; flex-direction: column; }
  .sb-eyebrow {
    font-size: 0.55rem; font-weight: 600;
    letter-spacing: 0.26em; text-transform: uppercase;
    color: var(--navy, #1A3A6B);
    margin-bottom: 0.75rem; display: block;
  }
  .sb-title {
    font-size: clamp(2rem, 6vw, 4rem);
    font-weight: 800; letter-spacing: -0.04em;
    line-height: 0.92; color: var(--ink, #111);
    text-transform: uppercase;
  }
  .sb-sub { font-size: 0.85rem; line-height: 1.85; color: var(--ink-light, #6B6B6B); font-weight: 300; margin-top: 1rem; }

  /* ── GRID ── */
  .sb-feed { display: flex; flex-direction: column; }
  .sb-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    padding: 2.5rem var(--pad-x, 5vw) 5rem;
  }
  @media (min-width: 600px) { .sb-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .sb-grid { grid-template-columns: repeat(3, 1fr); gap: 1.75rem; } }

  /* ── CARD ── */
  .sb-card {
    background: var(--bg, #F4F3EF);
    opacity: 0; transform: translateY(24px);
    transition: opacity 0.85s cubic-bezier(0.16,1,0.3,1), transform 0.85s cubic-bezier(0.16,1,0.3,1);
  }
  .sb-card.revealed { opacity: 1; transform: none; }
  .sb-card-link { display: block; text-decoration: none; color: inherit; }
  .sb-thumb {
    position: relative; width: 100%; aspect-ratio: 4/3;
    overflow: hidden; background: var(--bg-dark, #EFEDE8); margin-bottom: 1rem;
  }
  .sb-thumb-img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 1.2s cubic-bezier(0.4,0,0.2,1); }
  .sb-card-link:hover .sb-thumb-img { transform: scale(1.03); }
  .sb-thumb-ph { width: 100%; height: 100%; background: var(--bg-dark, #EFEDE8); }
  .sb-thumb-overlay { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; background: rgba(14,33,64,0); transition: background 0.4s; }
  .sb-card-link:hover .sb-thumb-overlay { background: rgba(14,33,64,0.4); }
  .sb-read { font-family: 'Courier New', monospace; font-size: 0.62rem; letter-spacing: 0.26em; text-transform: uppercase; color: #fff; opacity: 0; transform: translateY(6px); transition: opacity 0.3s, transform 0.3s; }
  .sb-card-link:hover .sb-read { opacity: 1; transform: none; }
  .sb-info { padding: 0 0 1rem; }
  .sb-meta { display: flex; align-items: center; gap: 0.6rem; flex-wrap: wrap; margin-bottom: 0.6rem; }
  .sb-cat { font-family: 'Courier New', monospace; font-size: 0.5rem; letter-spacing: 0.22em; text-transform: uppercase; color: var(--navy, #1A3A6B); font-weight: 600; }
  .sb-date { font-family: 'Courier New', monospace; font-size: 0.5rem; letter-spacing: 0.14em; color: rgba(26,26,26,0.35); }
  .sb-tag { font-family: 'Courier New', monospace; font-size: 0.46rem; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(26,26,26,0.35); border: 0.5px solid rgba(26,26,26,0.15); padding: 0.15rem 0.5rem; }
  .sb-card-title { font-size: clamp(1rem, 2.2vw, 1.4rem); font-weight: 700; letter-spacing: -0.02em; text-transform: uppercase; color: var(--ink, #1A1A1A); line-height: 1.15; margin-bottom: 0.6rem; transition: color 0.2s; }
  .sb-card-link:hover .sb-card-title { color: var(--navy, #1A3A6B); }
  .sb-excerpt { font-size: 0.82rem; line-height: 1.8; color: var(--ink-light, #6B6B6B); font-weight: 300; }
  .sb-empty { padding: 5rem var(--pad-x, 5vw); font-size: 0.875rem; color: var(--ink-light, #6B6B6B); }
  .sb-empty a { color: var(--navy, #1A3A6B); text-decoration: none; }

  /* ── THAI SECTION ── */
  .sb-thai-section {
    padding: 4rem var(--pad-x, 5vw) 6rem;
    border-top: 1px solid rgba(26,26,26,0.08);
    background: var(--bg, #F4F3EF);
  }
  .sb-thai-header { display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 2rem; }
  .sb-thai-label { font-size: 0.55rem; font-weight: 600; letter-spacing: 0.26em; text-transform: uppercase; color: var(--navy, #1A3A6B); font-family: "Noto Sans Thai", system-ui, sans-serif; }
  .sb-thai-title { font-family: "Noto Sans Thai", system-ui, sans-serif; font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 800; letter-spacing: -0.01em; line-height: 1.1; color: var(--ink, #111); }
  .sb-thai-grid { display: grid; grid-template-columns: 1fr; gap: 1.5rem; }
  @media (min-width: 600px) { .sb-thai-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .sb-thai-grid { grid-template-columns: repeat(3, 1fr); gap: 1.75rem; } }
  .sb-card-title-th { font-family: "Noto Sans Thai", system-ui, sans-serif !important; font-weight: 700; text-transform: none !important; letter-spacing: 0 !important; line-height: 1.5; font-size: clamp(1rem, 2.2vw, 1.25rem); -webkit-font-smoothing: antialiased; }
  .sb-excerpt-th { font-family: "Noto Sans Thai", system-ui, sans-serif !important; font-weight: 300; line-height: 2; letter-spacing: 0; font-size: 0.82rem; -webkit-font-smoothing: antialiased; }
  .sb-thai-section .sb-cat, .sb-thai-section .sb-date { letter-spacing: 0.08em; }
</style>