---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import fs from 'node:fs';
import path from 'node:path';
import matter from 'gray-matter';

export async function getStaticPaths() {
  const dir = path.join(process.cwd(), 'src/content/specbook');
  const files = fs.readdirSync(dir).filter(f => f.endsWith('.md'));
  return files.map(filename => ({
    params: { slug: filename.replace('.md', '') },
    props: { filename }
  }));
}

const { filename } = Astro.props;
const { slug } = Astro.params;
const dir = path.join(process.cwd(), 'src/content/specbook');
const raw = fs.readFileSync(path.join(dir, `${filename}`), 'utf8');
const { data: d, content: body } = matter(raw);

const seoTitle = d.seo_title || d.title;
const seoDescription = d.seo_description || d.excerpt || `${d.title} — TNC.18 Bangkok`;
const canonical = `https://tnc-18-project.pages.dev/specbook/${slug}`;
const publishDate = new Date(d.date).toISOString();
const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": seoTitle,
  "description": seoDescription,
  "datePublished": publishDate,
  "author": { "@type": "Organization", "name": "TNC.18" }
});

// Convert markdown to HTML
function mdToHtml(md) {
  let out = md
    .replace(/^### (.+)$/gm, '<h3>$1</h3>')
    .replace(/^## (.+)$/gm, '<h2>$1</h2>')
    .replace(/^# (.+)$/gm, '<h1>$1</h1>')
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2">$1</a>')
    .replace(/^- (.+)$/gm, '<li>$1</li>')
    .replace(/^---$/gm, '<hr>');
  out = out.replace(/(<li>[\s\S]*?<\/li>)(\n<li>[\s\S]*?<\/li>)*/g, (m) => `<ul>${m}</ul>`);
  return out.split(/\n\n+/).map(block => {
    const b = block.trim();
    if (!b) return '';
    if (/^<(h[1-6]|ul|hr)/.test(b)) return b;
    return `<p>${b.replace(/\n/g, ' ')}</p>`;
  }).join('\n');
}
const htmlBody = mdToHtml(body);
---

<Layout title={seoTitle} description={seoDescription}>
  <script type="application/ld+json" set:html={jsonLd} slot="head" />
  <Navbar />

  <main class="art-main">
    <header class="art-hero">
      {d.cover
        ? <img src={d.cover} alt={d.title} class="art-hero-img" loading="eager" />
        : <div class="art-hero-ph"></div>
      }
      <div class="art-hero-veil"></div>
      <div class="art-hero-ui">
        <nav class="art-breadcrumb">
          <a href="/specbook" class="art-back">← Specbook</a>
          {d.category && <span class="art-bc-sep">/</span>}
          {d.category && <span class="art-bc-cat">{d.category}</span>}
        </nav>
        <div class="art-hero-bot">
          <h1 class={`art-title${d.lang === "th" ? " art-title-th" : ""}`}>{d.title}</h1>
          <p class="art-date">
            {new Date(d.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
          </p>
        </div>
      </div>
    </header>

    {d.excerpt && (
      <div class="art-lede" data-reveal>
        <p class={`art-lede-text${d.lang === "th" ? " art-lede-text-th" : ""}`}>{d.excerpt}</p>
      </div>
    )}

    {d.tags && d.tags.length > 0 && (
      <div class="art-tags">
        {d.tags.map((tag: string) => <span class="art-tag">{tag}</span>)}
      </div>
    )}

    <div class={`art-prose${d.lang === "th" ? " art-prose-th" : ""}`} data-reveal set:html={htmlBody}></div>
  </main>

  <Footer ctaTitle="Start a Project" ctaSub="Senior partners only. We reply within 2 hours." />
<script>
  const reveals = document.querySelectorAll('[data-reveal]');
  if ('IntersectionObserver' in window) {
    const io = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) { e.target.classList.add('revealed'); io.unobserve(e.target); }
      });
    }, { threshold: 0.05 });
    reveals.forEach(el => io.observe(el));
  } else {
    reveals.forEach(el => el.classList.add('revealed'));
  }
</script>
</Layout>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  /* ── LAYOUT ── */
  .art-main { padding-top: 72px; background: var(--bg, #F8F7F4); min-height: 100vh; }

  /* ── HERO ── */
  .art-hero { position: relative; width: 100%; height: 65vh; overflow: hidden; background: #0a0e18; }
  .art-hero-img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .art-hero-ph { width: 100%; height: 100%; background: linear-gradient(135deg, #1a2a3e, #0a0e18); }
  .art-hero-veil { position: absolute; inset: 0; background: linear-gradient(to top, rgba(4,6,10,0.88) 0%, rgba(4,6,10,0.15) 55%, rgba(4,6,10,0.25) 100%); }
  .art-hero-ui { position: absolute; inset: 0; display: flex; flex-direction: column; justify-content: space-between; padding: 2rem var(--pad-x, 5vw) 3rem; }
  .art-breadcrumb { display: flex; align-items: center; gap: 0.75rem; }
  .art-back { font-family: 'Courier New', monospace; font-size: 0.58rem; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(248,247,244,0.7); text-decoration: none; transition: color 0.2s; }
  .art-back:hover { color: #F8F7F4; }
  .art-bc-sep { color: rgba(248,247,244,0.25); font-size: 0.6rem; }
  .art-bc-cat { font-family: 'Courier New', monospace; font-size: 0.52rem; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(248,247,244,0.45); }
  .art-hero-bot { display: flex; flex-direction: column; gap: 0.75rem; }
  .art-title { font-size: clamp(1.75rem, 5vw, 3.5rem); font-weight: 800; letter-spacing: -0.02em; text-transform: uppercase; color: #F8F7F4; line-height: 1.05; max-width: 820px; }
  .art-title-th { font-family: "Noto Sans Thai", system-ui, sans-serif !important; font-weight: 800; letter-spacing: 0 !important; text-transform: none !important; line-height: 1.3; }
  .art-date { font-family: 'Courier New', monospace; font-size: 0.52rem; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(248,247,244,0.45); }

  /* ── LEDE ── */
  .art-lede { padding: 3rem var(--pad-x, 5vw); border-bottom: 0.5px solid rgba(26,26,26,0.08); opacity: 0; transform: translateY(20px); transition: opacity 0.85s ease, transform 0.85s ease; }
  .art-lede.revealed { opacity: 1; transform: none; }
  .art-lede-text { font-size: clamp(1rem, 2.2vw, 1.3rem); font-weight: 300; line-height: 1.8; color: var(--ink-mid, #3D3D3D); max-width: 720px; font-style: italic; }
  .art-lede-text-th { font-family: "Noto Sans Thai", system-ui, sans-serif !important; font-style: normal !important; line-height: 2; letter-spacing: 0; -webkit-font-smoothing: antialiased; }

  /* ── TAGS ── */
  .art-tags { display: flex; gap: 0.5rem; flex-wrap: wrap; padding: 1.5rem var(--pad-x, 5vw); }
  .art-tag { font-family: 'Courier New', monospace; font-size: 0.48rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--navy, #1A3A6B); border: 0.5px solid var(--navy, #1A3A6B); padding: 0.25rem 0.65rem; }

  /* ── PROSE ── */
  .art-prose {
    padding: 4rem var(--pad-x, 5vw) 7rem;
    max-width: 780px;
    opacity: 0; transform: translateY(20px);
    transition: opacity 0.85s ease, transform 0.85s ease;
  }
  .art-prose.revealed { opacity: 1; transform: none; }
  .art-prose h2 { font-size: clamp(1.25rem, 2.8vw, 1.75rem); font-weight: 700; letter-spacing: -0.02em; color: var(--ink, #111); line-height: 1.25; margin: 3.5rem 0 1.25rem; padding-top: 0.25rem; border-top: 1px solid rgba(17,17,17,0.07); padding-top: 1.5rem; }
  .art-prose h2:first-child { margin-top: 0; }
  .art-prose h3 { font-size: clamp(0.95rem, 2vw, 1.15rem); font-weight: 600; letter-spacing: -0.01em; color: var(--ink, #111); line-height: 1.45; margin: 2.5rem 0 0.75rem; }
  .art-prose p { font-size: 1rem; line-height: 1.95; color: #444; font-weight: 300; margin-bottom: 1.5rem; }
  .art-prose strong { font-weight: 600; color: var(--ink, #111); }
  .art-prose a { color: var(--navy, #1A3A6B); text-decoration: underline; text-underline-offset: 3px; transition: opacity 0.2s; }
  .art-prose a:hover { opacity: 0.7; }
  .art-prose ul { padding-left: 1.5rem; margin: 0 0 1.5rem; }
  .art-prose li { font-size: 1rem; line-height: 1.9; color: #444; font-weight: 300; margin-bottom: 0.5rem; }
  .art-prose table { width: 100%; border-collapse: collapse; margin: 2.5rem 0; font-size: 0.9rem; border: 1px solid rgba(17,17,17,0.08); }
  .art-prose td { padding: 0.85rem 1.25rem; border-bottom: 1px solid rgba(17,17,17,0.07); color: #444; line-height: 1.6; vertical-align: top; }
  .art-prose tr:first-child td { font-weight: 600; color: var(--ink, #111); background: rgba(17,17,17,0.03); border-bottom: 1.5px solid rgba(17,17,17,0.12); }
  .art-prose hr { border: none; border-top: 1px solid rgba(17,17,17,0.1); margin: 3.5rem 0; }

  /* ── THAI PROSE ── */
  .art-prose-th h2, .art-prose-th h3, .art-prose-th p, .art-prose-th li, .art-prose-th td, .art-prose-th strong {
    font-family: "Noto Sans Thai", system-ui, sans-serif !important;
    text-transform: none !important;
    letter-spacing: 0 !important;
    -webkit-font-smoothing: antialiased;
  }
  .art-prose-th h2 { font-weight: 700; line-height: 1.5; font-size: clamp(1.2rem, 2.5vw, 1.6rem); }
  .art-prose-th h3 { font-weight: 600; line-height: 1.7; font-size: clamp(1rem, 2vw, 1.15rem); }
  .art-prose-th p, .art-prose-th li { line-height: 2.2; font-size: 1rem; font-weight: 300; }
  .art-prose-th strong { font-weight: 600; }

  /* ── RESPONSIVE ── */
  @media (min-width: 768px) {
    .art-hero { height: 75vh; }
    .art-hero-ui { padding: 2.5rem 8vw 3.5rem; }
    .art-lede { padding: 4rem 8vw; }
    .art-tags { padding: 1.5rem 8vw; }
    .art-prose { padding: 5rem 8vw 9rem; }
  }
  @media (min-width: 1200px) {
    .art-prose { padding: 5rem 10vw 9rem; }
    .art-lede { padding: 4rem 10vw; }
    .art-tags { padding: 1.5rem 10vw; }
  }
</style>