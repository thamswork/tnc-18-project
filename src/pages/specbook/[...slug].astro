---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import fs from 'node:fs';
import path from 'node:path';
import matter from 'gray-matter';

export async function getStaticPaths() {
  const dir = path.join(process.cwd(), 'src/content/specbook');
  const files = fs.readdirSync(dir).filter(f => f.endsWith('.md'));
  return files.map(filename => ({
    params: { slug: filename.replace('.md', '') },
    props: { filename }
  }));
}

const { filename } = Astro.props;
const { slug } = Astro.params;
const dir = path.join(process.cwd(), 'src/content/specbook');
const raw = fs.readFileSync(path.join(dir, `${filename}`), 'utf8');
const { data: d, content: body } = matter(raw);

const seoTitle = d.seo_title || d.title;
const seoDescription = d.seo_description || d.excerpt || `${d.title} — TNC.18 Bangkok`;
const canonical = `https://tnc-18-project.pages.dev/specbook/${slug}`;
const publishDate = new Date(d.date).toISOString();
const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": seoTitle,
  "description": seoDescription,
  "datePublished": publishDate,
  "author": { "@type": "Organization", "name": "TNC.18" }
});

// Convert markdown to HTML
function mdToHtml(md) {
  let out = md
    .replace(/^### (.+)$/gm, '<h3>$1</h3>')
    .replace(/^## (.+)$/gm, '<h2>$1</h2>')
    .replace(/^# (.+)$/gm, '<h1>$1</h1>')
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2">$1</a>')
    .replace(/^- (.+)$/gm, '<li>$1</li>')
    .replace(/^---$/gm, '<hr>');
  out = out.replace(/(<li>[\s\S]*?<\/li>)(\n<li>[\s\S]*?<\/li>)*/g, (m) => `<ul>${m}</ul>`);
  return out.split(/\n\n+/).map(block => {
    const b = block.trim();
    if (!b) return '';
    if (/^<(h[1-6]|ul|hr)/.test(b)) return b;
    return `<p>${b.replace(/\n/g, ' ')}</p>`;
  }).join('\n');
}
const htmlBody = mdToHtml(body);
---

<Layout title={seoTitle} description={seoDescription}>
  <script type="application/ld+json" set:html={jsonLd} slot="head" />
  <Navbar />

  <main class="art-main">
    <header class="art-hero">
      {d.cover
        ? <img src={d.cover} alt={d.title} class="art-hero-img" loading="eager" />
        : <div class="art-hero-ph"></div>
      }
      <div class="art-hero-veil"></div>
      <div class="art-hero-ui">
        <nav class="art-breadcrumb">
          <a href="/specbook" class="art-back">← Specbook</a>
          {d.category && <span class="art-bc-sep">/</span>}
          {d.category && <span class="art-bc-cat">{d.category}</span>}
        </nav>
        <div class="art-hero-bot">
          <h1 class={`art-title${d.lang === "th" ? " art-title-th" : ""}`}>{d.title}</h1>
          <p class="art-date">
            {new Date(d.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
          </p>
        </div>
      </div>
    </header>

    {d.excerpt && (
      <div class="art-lede" data-reveal>
        <p class={`art-lede-text${d.lang === "th" ? " art-lede-text-th" : ""}`}>{d.excerpt}</p>
      </div>
    )}

    {d.tags && d.tags.length > 0 && (
      <div class="art-tags">
        {d.tags.map((tag: string) => <span class="art-tag">{tag}</span>)}
      </div>
    )}

    <div class={`art-prose${d.lang === "th" ? " art-prose-th" : ""}`} data-reveal set:html={htmlBody}></div>
  </main>

  <Footer ctaTitle="Start a Project" ctaSub="Senior partners only. We reply within 2 hours." />
<script>
  const reveals = document.querySelectorAll('[data-reveal]');
  if ('IntersectionObserver' in window) {
    const io = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) { e.target.classList.add('revealed'); io.unobserve(e.target); }
      });
    }, { threshold: 0.05 });
    reveals.forEach(el => io.observe(el));
  } else {
    reveals.forEach(el => el.classList.add('revealed'));
  }
</script>
</Layout>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  /* ── LAYOUT ── */
  .art-main { padding-top: 72px; background: #F7F6F2; min-height: 100vh; }

  /* ── HERO ── */
  .art-hero { position: relative; width: 100%; height: 70vh; min-height: 420px; overflow: hidden; background: #0a0e18; }
  .art-hero-img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .art-hero-ph { width: 100%; height: 100%; background: linear-gradient(135deg, #1a2a3e 0%, #0a0e18 100%); }
  .art-hero-veil { position: absolute; inset: 0; background: linear-gradient(to top, rgba(4,6,10,0.92) 0%, rgba(4,6,10,0.3) 45%, rgba(4,6,10,0.1) 100%); }
  .art-hero-ui { position: absolute; inset: 0; display: flex; flex-direction: column; justify-content: space-between; padding: 2rem clamp(1.5rem, 6vw, 5rem) 3.5rem; }
  .art-breadcrumb { display: flex; align-items: center; gap: 0.75rem; }
  .art-back { font-family: 'Courier New', monospace; font-size: 0.6rem; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(255,255,255,0.6); text-decoration: none; transition: color 0.2s; }
  .art-back:hover { color: #fff; }
  .art-bc-sep { color: rgba(255,255,255,0.2); }
  .art-bc-cat { font-family: 'Courier New', monospace; font-size: 0.55rem; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(255,255,255,0.4); }
  .art-hero-bot { max-width: 860px; }
  .art-title { font-size: clamp(1.8rem, 5vw, 3.75rem); font-weight: 800; letter-spacing: -0.03em; text-transform: uppercase; color: #fff; line-height: 1.06; margin-bottom: 1rem; }
  .art-title-th { font-family: "Noto Sans Thai", system-ui, sans-serif !important; text-transform: none !important; letter-spacing: -0.01em !important; line-height: 1.3; font-weight: 800; }
  .art-date { font-family: 'Courier New', monospace; font-size: 0.55rem; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(255,255,255,0.4); }

  /* ── LEDE ── */
  .art-lede {
    padding: 3.5rem clamp(1.5rem, 6vw, 5rem);
    border-bottom: 1px solid rgba(26,26,26,0.08);
    opacity: 0; transform: translateY(16px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  .art-lede.revealed { opacity: 1; transform: none; }
  .art-lede-text { font-size: clamp(1.05rem, 2.2vw, 1.35rem); font-weight: 300; line-height: 1.85; color: #555; max-width: 700px; font-style: italic; }
  .art-lede-text-th { font-family: "Noto Sans Thai", system-ui, sans-serif !important; font-style: normal !important; line-height: 2.1; letter-spacing: 0; -webkit-font-smoothing: antialiased; }

  /* ── TAGS ── */
  .art-tags { display: flex; gap: 0.5rem; flex-wrap: wrap; padding: 1.5rem clamp(1.5rem, 6vw, 5rem); border-bottom: 1px solid rgba(26,26,26,0.06); }
  .art-tag { font-family: 'Courier New', monospace; font-size: 0.5rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--navy, #1A3A6B); border: 0.5px solid rgba(26,58,107,0.3); padding: 0.3rem 0.8rem; border-radius: 2px; }

  /* ── PROSE WRAPPER ── */
  .art-prose {
    max-width: 740px;
    margin: 0 auto;
    padding: 5rem clamp(1.5rem, 6vw, 2rem) 8rem;
    opacity: 0; transform: translateY(16px);
    transition: opacity 0.7s ease 0.1s, transform 0.7s ease 0.1s;
  }
  .art-prose.revealed { opacity: 1; transform: none; }

  /* ── PROSE ELEMENTS ── */
  .art-prose h2 {
    font-size: clamp(1.35rem, 2.8vw, 1.85rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    color: #111;
    line-height: 1.2;
    margin-top: 4rem;
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 1.5px solid rgba(17,17,17,0.08);
  }
  .art-prose h2:first-child { margin-top: 0; }
  .art-prose h3 {
    font-size: clamp(1rem, 2vw, 1.2rem);
    font-weight: 600;
    letter-spacing: -0.015em;
    color: #1a1a1a;
    line-height: 1.4;
    margin-top: 2.75rem;
    margin-bottom: 0.85rem;
  }
  .art-prose p {
    font-size: 1.025rem;
    line-height: 1.95;
    color: #444;
    font-weight: 300;
    margin-bottom: 1.75rem;
  }
  .art-prose p:last-child { margin-bottom: 0; }
  .art-prose strong { font-weight: 600; color: #1a1a1a; }
  .art-prose a { color: var(--navy, #1A3A6B); text-decoration: underline; text-underline-offset: 4px; text-decoration-thickness: 1px; transition: opacity 0.2s; }
  .art-prose a:hover { opacity: 0.65; }
  .art-prose ul { padding-left: 1.5rem; margin: 0.5rem 0 1.75rem; list-style: disc; }
  .art-prose li { font-size: 1.025rem; line-height: 1.9; color: #444; font-weight: 300; margin-bottom: 0.6rem; padding-left: 0.25rem; }
  .art-prose table { width: 100%; border-collapse: collapse; margin: 2.5rem 0; font-size: 0.925rem; border-radius: 4px; overflow: hidden; border: 1px solid rgba(17,17,17,0.09); }
  .art-prose td { padding: 1rem 1.25rem; border-bottom: 1px solid rgba(17,17,17,0.07); color: #555; line-height: 1.65; vertical-align: top; }
  .art-prose tr:first-child td { font-weight: 600; color: #111; background: rgba(26,58,107,0.04); border-bottom: 1.5px solid rgba(17,17,17,0.1); }
  .art-prose tr:last-child td { border-bottom: none; }
  .art-prose hr { border: none; border-top: 1px solid rgba(17,17,17,0.09); margin: 4rem 0; }

  /* ── THAI OVERRIDES ── */
  .art-prose-th h2,
  .art-prose-th h3,
  .art-prose-th p,
  .art-prose-th li,
  .art-prose-th td,
  .art-prose-th strong {
    font-family: "Noto Sans Thai", system-ui, sans-serif !important;
    text-transform: none !important;
    letter-spacing: 0 !important;
    -webkit-font-smoothing: antialiased;
  }
  .art-prose-th h2 { font-weight: 700; line-height: 1.55; font-size: clamp(1.25rem, 2.5vw, 1.65rem); }
  .art-prose-th h3 { font-weight: 600; line-height: 1.75; font-size: clamp(1rem, 1.8vw, 1.15rem); }
  .art-prose-th p, .art-prose-th li { line-height: 2.25; font-size: 1rem; }

  /* ── RESPONSIVE ── */
  @media (min-width: 768px) {
    .art-hero { height: 78vh; }
    .art-prose { padding: 6rem 3rem 10rem; }
  }
  @media (min-width: 1100px) {
    .art-prose { padding: 6rem 0 10rem; }
  }
</style>